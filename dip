function renderAgents(data){
  const agentGrid=el('agentGrid'); if(!agentGrid) return;
  agentGrid.innerHTML='';
  const agentMap={};
  data.forEach(d=>{
    const k=d.agentName||'Unknown'; if(k==='—'||!k) return;
    if(!agentMap[k]) agentMap[k]={name:k,total:0,delivered:0,returned:0,pending:0,cancelled:0};
    agentMap[k].total++;
    if(d.orderStatus==='Delivered') agentMap[k].delivered++;
    else if(['Returned','Pending Return','Return Confirmed'].includes(d.orderStatus)) agentMap[k].returned++;
    else if(d.orderStatus==='Pending') agentMap[k].pending++;
    else if(d.orderStatus==='Cancelled') agentMap[k].cancelled++;
  });
  const agents=Object.values(agentMap).sort((a,b)=>b.delivered-a.delivered);
  agents.forEach((ag,i)=>{
    const rr=ag.total?(ag.returned/ag.total*100).toFixed(1):0;
    const isSelected=SEL_AGENT===ag.name;
    const tile=document.createElement('div');
    tile.className='agent-tile'+(isSelected?' selected':'');
    const rankClass=i===0?'rank-1':i===1?'rank-2':i===2?'rank-3':'rank-other';
    tile.innerHTML=`
      <div class="rank-badge ${rankClass}">${i+1}</div>
      <div class="agent-name">${ag.name}</div>
      <div class="agent-meta">${ag.total} orders total</div>
      <div class="agent-stats">
        <div class="agent-stat-box"><div class="agent-stat-label">Delivered</div><div class="agent-stat-value" style="color:#16a34a">${ag.delivered}</div></div>
        <div class="agent-stat-box"><div class="agent-stat-label">Returned</div><div class="agent-stat-value" style="color:#dc2626">${ag.returned}</div></div>
        <div class="agent-stat-box"><div class="agent-stat-label">Pending</div><div class="agent-stat-value" style="color:#b45309">${ag.pending}</div></div>
        <div class="agent-stat-box"><div class="agent-stat-label">Return %</div><div class="agent-stat-value" style="color:#dc2626">${rr}%</div></div>
      </div>
      <div>
        <div style="display:flex;justify-content:space-between;font-size:.62rem;color:var(--t3);margin-top:.4rem;margin-bottom:.15rem"><span>Delivery Rate</span><span style="font-weight:700">${ag.total?(ag.delivered/ag.total*100).toFixed(1):0}%</span></div>
        <div class="progress-bar"><div class="progress-fill" style="width:${ag.total?(ag.delivered/ag.total*100).toFixed(1):0}%"></div></div>
      </div>`;
    tile.onclick=()=>{
      SEL_AGENT=SEL_AGENT===ag.name?null:ag.name;
      applyAll();
    };
    agentGrid.appendChild(tile);
  });
  renderAgentCombinedChart(agents);
  renderSectionGrid('agents',data);
}

