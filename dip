// SECTION NAVIGATION — resets agent filter on nav
// ══════════════════════════════════════════════════════
function showSection(name,navEl){
  // Reset contextual filters when navigating
  SEL_AGENT=null;
  if(name!=='activations') SEL_ACT_CHANNEL=null;
  CUR_SECTION=name;
  document.querySelectorAll('.dashboard-section').forEach(s=>s.style.display='none');
  const sec=el('sec-'+name);if(sec)sec.style.display='block';
  document.querySelectorAll('.nav-item').forEach(n=>n.classList.remove('active'));
  if(navEl)navEl.classList.add('active');
  applyAll();
}

// ══════════════════════════════════════════════════════
// SIDEBAR / THEME
// ══════════════════════════════════════════════════════
function toggleSidebar(){
  const sb=el('sidebar');sb.classList.toggle('collapsed');
  const c=sb.classList.contains('collapsed');
  el('sidebarIcon').innerHTML=c?'<polyline points="9 18 15 12 9 6"/><polyline points="15 18 21 12 15 6"/>':'<polyline points="15 18 9 12 15 6"/><polyline points="9 18 3 12 9 6"/>';
}
function applyTheme(base,dark){
  if(base==='teal') document.body.setAttribute('data-theme',dark?'teal-dark':'teal');
  else{if(dark) document.body.setAttribute('data-theme','dark');else document.body.removeAttribute('data-theme');}
  const icon=el('themeIcon');
  if(icon) icon.innerHTML=dark?'<path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/>':'<circle cx="12" cy="12" r="5"/><line x1="12" y1="1" x2="12" y2="3"/><line x1="12" y1="21" x2="12" y2="23"/><line x1="4.22" y1="4.22" x2="5.64" y2="5.64"/><line x1="18.36" y1="18.36" x2="19.78" y2="19.78"/><line x1="1" y1="12" x2="3" y2="12"/><line x1="21" y1="12" x2="23" y2="12"/><line x1="4.22" y1="19.78" x2="5.64" y2="18.36"/><line x1="18.36" y1="5.64" x2="19.78" y2="4.22"/>';
}
function changeScheme(v){
  const cur=document.body.getAttribute('data-theme')||'';
  const isDark=cur==='dark'||cur==='teal-dark';
  applyTheme(v,isDark);
  try{localStorage.setItem('dip_scheme',v);}catch(e){}
  setTimeout(()=>applyAll(),100);
}
function toggleTheme(){
  const cur=document.body.getAttribute('data-theme')||'';
  const isDark=cur==='dark'||cur==='teal-dark';
  const isTeal=cur==='teal'||cur==='teal-dark';
  applyTheme(isTeal?'teal':'blue',!isDark);
  try{localStorage.setItem('dip_dark',String(!isDark));}catch(e){}
  setTimeout(()=>applyAll(),100);
}

