      <div class="landing-features">
        <div class="landing-feature">
          <div class="landing-feature-icon"><svg viewBox="0 0 24 24" style="width:18px;height:18px;stroke:var(--acc);fill:none;stroke-width:2"><polyline points="23 6 13.5 15.5 8.5 10.5 1 18"/></svg></div>
          <div><div class="landing-feature-title">Activation Analytics</div><div class="landing-feature-desc">Daily, weekly, monthly and quarterly activation tracking per channel &amp; segment</div></div>
        </div>
        <div class="landing-feature">
          <div class="landing-feature-icon"><svg viewBox="0 0 24 24" style="width:18px;height:18px;stroke:var(--acc);fill:none;stroke-width:2"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/></svg></div>
          <div><div class="landing-feature-title">Agent Leaderboard</div><div class="landing-feature-desc">Real-time agent performance with activation, returns &amp; delivery metrics</div></div>
        </div>
        <div class="landing-feature">
          <div class="landing-feature-icon"><svg viewBox="0 0 24 24" style="width:18px;height:18px;stroke:var(--acc);fill:none;stroke-width:2"><circle cx="12" cy="12" r="10"/><path d="M12 2a10 10 0 0 1 10 10"/></svg></div>
          <div><div class="landing-feature-title">Returns Intelligence</div><div class="landing-feature-desc">Activation vs returns ratio with failure reason deep-dive</div></div>
        </div>
      </div>
    </div>
  </div>
  <div class="landing-right">
    <div class="landing-container">
      <div class="landing-header" style="animation:slideUp .7s ease forwards">
        <div style="display:flex;justify-content:center;margin-bottom:.85rem">
          <div class="logo-icon"><svg viewBox="0 0 24 24" style="width:32px;height:32px;stroke:#fff;fill:none;stroke-width:2"><rect x="2" y="3" width="20" height="14" rx="2"/><path d="M8 21h8"/><path d="M12 17v4"/><path d="M7 8l3 3 4-4 3 3"/></svg></div>
        </div>
        <h1 class="landing-title">DIP Dashboard</h1>
        <p class="landing-subtitle">Device Intelligence Platform · CLF SharePoint</p>
      </div>
      <div class="landing-card" style="animation:slideUp .7s ease .2s forwards;opacity:0">
        <div class="welcome-badge"><span class="badge-pulse"></span><span>DSP Devices Tracker</span></div>
        <div class="landing-user-info">
          <div class="avatar-placeholder" id="lAvatar">D</div>
          <div class="landing-details">
            <h3 id="lName">DIP Dashboard</h3>
            <p id="lEmail">CLF SharePoint</p>
            <p id="lRole" class="landing-role">All Users</p>
          </div>
        </div>
        <div class="stats-grid">
          <div class="landing-stat-card">
            <div class="stat-icon-bg"><svg viewBox="0 0 24 24" style="width:16px;height:16px;stroke:var(--acc);fill:none;stroke-width:2"><polyline points="23 6 13.5 15.5 8.5 10.5 1 18"/></svg></div>
            <div><div class="stat-label">Total Visits</div><div class="stat-value-sm" id="lVisits">--</div></div>
          </div>
          <div class="landing-stat-card">
            <div class="stat-icon-bg"><svg viewBox="0 0 24 24" style="width:16px;height:16px;stroke:var(--acc);fill:none;stroke-width:2"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg></div>
            <div><div class="stat-label">Last Visit</div><div class="stat-value-sm" id="lLastVisit" style="font-size:.82rem">--</div></div>
          </div>
        </div>
        <button type="button" id="launchBtn" class="landing-btn btn-primary">
          <svg style="width:18px;height:18px;stroke:#fff;fill:none;stroke-width:2" viewBox="0 0 24 24"><polyline points="5 12 19 12"/><polyline points="12 5 19 12 12 19"/></svg>
          <span>Launch DIP Dashboard</span>
        </button>
        <p class="landing-note"><svg viewBox="0 0 24 24" style="width:14px;height:14px;stroke:#16a34a;fill:none;stroke-width:2;flex-shrink:0"><polyline points="20 6 9 17 4 12"/></svg><span style="color:#16a34a;font-weight:600;">Open access — all team members welcome</span></p>
      </div>
      <div class="landing-footer">DIP Dashboard · Powered by CLF SharePoint</div>
    </div>
  </div>
</div>

<!-- MAIN DASHBOARD -->
<div class="portal-shell" id="dashboardContent" style="display:none;">
  <div class="header">
    <div class="logo-section">
      <div class="logo"><svg viewBox="0 0 24 24"><rect x="2" y="3" width="20" height="14" rx="2"/><path d="M8 21h8"/><path d="M12 17v4"/><path d="M7 8l3 3 4-4 3 3"/></svg></div>
      <span class="header-title">DIP Dashboard</span>
    </div>
    <div class="header-center">
      <div class="live-badge-pill"><span class="status-dot"></span><span>Live</span></div>
      <div class="date-badge">
        <svg style="width:14px;height:14px;stroke:currentColor;fill:none;stroke-width:2" viewBox="0 0 24 24"><rect x="3" y="4" width="18" height="18" rx="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
        <span id="currentDate"></span>
      </div>
      <div class="date-badge" id="dbUserBadge" style="color:var(--acc);font-weight:600;"></div>
      <div class="date-badge" id="selBadge" style="color:var(--acc2);font-weight:600;display:none;cursor:pointer;" onclick="SEL_STATUS=null;SEL_AGENT=null;SEL_ACT_CHANNEL=null;applyAll();" title="Click to clear filter"></div>
    </div>
    <div class="header-actions">
      <select class="color-scheme-selector" id="schemeSelect" onchange="changeScheme(this.value)">
        <option value="blue">&#9670; Blue</option>
        <option value="teal">&#9670; Teal</option>
      </select>
      <div class="theme-toggle" onclick="toggleTheme()" title="Light/Dark">
        <svg id="themeIcon" viewBox="0 0 24 24"><circle cx="12" cy="12" r="5"/><line x1="12" y1="1" x2="12" y2="3"/><line x1="12" y1="21" x2="12" y2="23"/><line x1="4.22" y1="4.22" x2="5.64" y2="5.64"/><line x1="18.36" y1="18.36" x2="19.78" y2="19.78"/><line x1="1" y1="12" x2="3" y2="12"/><line x1="21" y1="12" x2="23" y2="12"/><line x1="4.22" y1="19.78" x2="5.64" y2="18.36"/><line x1="18.36" y1="5.64" x2="19.78" y2="4.22"/></svg>
      </div>
    </div>
  </div>

  <div class="main-container">
    <div class="sidebar" id="sidebar">
      <div class="sidebar-toggle-btn" onclick="toggleSidebar()">
        <svg id="sidebarIcon" viewBox="0 0 24 24"><polyline points="15 18 9 12 15 6"/><polyline points="9 18 3 12 9 6"/></svg>
      </div>
      <div class="nav-items">
        <div class="nav-section-label">Overview</div>
        <div class="nav-item active" onclick="showSection('overview',this)">
          <div class="nav-icon"><svg viewBox="0 0 24 24"><rect x="3" y="3" width="7" height="7"/><rect x="14" y="3" width="7" height="7"/><rect x="14" y="14" width="7" height="7"/><rect x="3" y="14" width="7" height="7"/></svg></div>
          <div>Overview</div>
        </div>
        <div class="nav-section-label">Analytics</div>
        <div class="nav-item" onclick="showSection('activations',this)">
          <div class="nav-icon"><svg viewBox="0 0 24 24"><polyline points="23 6 13.5 15.5 8.5 10.5 1 18"/></svg></div>
          <div>Activations</div>
        </div>
        <div class="nav-item" onclick="showSection('returns',this)">
          <div class="nav-icon"><svg viewBox="0 0 24 24"><polyline points="1 4 1 10 7 10"/><path d="M3.51 15a9 9 0 1 0 .49-4.95"/></svg></div>
          <div>Returns</div>
        </div>
        <div class="nav-item" onclick="showSection('agents',this)">
          <div class="nav-icon"><svg viewBox="0 0 24 24"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg></div>
          <div>Agents</div>
        </div>
        <div class="nav-item" onclick="showSection('comparison',this)">
          <div class="nav-icon"><svg viewBox="0 0 24 24"><line x1="18" y1="20" x2="18" y2="10"/><line x1="12" y1="20" x2="12" y2="4"/><line x1="6" y1="20" x2="6" y2="14"/></svg></div>
          <div>Comparison</div>
        </div>
        <div class="nav-item" onclick="showSection('handsets',this)">
          <div class="nav-icon"><svg viewBox="0 0 24 24"><rect x="5" y="2" width="14" height="20" rx="2"/><line x1="12" y1="18" x2="12.01" y2="18"/></svg></div>
          <div>Top Handsets</div>
        </div>
        <div class="nav-section-label">Coming Soon</div>
        <div class="nav-item" style="opacity:.5;cursor:not-allowed">
          <div class="nav-icon"><svg viewBox="0 0 24 24"><path d="M10.29 3.86L1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z"/></svg></div>
          <div>Issue Tracker</div>
        </div>
      </div>
    </div>

    <div class="content">

      <!-- ══ SHARED FILTER BAR (renders inside each section) ══ -->

      <!-- OVERVIEW -->
      <div id="sec-overview" class="dashboard-section">
        <div class="page-header-row">
          <h2 class="section-title"><svg viewBox="0 0 24 24"><rect x="3" y="3" width="7" height="7"/><rect x="14" y="3" width="7" height="7"/><rect x="14" y="14" width="7" height="7"/><rect x="3" y="14" width="7" height="7"/></svg>Overview</h2>
          <button type="button" class="pdf-export-btn" onclick="exportPDF('overview')"><svg viewBox="0 0 24 24"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="9" y1="15" x2="15" y2="15"/></svg>Export to PDF</button>
        </div>
        <div id="filters-overview" class="filters-section"></div>
        <div class="top-stats" id="topStats"></div>
        <div class="insight-grid" id="insightGrid"></div>
        <div class="charts-row charts-2">
          <div class="chart-card">
            <div class="chart-title">
              <div class="chart-title-left"><svg viewBox="0 0 24 24"><polyline points="23 6 13.5 15.5 8.5 10.5 1 18"/></svg>Activation Trend</div>
              <div class="toggle-mini" id="trendPeriodToggle"></div>
            </div>
            <div class="chart-container" style="height:270px"><canvas id="chartTrend"></canvas></div>
          </div>
          <div class="chart-card">
            <div class="chart-title">
              <div class="chart-title-left"><svg viewBox="0 0 24 24"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/></svg>Activations by Sales Channel</div>
            </div>
            <div class="chart-container" style="height:270px"><canvas id="chartChannel"></canvas></div>
          </div>
        </div>
        <div class="charts-row charts-2">
          <div class="chart-card">
            <div class="chart-title"><div class="chart-title-left"><svg viewBox="0 0 24 24"><circle cx="12" cy="12" r="10"/></svg>Activation by Segment</div></div>
            <div class="chart-container" style="height:270px"><canvas id="chartSegment"></canvas></div>
          </div>
          <div class="chart-card">
            <div class="chart-title"><div class="chart-title-left"><svg viewBox="0 0 24 24"><polyline points="22 12 18 12 15 21 9 3 6 12 2 12"/></svg>Order Status Distribution</div></div>
            <div class="chart-container" style="height:270px"><canvas id="chartStatus"></canvas></div>
          </div>
        </div>
        <div class="charts-row charts-2">
          <div class="chart-card">
            <div class="chart-title">
              <div class="chart-title-left"><svg viewBox="0 0 24 24"><line x1="18" y1="20" x2="18" y2="10"/><line x1="12" y1="20" x2="12" y2="4"/><line x1="6" y1="20" x2="6" y2="14"/></svg>Activations vs Returns</div>
              <div class="toggle-mini" id="avRPeriodToggle"></div>
            </div>
            <div class="chart-container" style="height:270px"><canvas id="chartAvR"></canvas></div>
          </div>
          <div class="chart-card">
            <div class="chart-title"><div class="chart-title-left"><svg viewBox="0 0 24 24"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/></svg>du Status Breakdown</div></div>
            <div class="chart-container" style="height:270px"><canvas id="chartDuStatus"></canvas></div>
          </div>
        </div>
        <!-- DATA GRID -->
        <div class="table-section">
          <div class="table-header">
            <div class="table-title"><svg viewBox="0 0 24 24"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/></svg>Device Records</div>
            <div class="table-actions">
              <button type="button" class="export-btn" onclick="exportData('overview')"><svg viewBox="0 0 24 24"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/></svg>Export</button>
              <input type="text" class="search-box" placeholder="Search..." oninput="gridSearch('overview',this.value)">
            </div>
          </div>
          <div id="grid-overview" class="ag-theme-alpine" style="height:480px;width:100%;"></div>
        </div>
