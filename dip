<script>
// ══════════════════════════════════════════════════════
// CONFIG
// ══════════════════════════════════════════════════════
const SP_SITE = 'http://sharedspaces:8092/sites/CLF';
const SP_LIST = 'DSP Devices Tracker';

// Channels that are "Consumer" or "Enterprise" — excluded from channel-only charts
const CONSUMER_ENT_CHANNELS = ['Consumer','Enterprise'];

// ══════════════════════════════════════════════════════
// STATE
// ══════════════════════════════════════════════════════
let USER = {email:'',name:'Dashboard User',role:'Admin'};
let ALL_DATA = [];
let FILTERED = [];
let CHARTS = {};
let GRID_APIS = {};
let CUR_PERIOD = 'all';
let CUR_SECTION = 'overview';
let CUR_COMP_MODE = 'qoq';
let TREND_PERIOD = 'M';
let AVR_PERIOD = 'M';
let ACT_CH_PERIOD = 'M';
let HANDSET_METRIC = 'count';
let SEL_STATUS = null;
let SEL_AGENT = null;
let SEL_ACT_CHANNEL = null;
let DATE_FILTERS = {year:null,quarter:null,month:null,week:null,date:null};
const FILTER_DEFS = [
  {key:'orderStatus',label:'Order Status'},
  {key:'duStatus',label:'du Status'},
  {key:'agentName',label:'Agent'},
  {key:'salesChannel',label:'Sales Channel'},
  {key:'accountType',label:'Account Type'},
];
// Per-section filter state — each section independently
let SECTION_FILTERS = {};

// ══════════════════════════════════════════════════════
// UTILS
// ══════════════════════════════════════════════════════
const el = id => document.getElementById(id);
const set = (id,v) => { const e=el(id); if(e) e.textContent=v; };
function fmtDate(v){ if(!v) return '—'; const d=new Date(v); return isNaN(d)?'—':d.toLocaleDateString('en-GB'); }
function getWeekOfYear(date){ const d=new Date(date); d.setHours(0,0,0,0); d.setDate(d.getDate()+3-(d.getDay()+6)%7); const w1=new Date(d.getFullYear(),0,4); return 1+Math.round(((d-w1)/864e5-3+(w1.getDay()+6)%7)/7); }
function getRefDate(item){ return item.deliveryDate || item.creationDate || item.created; }

// ══════════════════════════════════════════════════════
// SP FETCH
// ══════════════════════════════════════════════════════
function spGet(url,cb){
  const xhr=new XMLHttpRequest();
  xhr.open('GET',url,true);
  xhr.setRequestHeader('Accept','application/json;odata=verbose');
  xhr.onreadystatechange=function(){
    if(xhr.readyState!==4) return;
    if(xhr.status>=200&&xhr.status<300){ try{ cb(null,JSON.parse(xhr.responseText)); }catch(e){ cb(e,null); } }
    else{ cb(new Error('HTTP '+xhr.status),null); }
  };
  xhr.onerror=()=>cb(new Error('Network error'),null);
  xhr.send();
}

// ══════════════════════════════════════════════════════
// LOAD DATA
// ══════════════════════════════════════════════════════
function loadData(){
  el('loadingOverlay').style.display='flex';
  set('loadingText','Loading DSP Devices Tracker...');
  const select=['Title','Package_x0020_Name','Description','Receiver_x0020_Address','Receiver_x0020_Name','Receiver_x0020_Phone_x0020_Numbe','Win_x0020_cash_x0020_Code','Order_x0020_Ref_x0023_','Order_x0020_Status','Dealer_x0020_ID','Dealer_x0020_Name','du_x0020_status','Creation_x0020_Date','Delivery_x0020_Date','Wincash_x0020_Date','Agent_x0020_Name_x0020_2','Account_x0020_Type','Plan_x0020_Name','Customer_x0020_Type','Order_x0020_Assigned_x0020_To','Edara_x0020_Delivery_x0020_Agent','Comments','Failure_x0020_Reason','Edara_x0020_Pickup_x0020_Date','Modified','Created'].join(',');
  let allResults=[];
  function fetchPage(url){
    spGet(url,function(err,data){
      if(err){ console.error('Load error:',err); ALL_DATA=[]; finishLoad(); return; }
      allResults=allResults.concat(data.d.results);
      set('loadingText','Loaded '+allResults.length+' records...');
      if(data.d.__next){ fetchPage(data.d.__next); }
      else{ ALL_DATA=allResults.map(mapItem); finishLoad(); }
    });
  }
  const url=SP_SITE+"/_api/web/lists/getbytitle('"+SP_LIST+"')/items?$select="+encodeURIComponent(select)+"&$top=5000&$orderby=Id desc";
  fetchPage(url);
}

function mapItem(it){
  return {
    id:it.Id||0, activityNo:it.Title||'—', packageName:it.Package_x0020_Name||'—',
    description:it.Description||'—', receiverAddress:it.Receiver_x0020_Address||'—',
    receiverName:it.Receiver_x0020_Name||'—', receiverPhone:it.Receiver_x0020_Phone_x0020_Numbe||'—',
    wincashCode:it.Win_x0020_cash_x0020_Code||'—', orderRef:it.Order_x0020_Ref_x0023_||'—',
    orderStatus:it.Order_x0020_Status||'—', dealerId:it.Dealer_x0020_ID||'—',
    dealerName:it.Dealer_x0020_Name||'—', duStatus:it.du_x0020_status||'—',
    creationDate:it.Creation_x0020_Date||it.Created||null, deliveryDate:it.Delivery_x0020_Date||null,
    wincashDate:it.Wincash_x0020_Date||null, agentName:it.Agent_x0020_Name_x0020_2||'—',
    accountType:it.Account_x0020_Type||'—', planName:it.Plan_x0020_Name||'—',
    salesChannel:it.Customer_x0020_Type||'—', orderAssignedTo:it.Order_x0020_Assigned_x0020_To||'—',
    edaraAgent:it.Edara_x0020_Delivery_x0020_Agent||'—', comments:it.Comments||'—',
    failureReason:it.Failure_x0020_Reason||'—', edaraPickupDate:it.Edara_x0020_Pickup_x0020_Date||null,
    modified:it.Modified||null, created:it.Created||null,
  };
}

function finishLoad(){
  el('loadingOverlay').style.display='none';
  // Build filter bars for all sections
  ['overview','activations','returns','agents','handsets'].forEach(s=>buildFilterBar(s));
  applyAll();
}

// ══════════════════════════════════════════════════════
// DATE PERIOD
// ══════════════════════════════════════════════════════
function filterByPeriod(data){
  // Specific date filter takes precedence over cascading filters
  if(DATE_FILTERS.date){
    const sel=new Date(DATE_FILTERS.date+'T00:00:00');
    if(!isNaN(sel)){
      return data.filter(item=>{
        const rd=getRefDate(item); if(!rd) return false;
        const dt=new Date(rd);
        return dt.getFullYear()===sel.getFullYear()&&dt.getMonth()===sel.getMonth()&&dt.getDate()===sel.getDate();
      });
    }
  }
  // Use DATE_FILTERS cascading if any set
  if(DATE_FILTERS.year||DATE_FILTERS.quarter||DATE_FILTERS.month!==null||DATE_FILTERS.week){
    return data.filter(item=>{
      const rd=getRefDate(item); if(!rd) return false;
      const dt=new Date(rd);
      if(DATE_FILTERS.year&&dt.getFullYear()!==parseInt(DATE_FILTERS.year)) return false;
      if(DATE_FILTERS.quarter){const q=parseInt(DATE_FILTERS.quarter.replace('Q',''))-1;if(Math.floor(dt.getMonth()/3)!==q)return false;}
      if(DATE_FILTERS.month!==null&&DATE_FILTERS.month!==''){if(dt.getMonth()!==parseInt(DATE_FILTERS.month))return false;}
      if(DATE_FILTERS.week&&getWeekOfYear(dt)!==parseInt(DATE_FILTERS.week)) return false;
      return true;
    });
  }
  return data; // All time by default
}

// ══════════════════════════════════════════════════════
// FILTER BAR BUILDER (shared across sections)
// ══════════════════════════════════════════════════════
function buildFilterBar(section){
  const container=el('filters-'+section); if(!container) return;
  container.innerHTML='';
  // Init state
  if(!SECTION_FILTERS[section]) SECTION_FILTERS[section]={};
  FILTER_DEFS.forEach(fd=>{ if(!SECTION_FILTERS[section][fd.key]) SECTION_FILTERS[section][fd.key]=[]; });

  const row=document.createElement('div');
  row.className='filters-row';

  // Date cascade dropdowns (shared global state)
  const dateFields=[
    {key:'year',label:'Year'},
    {key:'quarter',label:'Quarter'},
    {key:'month',label:'Month'},
    {key:'week',label:'Week'},
  ];
  dateFields.forEach(dd=>{
    const grp=document.createElement('div'); grp.className='filter-group';
    grp.innerHTML=`<div class="filter-label">${dd.label}</div>`;
    const sel=document.createElement('select');
    sel.id=`df_${section}_${dd.key}`;
    sel.className='f-select';
    sel.onchange=()=>onDateFilterChange(dd.key,sel.value,section);
    grp.appendChild(sel); row.appendChild(grp);
  });
  // Specific date picker (calendar)
  const dgrp=document.createElement('div'); dgrp.className='filter-group';
  dgrp.innerHTML=`<div class="filter-label">Date (Calendar)</div>`;
  const dinp=document.createElement('input');
  dinp.type='date'; dinp.id=`df_${section}_date`; dinp.className='f-date';
  dinp.value=DATE_FILTERS.date||'';
  dinp.title='Pick a specific date to filter all charts & tiles';
  dinp.onchange=()=>onDateFilterChange('date',dinp.value,section);
  dgrp.appendChild(dinp); row.appendChild(dgrp);

  // Other multi-select dropdowns
  FILTER_DEFS.forEach(fd=>{
    const vals=[...new Set(ALL_DATA.map(b=>b[fd.key]).filter(v=>v&&v!=='—'))].sort();
    const grp=document.createElement('div'); grp.className='filter-group';
    grp.innerHTML=`<div class="filter-label">${fd.label}</div>`;
    const wrap=document.createElement('div'); wrap.className='ms-wrap'; wrap.id=`ms_${section}_${fd.key}`;
    const trig=document.createElement('div'); trig.className='ms-trigger'; trig.id=`mst_${section}_${fd.key}`;
    trig.innerHTML=`<span class="ms-text" id="mstext_${section}_${fd.key}">All</span><svg viewBox="0 0 24 24"><polyline points="6 9 12 15 18 9"/></svg>`;
    trig.onclick=function(e){e.stopPropagation();toggleMs(section,fd.key);};
    const drop=document.createElement('div'); drop.className='ms-dropdown'; drop.id=`msd_${section}_${fd.key}`;
    vals.forEach(v=>{
      const cid=`cb_${section}_${fd.key}_${v.replace(/[^a-zA-Z0-9]/g,'_')}`;
      const opt=document.createElement('div'); opt.className='ms-option';
      opt.innerHTML=`<input type="checkbox" id="${cid}" value="${v}" onchange="onFChange('${section}','${fd.key}')"><label for="${cid}">${v}</label>`;
      drop.appendChild(opt);
    });
    wrap.appendChild(trig); wrap.appendChild(drop); grp.appendChild(wrap); row.appendChild(grp);
  });

  // Actions
  const acts=document.createElement('div'); acts.className='filter-actions-row';
  acts.innerHTML=`<button type="button" class="reset-btn" onclick="resetFilters('${section}')"><svg viewBox="0 0 24 24"><polyline points="1 4 1 10 7 10"/><path d="M3.51 15a9 9 0 1 0 .49-4.95"/></svg>Reset All Filters</button>`;
  row.appendChild(acts);

  container.appendChild(row);
  populateDateDropdowns(section);
}

function populateDateDropdowns(section){
  const dateOpts={
    year:()=>[...new Set(ALL_DATA.map(d=>{const rd=getRefDate(d);return rd?new Date(rd).getFullYear():null;}).filter(Boolean))].sort((a,b)=>b-a).map(y=>({v:String(y),l:String(y)})),
    quarter:()=>{
      if(!DATE_FILTERS.year) return [];
      const yr=parseInt(DATE_FILTERS.year);
      return [...new Set(ALL_DATA.filter(d=>{const rd=getRefDate(d);return rd&&new Date(rd).getFullYear()===yr;}).map(d=>'Q'+(Math.floor(new Date(getRefDate(d)).getMonth()/3)+1)))].sort().map(q=>({v:q,l:q}));
    },
    month:()=>{
      if(!DATE_FILTERS.year) return [];
      const yr=parseInt(DATE_FILTERS.year);
      const qf=DATE_FILTERS.quarter?parseInt(DATE_FILTERS.quarter.replace('Q',''))-1:null;
      return [...new Set(ALL_DATA.filter(d=>{const rd=getRefDate(d);if(!rd)return false;const dt=new Date(rd);if(dt.getFullYear()!==yr)return false;if(qf!==null&&Math.floor(dt.getMonth()/3)!==qf)return false;return true;}).map(d=>new Date(getRefDate(d)).getMonth()))].sort((a,b)=>a-b).map(m=>({v:String(m),l:new Date(2000,m,1).toLocaleString('en',{month:'long'})}));
    },
    week:()=>{
      if(!DATE_FILTERS.year) return [];
      const yr=parseInt(DATE_FILTERS.year);
      const mf=DATE_FILTERS.month!==null&&DATE_FILTERS.month!==''?parseInt(DATE_FILTERS.month):null;
      return [...new Set(ALL_DATA.filter(d=>{const rd=getRefDate(d);if(!rd)return false;const dt=new Date(rd);if(dt.getFullYear()!==yr)return false;if(mf!==null&&dt.getMonth()!==mf)return false;return true;}).map(d=>getWeekOfYear(new Date(getRefDate(d)))))].sort((a,b)=>a-b).map(w=>({v:String(w),l:'Week '+w}));
    }
  };
  ['year','quarter','month','week'].forEach(key=>{
    const sel=el(`df_${section}_${key}`); if(!sel) return;
    const opts=dateOpts[key]?dateOpts[key]():[];
    sel.innerHTML=`<option value="">All ${key.charAt(0).toUpperCase()+key.slice(1)}</option>`+opts.map(o=>`<option value="${o.v}"${DATE_FILTERS[key]===o.v?' selected':''}>${o.l}</option>`).join('');
  });
  // Sync date picker value
  const dinp=el(`df_${section}_date`); if(dinp) dinp.value=DATE_FILTERS.date||'';
}

function onDateFilterChange(key,value,section){
  DATE_FILTERS[key]=value||null;
  // Picking a specific date clears all cascade filters (it's an exact day filter)
  if(key==='date'&&value){
    DATE_FILTERS.year=null;DATE_FILTERS.quarter=null;DATE_FILTERS.month=null;DATE_FILTERS.week=null;
  } else if(key!=='date'&&value){
    // Picking any cascade filter clears the specific-date selection
    DATE_FILTERS.date=null;
  }
  if(key==='year'){DATE_FILTERS.quarter=null;DATE_FILTERS.month=null;DATE_FILTERS.week=null;}
  if(key==='quarter'){DATE_FILTERS.month=null;DATE_FILTERS.week=null;}
  if(key==='month'){DATE_FILTERS.week=null;}
  // Update all section dropdowns
  ['overview','activations','returns','agents','handsets'].forEach(s=>populateDateDropdowns(s));
  applyAll();
}

function toggleMs(section,key){
  const drop=el(`msd_${section}_${key}`),trig=el(`mst_${section}_${key}`);
  const isOpen=drop.classList.contains('open');
  document.querySelectorAll('.ms-dropdown.open').forEach(d=>{d.classList.remove('open');const parts=d.id.replace('msd_','').split('_');const t=el('mst_'+parts.join('_'));if(t)t.classList.remove('open');});
  if(!isOpen){
    const rect=trig.getBoundingClientRect();
    drop.style.top=(rect.bottom+4)+'px'; drop.style.left=rect.left+'px';
    drop.style.width=Math.max(rect.width,200)+'px';
    drop.classList.add('open'); trig.classList.add('open');
  }
}
document.addEventListener('click',()=>document.querySelectorAll('.ms-dropdown.open').forEach(d=>{d.classList.remove('open');const t=el('mst_'+d.id.replace('msd_',''));if(t)t.classList.remove('open');}));
window.addEventListener('scroll',function(){document.querySelectorAll('.ms-dropdown.open').forEach(d=>{const id=d.id.replace('msd_','');const trig=el('mst_'+id);if(trig){const rect=trig.getBoundingClientRect();d.style.top=(rect.bottom+4)+'px';d.style.left=rect.left+'px';}});},true);

function getChecked(section,key){
  const drop=el(`msd_${section}_${key}`); if(!drop) return [];
  return Array.from(drop.querySelectorAll('input:checked')).map(c=>c.value);
}
function updateMsText(section,key){
  const checked=getChecked(section,key); const e=el(`mstext_${section}_${key}`); if(!e) return;
  e.textContent=!checked.length?'All':checked.length===1?checked[0]:checked.length+' selected';
}
function onFChange(section,key){ updateMsText(section,key); applyAll(); }

function resetFilters(section){
  // Reset date filters
  DATE_FILTERS={year:null,quarter:null,month:null,week:null,date:null};
  SEL_STATUS=null; SEL_AGENT=null; SEL_ACT_CHANNEL=null;
  // Reset all checkboxes across all sections
  ['overview','activations','returns','agents','handsets'].forEach(s=>{
    FILTER_DEFS.forEach(fd=>{
      const drop=el(`msd_${s}_${fd.key}`);
      if(drop) drop.querySelectorAll('input').forEach(c=>c.checked=false);
      updateMsText(s,fd.key);
    });
    populateDateDropdowns(s);
  });
  applyAll();
}

// ══════════════════════════════════════════════════════
// APPLY ALL
// ══════════════════════════════════════════════════════
function applyAll(){
  const sec=CUR_SECTION;
  // Apply section-specific dropdown filters
  const filters={};
  FILTER_DEFS.forEach(fd=>{ filters[fd.key]=getChecked(sec,fd.key); });
  FILTERED=ALL_DATA.filter(item=>{
    for(const fd of FILTER_DEFS){
      const vals=filters[fd.key]; if(!vals.length) continue;
      if(!vals.includes(item[fd.key])) return false;
    }
    return true;
  });
  // Apply agent filter from tile click
  if(SEL_AGENT){ FILTERED=FILTERED.filter(d=>d.agentName===SEL_AGENT); }

  const periodData=filterByPeriod(FILTERED);
  // Status filter for stat tiles
  const statusData=SEL_STATUS?periodData.filter(d=>{
    if(SEL_STATUS==='PendingDelivery'){
      const v=String(d.duStatus||'').toLowerCase().trim();
      return v&&v.includes('pending')&&!v.includes('return')&&!v.includes('cancel');
    }
    if(SEL_STATUS==='PendingReturn'){
      return d.orderStatus==='Pending Return';
    }
    const sg={Returned:['Returned','Pending Return','Return Confirmed'],Delivered:['Delivered'],Cancelled:['Cancelled']};
    return (sg[SEL_STATUS]||[SEL_STATUS]).includes(d.orderStatus);
  }):periodData;

  updateSelBadge();

  if(sec==='overview'){ renderOverview(periodData,statusData); }
  else if(sec==='activations'){ renderActivations(periodData); }
  else if(sec==='returns'){ renderReturns(periodData); }
  else if(sec==='agents'){ renderAgents(periodData); }
  else if(sec==='comparison'){ renderComparison(); }
  else if(sec==='handsets'){ renderHandsets(periodData); }
}

function updateSelBadge(){
  const badge=el('selBadge');
  if(!badge) return;
  const parts=[];
  const labelMap={'PendingDelivery':'Pending Delivery (du status)','PendingReturn':'Pending Return (order status)'};
  if(SEL_STATUS) parts.push('Status: '+(labelMap[SEL_STATUS]||SEL_STATUS));
  if(SEL_AGENT) parts.push('Agent: '+SEL_AGENT);
  if(SEL_ACT_CHANNEL) parts.push('Channel: '+SEL_ACT_CHANNEL);
  if(parts.length){ badge.textContent=parts.join(' · ')+' ✕'; badge.style.display='block'; }
  else badge.style.display='none';
}

