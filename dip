document.addEventListener('keydown',function(e){if(e.ctrlKey&&e.shiftKey&&e.key==='D'){const dc=el('devConsole');dc.style.display=dc.style.display==='none'?'flex':'none';}});
function devLogin(){
  const email=el('devEmail').value.trim();if(!email){alert('Enter email');return;}
  USER.email=email;USER.name=email.split('@')[0].replace(/\./g,' ').replace(/\b\w/g,c=>c.toUpperCase());USER.role='Admin';
  el('devConsole').style.display='none';
  // Update landing card
  const initials=USER.name.trim().split(' ');
  el('lAvatar').textContent=(initials.length>=2?initials[0][0]+initials[initials.length-1][0]:USER.name[0]).toUpperCase();
  set('lName',USER.name); set('lEmail',USER.email+' (Dev)');
  el('landingPage').style.display='flex';
}

// ══════════════════════════════════════════════════════
// LANDING PAGE HELPERS
// ══════════════════════════════════════════════════════
function getVisitCount(){ try{ return parseInt(localStorage.getItem('dip_vc')||'0'); }catch(e){return 0;} }
function incVisit(){ try{ const c=getVisitCount()+1; localStorage.setItem('dip_vc',c); return c; }catch(e){return 1;} }
function getLastVisit(){ try{ const lv=localStorage.getItem('dip_lv'); if(!lv) return 'First visit'; const diff=Date.now()-new Date(lv).getTime(); const m=Math.floor(diff/6e4),h=Math.floor(diff/36e5),d=Math.floor(diff/864e5); if(m<60) return m+'m ago'; if(h<24) return h+'h ago'; if(d<7) return d+'d ago'; return new Date(lv).toLocaleDateString('en-GB'); }catch(e){ return '—'; } }
function saveLastVisit(){ try{ localStorage.setItem('dip_lv',new Date().toISOString()); }catch(e){} }

function launchDashboard(){
  incVisit(); saveLastVisit();
  el('landingPage').style.display='none';
  const dash=el('dashboardContent');
  dash.style.display='flex';
  dash.style.flexDirection='column';
  set('dbUserBadge',USER.name+' · '+USER.role);
  el('currentDate').textContent=new Date().toLocaleDateString('en-US',{weekday:'short',year:'numeric',month:'short',day:'numeric'});
  loadData();
}

// ══════════════════════════════════════════════════════
// INIT — show landing page first
// ══════════════════════════════════════════════════════
window.addEventListener('load',function(){
  // Theme
  try{
    const s=localStorage.getItem('dip_scheme')||'blue';
    const dk=localStorage.getItem('dip_dark')==='true';
    const sel=el('schemeSelect');if(sel) sel.value=s;
    applyTheme(s,dk);
  }catch(e){}

  // Populate landing stats
  set('lVisits', getVisitCount());
  set('lLastVisit', getLastVisit());

  // Try to get SP user identity (non-blocking)
  try{
    spGet(SP_SITE+'/_api/web/currentuser?$select=Title,Email',function(err,data){
      if(!err&&data&&data.d){
        USER.email=data.d.Email; USER.name=data.d.Title;
        const initials=USER.name.trim().split(' ').filter(Boolean);
        el('lAvatar').textContent=(initials.length>=2?initials[0][0]+initials[initials.length-1][0]:USER.name[0]).toUpperCase();
        set('lName',USER.name); set('lEmail',USER.email);
      }
    });
  }catch(e){}

  // Wire launch button
  el('launchBtn').onclick=launchDashboard;

  // Show landing
  el('landingPage').style.display='flex';
  el('dashboardContent').style.display='none';
});
</script>
