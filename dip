function _sectionLabel(s){
  const m={overview:'Overview',activations:'Activation Deep Dive',returns:'Returns Intelligence',agents:'Agent Performance',comparison:'Period Comparison',handsets:'Top Handsets'};
  return m[s]||s;
}
function _getFiltersDescription(section){
  const parts=[];
  if(DATE_FILTERS.date){
    const d=new Date(DATE_FILTERS.date+'T00:00:00');
    parts.push('Date: '+(isNaN(d)?DATE_FILTERS.date:d.toLocaleDateString('en-GB',{weekday:'short',day:'2-digit',month:'short',year:'numeric'})));
  }
  if(DATE_FILTERS.year) parts.push('Year: '+DATE_FILTERS.year);
  if(DATE_FILTERS.quarter) parts.push('Quarter: '+DATE_FILTERS.quarter);
  if(DATE_FILTERS.month!==null&&DATE_FILTERS.month!==''&&DATE_FILTERS.month!==undefined){
    const mname=new Date(2000,parseInt(DATE_FILTERS.month),1).toLocaleString('en',{month:'long'});
    parts.push('Month: '+mname);
  }
  if(DATE_FILTERS.week) parts.push('Week: '+DATE_FILTERS.week);
  if(parts.length===0) parts.push('Period: All Time');
  if(SECTION_FILTERS[section]){
    FILTER_DEFS.forEach(fd=>{
      const vals=getChecked(section,fd.key);
      if(vals.length) parts.push(fd.label+': '+vals.join(', '));
    });
  }
  const tileLabelMap={'PendingDelivery':'Pending Delivery (du status)','PendingReturn':'Pending Return (order status)'};
  if(SEL_STATUS) parts.push('Status filter (tile): '+(tileLabelMap[SEL_STATUS]||SEL_STATUS));
  if(SEL_AGENT) parts.push('Agent filter (tile): '+SEL_AGENT);
  if(SEL_ACT_CHANNEL) parts.push('Activation channel (tile): '+SEL_ACT_CHANNEL);
  return parts;
}
async function exportPDF(section){
  if(!window.jspdf||!window.html2canvas){
    alert('PDF libraries are still loading. Please try again in a moment.');
    return;
  }
  const sectionEl=el('sec-'+section); if(!sectionEl){alert('Section not found');return;}
  // Find & disable the clicked PDF button while generating
  const btn=sectionEl.querySelector('.pdf-export-btn');
  const oldHtml=btn?btn.innerHTML:null;
  if(btn){btn.disabled=true;btn.innerHTML='Generating PDF...';}
  el('loadingOverlay').style.display='flex';
  set('loadingText','Generating PDF — this may take a few seconds...');
  try{
    const {jsPDF}=window.jspdf;
    const pdf=new jsPDF({orientation:'p',unit:'mm',format:'a4'});
    const pageW=pdf.internal.pageSize.getWidth();
    const pageH=pdf.internal.pageSize.getHeight();
    const margin=12;
    const contentW=pageW-margin*2;

    // ── HEADER BANNER ──
    pdf.setFillColor(37,99,235);
    pdf.rect(0,0,pageW,28,'F');
    pdf.setTextColor(255,255,255);
    pdf.setFontSize(17); pdf.setFont(undefined,'bold');
    pdf.text('DIP Dashboard — '+_sectionLabel(section),margin,13);
    pdf.setFontSize(10); pdf.setFont(undefined,'normal');
    pdf.text('Generated: '+new Date().toLocaleString('en-GB'),margin,21);
    if(USER&&USER.name) pdf.text('User: '+USER.name,pageW-margin-pdf.getTextWidth('User: '+USER.name),21);

    let y=36;
    pdf.setTextColor(15,26,62);

    // ── FILTERS APPLIED ──
    pdf.setFontSize(12); pdf.setFont(undefined,'bold');
    pdf.setTextColor(37,99,235);
    pdf.text('Filters Applied',margin,y); y+=2;
    pdf.setDrawColor(37,99,235); pdf.setLineWidth(0.4);
    pdf.line(margin,y,margin+contentW,y); y+=5;
    pdf.setFontSize(9.5); pdf.setFont(undefined,'normal');
    pdf.setTextColor(40,40,40);
    const filterParts=_getFiltersDescription(section);
    filterParts.forEach(f=>{
      const lines=pdf.splitTextToSize('• '+f,contentW-4);
      lines.forEach(line=>{
        if(y>pageH-15){pdf.addPage(); y=15;}
        pdf.text(line,margin+2,y); y+=4.8;
      });
    });
    y+=4;

    // ── COLLECT CAPTURE TARGETS ──
    const captureTargets=[];
    const stats=sectionEl.querySelector('.top-stats');
    if(stats&&stats.offsetHeight>5) captureTargets.push({el:stats,label:'Key Metrics'});
    const insights=sectionEl.querySelector('.insight-grid');
    if(insights&&insights.offsetHeight>5) captureTargets.push({el:insights,label:'Insights'});
    const agentGrid=sectionEl.querySelector('.agent-grid');
    if(agentGrid&&agentGrid.offsetHeight>5) captureTargets.push({el:agentGrid,label:'Agent Tiles'});
    const compGrid=sectionEl.querySelector('.comparison-grid');
    if(compGrid&&compGrid.offsetHeight>5) captureTargets.push({el:compGrid,label:'Period Comparison'});
    // All chart rows in order
    sectionEl.querySelectorAll('.charts-row').forEach(r=>{
      if(r.offsetHeight>5) captureTargets.push({el:r,label:null});
    });

    // Force charts to redraw so numbers (datalabels) are baked into canvases
    Object.values(CHARTS).forEach(c=>{ if(c&&typeof c.update==='function'){try{c.update('none');}catch(e){}} });
    // Brief wait so layout/labels stabilise
    await new Promise(r=>setTimeout(r,150));

    const bodyBg=getComputedStyle(document.body).backgroundColor;
    const captureBg=(bodyBg&&bodyBg!=='rgba(0, 0, 0, 0)')?bodyBg:'#ffffff';

    for(const item of captureTargets){
      try{
        const canvas=await html2canvas(item.el,{scale:1.7,useCORS:true,backgroundColor:captureBg,logging:false,allowTaint:true});
        const imgW=contentW;
        const imgH=(canvas.height/canvas.width)*imgW;
        // Section sub-header
        if(item.label){
          if(y>pageH-25){pdf.addPage(); y=15;}
          pdf.setFontSize(11); pdf.setFont(undefined,'bold');
          pdf.setTextColor(37,99,235);
          pdf.text(item.label,margin,y); y+=2;
          pdf.setDrawColor(200,210,235); pdf.setLineWidth(0.3);
          pdf.line(margin,y,margin+contentW,y); y+=5;
        }
        // Split image across pages when taller than remaining space
        if(imgH>pageH-y-10){
          const pxPerMm=canvas.width/imgW;
          let srcY=0; let remaining=canvas.height;
          while(remaining>0){
            if(pageH-y<40){pdf.addPage(); y=15;}
            const availMm=pageH-y-10;
            const availPx=availMm*pxPerMm;
            const chunkPx=Math.min(remaining,availPx);
            const chunkC=document.createElement('canvas');
            chunkC.width=canvas.width; chunkC.height=chunkPx;
            chunkC.getContext('2d').drawImage(canvas,0,srcY,canvas.width,chunkPx,0,0,canvas.width,chunkPx);
            const chunkMm=chunkPx/pxPerMm;
            pdf.addImage(chunkC.toDataURL('image/jpeg',0.92),'JPEG',margin,y,imgW,chunkMm);
            srcY+=chunkPx; remaining-=chunkPx; y+=chunkMm+4;
            if(remaining>0){pdf.addPage(); y=15;}
          }
        } else {
          if(y+imgH>pageH-10){pdf.addPage(); y=15;}
          pdf.addImage(canvas.toDataURL('image/jpeg',0.92),'JPEG',margin,y,imgW,imgH);
          y+=imgH+6;
        }
      } catch(err){ console.warn('Capture failed for',item.label,err); }
    }

    // ── FOOTER on each page ──
    const pages=pdf.internal.getNumberOfPages();
    for(let i=1;i<=pages;i++){
      pdf.setPage(i);
      pdf.setFontSize(8); pdf.setTextColor(120,120,120); pdf.setFont(undefined,'normal');
      pdf.text('DIP Dashboard · CLF SharePoint',margin,pageH-6);
      const pgText='Page '+i+' of '+pages;
      pdf.text(pgText,pageW-margin-pdf.getTextWidth(pgText),pageH-6);
    }

    pdf.save('DIP_'+section+'_'+new Date().toISOString().split('T')[0]+'.pdf');
  } catch(e){
    console.error('PDF export failed:',e);
    alert('PDF export failed: '+e.message);
  } finally {
    el('loadingOverlay').style.display='none';
    if(btn){btn.disabled=false;btn.innerHTML=oldHtml;}
  }
}

function exportData(section){
  const api=GRID_APIS[section]; const rows=[];
  if(api){
    api.forEachNodeAfterFilter(n=>{if(n.data) rows.push(n.data);});
  }
  const data=rows.length?rows:filterByPeriod(FILTERED);
  const cols=['activityNo','packageName','receiverName','receiverPhone','orderStatus','duStatus','agentName','salesChannel','accountType','dealerName','dealerId','orderRef','planName','wincashCode','failureReason','creationDate','deliveryDate','wincashDate','edaraPickupDate','edaraAgent','orderAssignedTo','comments'];
  const headers=['Activity #','Package Name','Receiver','Phone','Order Status','du Status','Agent','Sales Channel','Account Type','Dealer','Dealer ID','Order Ref','Plan Name','Wincash Code','Failure Reason','Creation Date','Delivery Date','Wincash Date','Edara Pickup','Edara Agent','Assigned To','Comments'];
  let html='<html><head><meta charset="utf-8"></head><body><table border="1" cellpadding="4" cellspacing="0">';
  html+='<tr>'+headers.map(h=>`<th style="background:#2563eb;color:white;font-weight:bold;padding:10px;">${h}</th>`).join('')+'</tr>';
  data.forEach((row,i)=>{
    const bg=i%2===0?'#f0f6ff':'#ffffff';
    html+='<tr>'+cols.map(c=>{let v=row[c]||'—';if(['creationDate','deliveryDate','wincashDate','edaraPickupDate'].includes(c))v=fmtDate(v);return `<td style="background:${bg};padding:8px;">${v}</td>`;}).join('')+'</tr>';
  });
  html+='</table></body></html>';
  const blob=new Blob([html],{type:'application/vnd.ms-excel'});
  const a=document.createElement('a');a.href=URL.createObjectURL(blob);
  a.download='DIP_Devices_'+new Date().toISOString().split('T')[0]+'.xls';a.click();
}

