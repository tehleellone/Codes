<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>DIP Dashboard</title>
<script src="https://cdnjs.cloudflare.com/ajax/libs/Chart.js/4.4.1/chart.umd.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/chartjs-plugin-datalabels@2.2.0/dist/chartjs-plugin-datalabels.min.js"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/html2canvas/1.4.1/html2canvas.min.js"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/jspdf/2.5.1/jspdf.umd.min.js"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/ag-grid/32.0.2/ag-grid-community.min.js"></script>
<link rel="stylesheet" href="https://unpkg.com/ag-grid-community@32.0.2/styles/ag-grid.css">
<link rel="stylesheet" href="https://unpkg.com/ag-grid-community@32.0.2/styles/ag-theme-alpine.css">
<style>
@import url('https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&display=swap');

:root {
  --bg-body: linear-gradient(145deg,#f0f6ff,#e8f4ff,#f0f0ff);
  --bg-card: #ffffff;
  --bg-header: rgba(255,255,255,0.97);
  --bg-sidebar: linear-gradient(180deg,#f0f6ff,#e8f0ff);
  --bg-content: #f0f4ff;
  --bg-input: rgba(37,99,235,0.06);
  --bg-secondary: rgba(37,99,235,0.05);
  --bg-hover: rgba(37,99,235,0.07);
  --border: rgba(37,99,235,0.18);
  --border-s: rgba(37,99,235,0.42);
  --t1: #0f1a3e;
  --t2: #3d4f8a;
  --t3: #7a8fc4;
  --acc: #2563eb;
  --acc2: #7c3aed;
  --glow: rgba(37,99,235,0.25);
  --grad: linear-gradient(135deg,#2563eb,#7c3aed);
  --nab: rgba(37,99,235,0.09);
  --nab2: rgba(37,99,235,0.32);
  --sc: #2563eb;
  --cs: 0 1px 8px rgba(37,99,235,0.10);
  --ch: 0 6px 20px rgba(37,99,235,0.18);
  --chip: rgba(37,99,235,0.08);
}
body[data-theme="dark"] {
  --bg-body: linear-gradient(145deg,#060c1f,#0c1535,#080e25);
  --bg-card: #0e1630;
  --bg-header: rgba(6,12,31,0.98);
  --bg-sidebar: linear-gradient(180deg,#101a38,#0c1430);
  --bg-content: #090f28;
  --bg-input: rgba(37,99,235,0.14);
  --bg-secondary: rgba(37,99,235,0.09);
  --bg-hover: rgba(37,99,235,0.13);
  --border: rgba(37,99,235,0.22);
  --border-s: rgba(37,99,235,0.5);
  --t1: #e2e8f0;
  --t2: #a5b4c8;
  --t3: #637899;
  --acc: #60a5fa;
  --acc2: #a78bfa;
  --glow: rgba(96,165,250,0.32);
  --grad: linear-gradient(135deg,#3b82f6,#8b5cf6);
  --nab: rgba(37,99,235,0.15);
  --nab2: rgba(37,99,235,0.45);
  --sc: #60a5fa;
  --cs: 0 2px 16px rgba(0,0,0,0.55);
  --ch: 0 6px 24px rgba(37,99,235,0.22);
  --chip: rgba(37,99,235,0.16);
}
body[data-theme="teal"] {
  --bg-body: linear-gradient(145deg,#f0fffe,#e6fffd,#f0f9ff);
  --bg-card: #ffffff;
  --bg-header: rgba(255,255,255,0.97);
  --bg-sidebar: linear-gradient(180deg,#f0fffe,#e6fffd);
  --bg-content: #f0fffe;
  --bg-input: rgba(13,148,136,0.06);
  --bg-secondary: rgba(13,148,136,0.05);
  --bg-hover: rgba(13,148,136,0.07);
  --border: rgba(13,148,136,0.18);
  --border-s: rgba(13,148,136,0.42);
  --t1: #0f2a2a;
  --t2: #1d6a6a;
  --t3: #5aafaf;
  --acc: #0d9488;
  --acc2: #0891b2;
  --glow: rgba(13,148,136,0.25);
  --grad: linear-gradient(135deg,#0d9488,#0891b2);
  --nab: rgba(13,148,136,0.09);
  --nab2: rgba(13,148,136,0.32);
  --sc: #0d9488;
  --cs: 0 1px 8px rgba(13,148,136,0.10);
  --ch: 0 6px 20px rgba(13,148,136,0.18);
  --chip: rgba(13,148,136,0.08);
}
body[data-theme="teal-dark"] {
  --bg-body: linear-gradient(145deg,#061515,#0a2020,#061818);
  --bg-card: #0a1e1e;
  --bg-header: rgba(6,15,15,0.98);
  --bg-sidebar: linear-gradient(180deg,#0c2222,#081a1a);
  --bg-content: #071616;
  --bg-input: rgba(13,148,136,0.14);
  --bg-secondary: rgba(13,148,136,0.09);
  --bg-hover: rgba(13,148,136,0.13);
  --border: rgba(13,148,136,0.22);
  --border-s: rgba(13,148,136,0.5);
  --t1: #ccfbf1;
  --t2: #5eead4;
  --t3: #2dd4bf;
  --acc: #2dd4bf;
  --acc2: #22d3ee;
  --glow: rgba(45,212,191,0.32);
  --grad: linear-gradient(135deg,#14b8a6,#06b6d4);
  --nab: rgba(13,148,136,0.15);
  --nab2: rgba(13,148,136,0.45);
  --sc: #2dd4bf;
  --cs: 0 2px 16px rgba(0,0,0,0.55);
  --ch: 0 6px 24px rgba(13,148,136,0.22);
  --chip: rgba(13,148,136,0.16);
}

*,*::before,*::after{margin:0;padding:0;box-sizing:border-box}
html{scroll-behavior:smooth}
body{font-family:'Inter',-apple-system,BlinkMacSystemFont,'Segoe UI',sans-serif;background:var(--bg-body);color:var(--t1);min-height:100vh;-webkit-font-smoothing:antialiased;transition:background .3s,color .3s;line-height:1.5;}
select,input,textarea,button{font-family:inherit}
h1,h2,h3,h4,h5,h6{margin:0!important;padding:0!important;font-weight:inherit}

/* PORTAL SHELL */
.portal-shell{max-width:1800px;margin:0 auto;min-height:100vh;display:flex;flex-direction:column;background:var(--bg-body)}
.header{background:var(--bg-header);border-bottom:1px solid var(--border);backdrop-filter:blur(16px);padding:0 1.25rem;height:56px;display:flex;align-items:center;justify-content:space-between;gap:1rem;position:sticky;top:0;z-index:200;flex-shrink:0}
.logo-section{display:flex;align-items:center;gap:.65rem;min-width:0}
.logo{width:36px;height:36px;border-radius:10px;background:var(--grad);display:flex;align-items:center;justify-content:center;box-shadow:0 0 14px var(--glow);flex-shrink:0}
.logo svg{width:20px;height:20px;stroke:#fff;fill:none;stroke-width:2}
.header-title{font-size:1.05rem;font-weight:800;white-space:nowrap;background:var(--grad);-webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text}
.header-center{display:flex;align-items:center;gap:.75rem;flex:1;justify-content:flex-start;padding-left:.75rem}
.header-actions{display:flex;align-items:center;gap:.5rem;flex-shrink:0}
.live-badge-pill{display:inline-flex;align-items:center;gap:.3rem;padding:.22rem .65rem;border-radius:20px;background:rgba(22,163,74,.12);border:1px solid rgba(22,163,74,.28);font-size:.73rem;font-weight:700;color:#16a34a;white-space:nowrap}
body[data-theme="dark"] .live-badge-pill,body[data-theme="teal-dark"] .live-badge-pill{background:rgba(34,197,94,.1);border-color:rgba(34,197,94,.25);color:#22c55e}
.status-dot{width:6px;height:6px;border-radius:50%;background:#16a34a;animation:pulseDot 2s infinite}
.date-badge{font-size:.75rem;color:var(--t3);display:flex;align-items:center;gap:.3rem;white-space:nowrap}
.color-scheme-selector{padding:.3rem .65rem;background:var(--bg-input);border:1px solid var(--border);border-radius:18px;color:var(--t1);font-size:.75rem;cursor:pointer;transition:border-color .2s}
.theme-toggle{width:34px;height:34px;border-radius:50%;background:var(--bg-input);border:1px solid var(--border);display:flex;align-items:center;justify-content:center;cursor:pointer;color:var(--t1);transition:all .2s}
.theme-toggle svg{width:16px;height:16px;stroke:currentColor;fill:none;stroke-width:2}

/* SIDEBAR */
.main-container{display:flex;flex:1;min-height:0;position:relative}
.sidebar{width:210px;min-width:210px;background:var(--bg-sidebar);border-right:1px solid var(--border);padding:1rem 0;overflow:visible;flex-shrink:0;transition:width .26s ease,min-width .26s ease,opacity .22s,padding .25s;position:relative}
.sidebar.collapsed{width:0;min-width:0;padding:0;border:none;overflow:visible!important}
.sidebar.collapsed .nav-items{opacity:0;pointer-events:none}
.sidebar.collapsed .sidebar-toggle-btn{right:-28px;background:var(--bg-card);box-shadow:var(--cs)}
.sidebar-toggle-btn{position:absolute;right:-14px;top:20px;z-index:300;width:28px;height:28px;border-radius:50%;background:var(--bg-card);border:1px solid var(--border);box-shadow:var(--cs);display:flex;align-items:center;justify-content:center;cursor:pointer;color:var(--t1);transition:all .2s}
.sidebar-toggle-btn svg{width:14px;height:14px;stroke:currentColor;fill:none;stroke-width:2}
.nav-items{display:flex;flex-direction:column;gap:2px;padding:0 .65rem}
.nav-section-label{font-size:.67rem;text-transform:uppercase;letter-spacing:.1em;color:var(--t3);padding:.75rem .6rem .3rem;white-space:nowrap;overflow:hidden}
.nav-item{display:flex;align-items:center;gap:.65rem;padding:.55rem .7rem;border-radius:9px;cursor:pointer;color:var(--t2);border:1px solid transparent;transition:all .17s;white-space:nowrap;overflow:hidden;font-size:.84rem;font-weight:500;user-select:none}
.nav-item .nav-icon{display:flex;align-items:center;flex-shrink:0;width:17px;height:17px}
.nav-item .nav-icon svg{width:17px;height:17px;stroke:currentColor;fill:none;stroke-width:2}
.nav-item:hover{background:var(--bg-hover);color:var(--t1)}
.nav-item.active{background:var(--nab);border-color:var(--nab2);color:var(--t1);font-weight:600}

/* CONTENT */
.content{flex:1;overflow-y:auto;min-width:0;background:var(--bg-content);padding:1.1rem 1.25rem}
.dashboard-section{animation:fadeIn .25s ease;padding:.5rem 0}
@keyframes fadeIn{from{opacity:0}to{opacity:1}}
@keyframes pulseDot{0%,100%{box-shadow:0 0 0 0 rgba(37,99,235,.4)}50%{box-shadow:0 0 0 5px rgba(37,99,235,0)}}

/* SECTION TITLE */
.section-title{font-size:1rem;font-weight:800;margin:.85rem 0 .65rem!important;display:flex;align-items:center;gap:.45rem;color:var(--acc)}
.section-title svg{width:20px;height:20px;stroke:currentColor;fill:none;stroke-width:2}

/* ── COMPACT FILTER BAR ── */
.filters-section{background:var(--bg-card);border:1px solid var(--border);border-radius:12px;padding:.75rem 1rem;margin-bottom:1rem;box-shadow:var(--cs)}
.filters-row{display:flex;flex-wrap:wrap;gap:.5rem;align-items:flex-end}
.filter-group{display:flex;flex-direction:column;gap:.2rem;min-width:0}
.filter-label{font-size:.63rem;font-weight:700;color:var(--t2);text-transform:uppercase;letter-spacing:.05em}

/* Native select — compact */
.f-select{padding:.34rem .55rem;border-radius:7px;border:1px solid var(--border);background:var(--bg-input);color:var(--t1);font-size:.78rem;cursor:pointer;transition:border-color .18s;min-width:100px;max-width:150px}
.f-select:focus{outline:none;border-color:var(--border-s)}

/* Date picker — same look as select */
.f-date{padding:.30rem .55rem;border-radius:7px;border:1px solid var(--border);background:var(--bg-input);color:var(--t1);font-size:.78rem;cursor:pointer;transition:border-color .18s;min-width:140px;max-width:170px;font-family:inherit}
.f-date:focus{outline:none;border-color:var(--border-s)}
.f-date::-webkit-calendar-picker-indicator{cursor:pointer;opacity:.7;filter:invert(0)}
body[data-theme="dark"] .f-date::-webkit-calendar-picker-indicator,body[data-theme="teal-dark"] .f-date::-webkit-calendar-picker-indicator{filter:invert(1)}

/* Page header row (title + PDF export) */
.page-header-row{display:flex;justify-content:space-between;align-items:center;gap:1rem;flex-wrap:wrap;margin:.85rem 0 .65rem}
.page-header-row .section-title{margin:0!important}
.pdf-export-btn{padding:.4rem .9rem;border-radius:8px;font-size:.78rem;font-weight:700;cursor:pointer;display:inline-flex;align-items:center;gap:.4rem;background:linear-gradient(135deg,#dc2626,#b91c1c);color:#fff;border:none;box-shadow:0 2px 10px rgba(220,38,38,.32);transition:all .2s;white-space:nowrap}
.pdf-export-btn:hover{transform:translateY(-1px);box-shadow:0 4px 16px rgba(220,38,38,.42)}
.pdf-export-btn:disabled{opacity:.6;cursor:not-allowed;transform:none}
.pdf-export-btn svg{width:14px;height:14px;stroke:#fff;fill:none;stroke-width:2}

/* Multi-select dropdown */
.ms-wrap{position:relative;z-index:auto}
.ms-trigger{padding:.34rem .55rem;border-radius:7px;border:1px solid var(--border);background:var(--bg-input);color:var(--t1);font-size:.78rem;cursor:pointer;display:flex;align-items:center;justify-content:space-between;gap:.35rem;transition:border-color .18s;user-select:none;min-width:110px;max-width:160px;white-space:nowrap}
.ms-trigger:hover,.ms-trigger.open{border-color:var(--border-s)}
.ms-trigger svg{width:12px;height:12px;stroke:var(--t3);fill:none;stroke-width:2;transition:transform .2s;flex-shrink:0}
.ms-trigger.open svg{transform:rotate(180deg)}
.ms-text{overflow:hidden;text-overflow:ellipsis;white-space:nowrap;max-width:110px}
.ms-dropdown{position:fixed;background:var(--bg-card);border:1px solid var(--border-s);border-radius:8px;max-height:240px;overflow-y:auto;z-index:99999;box-shadow:0 8px 32px rgba(0,0,0,.28);display:none;min-width:180px}
.ms-dropdown.open{display:block}
.ms-option{padding:7px 12px;display:flex;align-items:center;gap:9px;cursor:pointer;font-size:.8rem;transition:background .15s}
.ms-option:hover{background:var(--bg-hover)}
.ms-option input[type=checkbox]{width:13px;height:13px;cursor:pointer;accent-color:var(--acc);flex-shrink:0}
.ms-option label{cursor:pointer;flex:1;color:var(--t1);white-space:nowrap}

/* Filter actions */
.filter-actions-row{display:flex;gap:.5rem;align-items:center;margin-left:auto;flex-shrink:0}
.reset-btn{padding:.34rem .8rem;border-radius:7px;font-size:.76rem;font-weight:600;cursor:pointer;display:inline-flex;align-items:center;gap:.3rem;background:var(--bg-input);color:var(--t1);border:1px solid var(--border);transition:all .2s;white-space:nowrap}
.reset-btn:hover{border-color:var(--border-s)}
.reset-btn svg{width:13px;height:13px;stroke:currentColor;fill:none;stroke-width:2}
.export-btn{padding:.34rem .8rem;border-radius:7px;font-size:.76rem;font-weight:700;cursor:pointer;display:inline-flex;align-items:center;gap:.3rem;background:var(--grad);color:#fff;border:none;box-shadow:0 2px 8px var(--glow);transition:all .2s;white-space:nowrap}
.export-btn:hover{transform:translateY(-1px);box-shadow:0 4px 14px var(--glow)}
.export-btn svg{width:13px;height:13px;stroke:#fff;fill:none;stroke-width:2}

/* STAT CARDS */
.top-stats{display:grid;grid-template-columns:repeat(auto-fit,minmax(140px,1fr));gap:.75rem;margin-bottom:1rem}
.stat-card{background:var(--bg-card);border:1px solid var(--border);border-radius:12px;padding:.9rem 1rem;box-shadow:var(--cs);position:relative;overflow:hidden;transition:transform .18s,box-shadow .18s;cursor:pointer}
.stat-card::before{content:'';position:absolute;top:0;left:0;right:0;height:3px;background:var(--grad)}
.stat-card:hover{transform:translateY(-2px);box-shadow:var(--ch)}
.stat-card.active{box-shadow:0 0 0 2px var(--acc),var(--ch)!important;transform:translateY(-2px)}
.stat-card.dimmed{opacity:.38}
.s-label{font-size:.7rem;text-transform:uppercase;letter-spacing:.06em;color:var(--t3);font-weight:700;margin-bottom:.25rem}
.s-value{font-size:1.75rem;font-weight:900;line-height:1;margin-bottom:.15rem}
.s-sub{font-size:.72rem;font-weight:600;color:var(--t2)}

/* CHARTS */
.chart-card{background:var(--bg-card);border:1px solid var(--border);border-radius:12px;padding:1rem;box-shadow:var(--cs)}
.chart-title{font-size:.8rem;font-weight:700;color:var(--t2);margin-bottom:.65rem;display:flex;align-items:center;justify-content:space-between;gap:.35rem}
.chart-title-left{display:flex;align-items:center;gap:.35rem}
.chart-title svg{width:16px;height:16px;stroke:var(--acc);fill:none;stroke-width:2}
.chart-container{position:relative}
.charts-row{display:grid;gap:.85rem;margin-bottom:1rem}
.charts-2{grid-template-columns:1fr 1fr}
.charts-3{grid-template-columns:1fr 1fr 1fr}
.charts-1{grid-template-columns:1fr}
@media(max-width:900px){.charts-2,.charts-3{grid-template-columns:1fr}}

/* TOGGLE MINI */
.toggle-mini{display:flex;gap:.25rem}
.toggle-mini button{padding:.2rem .55rem;border-radius:6px;font-size:.68rem;font-weight:700;border:1px solid var(--border);cursor:pointer;background:var(--bg-secondary);color:var(--t3);transition:all .15s}
.toggle-mini button.active{background:var(--grad);border-color:transparent;color:#fff}

/* AGENT TILES */
.agent-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(200px,1fr));gap:.75rem;margin-bottom:1rem}
.agent-tile{background:var(--bg-card);border:1px solid var(--border);border-radius:12px;padding:.85rem 1rem;box-shadow:var(--cs);position:relative;overflow:hidden;transition:all .2s;cursor:pointer}
.agent-tile::before{content:'';position:absolute;top:0;left:0;right:0;height:3px;background:var(--grad)}
.agent-tile:hover{transform:translateY(-2px);box-shadow:var(--ch);border-color:var(--border-s)}
.agent-tile.selected{box-shadow:0 0 0 2px var(--acc),var(--ch)!important;transform:translateY(-2px)}
.agent-name{font-size:.86rem;font-weight:700;color:var(--t1);margin-bottom:.08rem}
.agent-meta{font-size:.67rem;color:var(--t3);margin-bottom:.5rem}
.agent-stats{display:grid;grid-template-columns:1fr 1fr;gap:.35rem}
.agent-stat-box{background:var(--bg-secondary);border-radius:7px;padding:.4rem .5rem;border:1px solid var(--border)}
.agent-stat-label{font-size:.6rem;text-transform:uppercase;color:var(--t3);font-weight:600;margin-bottom:.08rem}
.agent-stat-value{font-size:.95rem;font-weight:800}
.rank-badge{width:24px;height:24px;border-radius:50%;display:flex;align-items:center;justify-content:center;font-weight:900;font-size:.68rem;color:#fff;flex-shrink:0;position:absolute;top:9px;right:9px}
.rank-1{background:var(--grad)}
.rank-2{background:linear-gradient(135deg,#94a3b8,#64748b)}
.rank-3{background:linear-gradient(135deg,#c2853b,#d97706)}
.rank-other{background:var(--bg-secondary);color:var(--t3);border:1px solid var(--border)}
.progress-bar{background:var(--bg-secondary);border-radius:20px;height:4px;overflow:hidden;margin-top:.4rem}
.progress-fill{height:100%;border-radius:20px;background:var(--grad);transition:width .5s ease}

/* STATUS BADGES */
.badge{display:inline-block;padding:.17rem .5rem;border-radius:20px;font-size:.67rem;font-weight:700;text-transform:uppercase;letter-spacing:.04em}
.badge-success{background:rgba(22,163,74,.12);color:#16a34a;border:1px solid rgba(22,163,74,.28)}
.badge-warning{background:rgba(245,158,11,.12);color:#b45309;border:1px solid rgba(245,158,11,.28)}
.badge-danger{background:rgba(220,38,38,.12);color:#dc2626;border:1px solid rgba(220,38,38,.28)}
.badge-info{background:rgba(37,99,235,.12);color:#2563eb;border:1px solid rgba(37,99,235,.28)}
body[data-theme="dark"] .badge-success,body[data-theme="teal-dark"] .badge-success{background:rgba(34,197,94,.12);color:#22c55e;border-color:rgba(34,197,94,.25)}
body[data-theme="dark"] .badge-warning,body[data-theme="teal-dark"] .badge-warning{background:rgba(251,191,36,.12);color:#fbbf24;border-color:rgba(251,191,36,.25)}

/* TABLE */
.table-section{background:var(--bg-card);border:1px solid var(--border);border-radius:12px;padding:1rem 1.1rem;margin-bottom:1rem;box-shadow:var(--cs)}
.table-header{display:flex;justify-content:space-between;align-items:center;flex-wrap:wrap;gap:.65rem;margin-bottom:.75rem}
.table-title{font-size:.88rem;font-weight:800;color:var(--t1);display:flex;align-items:center;gap:.35rem}
.table-title svg{width:17px;height:17px;stroke:currentColor;fill:none;stroke-width:2}
.table-actions{display:flex;align-items:center;gap:.5rem;flex-wrap:wrap}
.search-box{padding:.38rem .7rem;border-radius:7px;border:1px solid var(--border);background:var(--bg-input);color:var(--t1);font-size:.79rem;min-width:170px;transition:border-color .18s}
.search-box:focus{outline:none;border-color:var(--border-s)}
.search-box::placeholder{color:var(--t3)}

/* AG GRID */
.ag-theme-alpine .ag-root-wrapper{background:var(--bg-card)!important;border-color:var(--border)!important;border-radius:10px!important;overflow:hidden!important}
.ag-theme-alpine .ag-header,.ag-theme-alpine .ag-header-row,.ag-theme-alpine .ag-header-viewport{background:var(--bg-secondary)!important;border-bottom:2px solid var(--border-s)!important}
.ag-theme-alpine .ag-header-cell{background:var(--bg-secondary)!important;color:var(--t1)!important;font-weight:700!important;font-size:.7rem!important;text-transform:uppercase!important;letter-spacing:.04em!important}
.ag-theme-alpine .ag-header-cell-text{color:var(--t1)!important;font-weight:700!important}
.ag-theme-alpine .ag-icon{color:var(--t3)!important}
.ag-theme-alpine .ag-body-viewport,.ag-theme-alpine .ag-center-cols-viewport{background:var(--bg-card)!important}
.ag-theme-alpine .ag-row{background:var(--bg-card)!important;color:var(--t1)!important;border-bottom-color:var(--border)!important}
.ag-theme-alpine .ag-row-odd{background:var(--bg-secondary)!important}
.ag-theme-alpine .ag-row-hover{background:var(--bg-hover)!important}
.ag-theme-alpine .ag-cell{color:var(--t1)!important}
.ag-theme-alpine .ag-paging-panel{background:var(--bg-card)!important;color:var(--t1)!important;border-top-color:var(--border)!important}

/* INSIGHT CARDS */
.insight-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(200px,1fr));gap:.75rem;margin-bottom:1rem}
.insight-card{background:var(--bg-card);border:1px solid var(--border);border-radius:12px;padding:.85rem 1rem;box-shadow:var(--cs);position:relative;overflow:hidden}
.insight-card::before{content:'';position:absolute;top:0;left:0;right:0;height:3px;background:var(--grad)}
.insight-icon{width:34px;height:34px;border-radius:8px;background:var(--nab);border:1px solid var(--nab2);display:flex;align-items:center;justify-content:center;margin-bottom:.55rem}
.insight-icon svg{width:18px;height:18px;stroke:var(--acc);fill:none;stroke-width:2}
.insight-label{font-size:.67rem;text-transform:uppercase;letter-spacing:.06em;color:var(--t3);font-weight:700;margin-bottom:.15rem}
.insight-value{font-size:1.5rem;font-weight:900;color:var(--sc);line-height:1;margin-bottom:.15rem}
.insight-sub{font-size:.72rem;color:var(--t2);font-weight:600}

/* COMPARISON */
.comparison-grid{display:grid;grid-template-columns:1fr 1fr;gap:.85rem;margin-bottom:1rem}
.comp-card{background:var(--bg-card);border:1px solid var(--border);border-radius:12px;padding:1rem;box-shadow:var(--cs)}
.comp-title{font-size:.82rem;font-weight:700;color:var(--t2);margin-bottom:.75rem;display:flex;align-items:center;gap:.35rem}
.comp-metric-row{display:flex;justify-content:space-between;align-items:center;padding:.38rem 0;border-bottom:1px solid var(--border)}
.comp-metric-row:last-child{border-bottom:none}
.comp-metric-label{font-size:.76rem;color:var(--t3);font-weight:600}
.comp-metric-val{font-size:.82rem;font-weight:800;color:var(--t1)}
.comp-delta{font-size:.7rem;font-weight:700;padding:.1rem .38rem;border-radius:10px}
.delta-up{background:rgba(22,163,74,.12);color:#16a34a}
.delta-down{background:rgba(220,38,38,.12);color:#dc2626}
.delta-flat{background:var(--bg-secondary);color:var(--t3)}

/* LOADING */
.loading-overlay{position:fixed;inset:0;background:var(--bg-body);display:flex;align-items:center;justify-content:center;z-index:9999;flex-direction:column;gap:1rem}
.spinner{width:38px;height:38px;border:3px solid var(--border);border-top-color:var(--acc);border-radius:50%;animation:spin 1s linear infinite}
@keyframes spin{to{transform:rotate(360deg)}}
.loading-text{font-size:.83rem;color:var(--t3);font-weight:600}

/* DEV CONSOLE */
.dev-console{position:fixed;bottom:12px;right:12px;z-index:9999;background:var(--bg-card);border:1px solid var(--border);border-radius:10px;padding:.65rem .9rem;display:flex;align-items:center;gap:.5rem;box-shadow:var(--cs);font-size:.75rem}
.dev-console input{padding:.3rem .6rem;border-radius:6px;border:1px solid var(--border);background:var(--bg-input);color:var(--t1);font-size:.75rem;width:200px}
.dev-console button{padding:.3rem .7rem;border-radius:6px;background:var(--grad);color:#fff;border:none;font-size:.74rem;font-weight:700;cursor:pointer}
.dev-console-label{font-size:.68rem;color:var(--t3);font-weight:600;text-transform:uppercase;letter-spacing:.04em}

@media(max-width:768px){.comparison-grid{grid-template-columns:1fr}}

/* ═══════ LANDING PAGE ═══════════════════════════════════════════════════ */
.landing-page{min-height:100vh;display:flex;flex-direction:row;background:var(--bg-body)}
.landing-left,.landing-right{flex:1;display:flex;align-items:center;justify-content:center;padding:2rem;min-width:0}
.landing-container{width:100%;max-width:420px}
.landing-card{background:var(--bg-card);border:1px solid var(--border);border-radius:16px;padding:1.4rem;box-shadow:var(--cs);margin-bottom:1rem}
.landing-header{text-align:center;margin-bottom:1.4rem}
.logo-icon{width:60px;height:60px;border-radius:15px;background:var(--grad);display:flex;align-items:center;justify-content:center;box-shadow:0 0 24px var(--glow);margin:0 auto}
.landing-title{font-size:1.4rem;font-weight:800;color:var(--t1);margin-bottom:.25rem!important}
.landing-subtitle{font-size:.82rem;color:var(--t3)}
.welcome-badge{display:inline-flex;align-items:center;gap:.35rem;padding:.25rem .7rem;border-radius:20px;background:var(--nab);border:1px solid var(--nab2);font-size:.75rem;font-weight:600;color:var(--acc);margin-bottom:.75rem}
.badge-pulse{width:6px;height:6px;border-radius:50%;background:var(--acc);animation:pulseDot 2s infinite;flex-shrink:0}
.landing-user-info{display:flex;align-items:center;gap:.8rem}
.avatar-placeholder{width:48px;height:48px;border-radius:50%;background:var(--grad);display:flex;align-items:center;justify-content:center;font-size:1rem;font-weight:800;color:#fff;flex-shrink:0}
.landing-details h3{font-size:.95rem;font-weight:700;color:var(--t1)}
.landing-details p{font-size:.77rem;color:var(--t3)}
.landing-role{display:inline-block;margin-top:.25rem;padding:.17rem .55rem;border-radius:5px;font-size:.7rem;font-weight:600;background:var(--chip);color:var(--acc);border:1px solid var(--border)}
.stats-grid{display:grid;grid-template-columns:1fr 1fr;gap:.55rem;margin:.9rem 0}
.landing-stat-card{background:var(--bg-secondary);border:1px solid var(--border);border-radius:10px;padding:.7rem;display:flex;gap:.55rem;align-items:center}
.stat-icon-bg{width:34px;height:34px;border-radius:7px;background:var(--nab);border:1px solid var(--nab2);display:flex;align-items:center;justify-content:center;flex-shrink:0}
.stat-label{font-size:.68rem;color:var(--t3);font-weight:600;text-transform:uppercase;letter-spacing:.04em}
.stat-value-sm{font-size:1rem;font-weight:800;color:var(--sc)}
.landing-btn{width:100%;padding:.72rem;border-radius:11px;font-size:.88rem;font-weight:700;cursor:pointer;border:none;transition:all .2s;display:flex;align-items:center;justify-content:center;gap:.45rem;margin-top:.5rem}
.btn-primary{background:var(--grad);color:#fff;box-shadow:0 3px 14px var(--glow)}
.btn-primary:hover{box-shadow:0 5px 20px var(--glow);transform:translateY(-1px)}
.landing-note{display:flex;align-items:flex-start;gap:.35rem;margin-top:.6rem;font-size:.74rem;color:var(--t3)}
.landing-footer{text-align:center;font-size:.72rem;color:var(--t3);margin-top:.4rem}
.landing-branding{max-width:420px}
.landing-brand-title{font-size:1.9rem;font-weight:900;color:var(--t1);margin:0!important}
.landing-brand-title span{background:var(--grad);-webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text}
.landing-brand-subtitle{font-size:.86rem;color:var(--t3);margin-top:.4rem}
.landing-features{margin-top:1.3rem;display:flex;flex-direction:column;gap:.7rem}
.landing-feature{display:flex;align-items:flex-start;gap:.65rem}
.landing-feature-icon{width:34px;height:34px;border-radius:9px;flex-shrink:0;background:var(--nab);border:1px solid var(--nab2);display:flex;align-items:center;justify-content:center}
.landing-feature-title{font-weight:700;font-size:.86rem;color:var(--t1)}
.landing-feature-desc{font-size:.76rem;color:var(--t3);margin-top:.12rem}
@keyframes slideUp{from{opacity:0;transform:translateY(24px)}to{opacity:1;transform:translateY(0)}}
@media(max-width:768px){.landing-page{flex-direction:column!important}}
</style>
</head>
<body>

<!-- LANDING PAGE -->
<div id="landingPage" class="landing-page" style="display:none;">
  <div class="landing-left" style="animation:fadeIn .55s ease forwards">
    <div class="landing-branding">
