function renderTopStats(data){
  const container=el('topStats'); if(!container) return;
  container.innerHTML='';
  const total=data.length;
  const delivered=data.filter(d=>d.orderStatus==='Delivered').length;
  const returned=data.filter(d=>['Returned','Pending Return','Return Confirmed'].includes(d.orderStatus)).length;
  const cancelled=data.filter(d=>d.orderStatus==='Cancelled').length;
  // Pending Delivery — du_x0020_status (duStatus); Pending Return — Order_x0020_Status (orderStatus)
  const isPendingDelivery=s=>{const v=String(s||'').toLowerCase().trim();return v&&v.includes('pending')&&!v.includes('return')&&!v.includes('cancel');};
  const pendingDelivery=data.filter(d=>isPendingDelivery(d.duStatus)).length;
  const pendingReturn=data.filter(d=>d.orderStatus==='Pending Return').length;
  const tiles=[
    {label:'Total Orders',value:total,sub:'All records in period',color:'var(--sc)',key:null},
    {label:'Delivered',value:delivered,sub:(total?(delivered/total*100).toFixed(1):0)+'% delivery rate',color:'#16a34a',key:'Delivered'},
    {label:'Pending Delivery',value:pendingDelivery,sub:'From du status',color:'#f59e0b',key:'PendingDelivery'},
    {label:'Returned',value:returned,sub:(total?(returned/total*100).toFixed(1):0)+'% return rate',color:'#dc2626',key:'Returned'},
    {label:'Pending Return',value:pendingReturn,sub:'Order status',color:'#f97316',key:'PendingReturn'},
    {label:'Cancelled',value:cancelled,sub:'Cancelled orders',color:'#6b7280',key:'Cancelled'},
  ];
  tiles.forEach(t=>{
    const active=SEL_STATUS===t.key&&t.key;
    const dimmed=SEL_STATUS&&!active&&t.key;
    const card=document.createElement('div');
    card.className='stat-card'+(active?' active':'')+(dimmed?' dimmed':'');
    card.innerHTML=`<div class="s-label">${t.label}</div><div class="s-value" style="color:${t.color}">${t.value}</div><div class="s-sub">${t.sub}</div>`;
    if(t.key) card.onclick=()=>{SEL_STATUS=SEL_STATUS===t.key?null:t.key;applyAll();};
    container.appendChild(card);
  });
}

function renderInsights(data){
  const container=el('insightGrid'); if(!container) return;
  container.innerHTML='';
  const agents=[...new Set(data.map(d=>d.agentName).filter(v=>v&&v!=='—'))];
  const channels=[...new Set(data.map(d=>d.salesChannel).filter(v=>v&&v!=='—'))];
  const topChannel=channels.reduce((best,ch)=>{const c=data.filter(d=>d.salesChannel===ch).length;return c>best.c?{ch,c}:best;},{ch:'—',c:0});
  const topAgent=agents.reduce((best,ag)=>{const c=data.filter(d=>d.agentName===ag).length;return c>best.c?{ag,c}:best;},{ag:'—',c:0});
  const avgDelivery=(()=>{const pairs=data.filter(d=>d.creationDate&&d.deliveryDate);if(!pairs.length)return '—';const avg=pairs.reduce((s,d)=>(new Date(d.deliveryDate)-new Date(d.creationDate))/(864e5)+s,0)/pairs.length;return avg.toFixed(1)+' days';})();
  const wincashCount=data.filter(d=>d.wincashCode&&d.wincashCode!=='—').length;
  const insights=[
    {icon:'<svg viewBox="0 0 24 24"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/></svg>',label:'Active Agents',value:agents.length,sub:'In this period'},
    {icon:'<svg viewBox="0 0 24 24"><path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/></svg>',label:'Top Channel',value:topChannel.ch,sub:topChannel.c+' orders'},
    {icon:'<svg viewBox="0 0 24 24"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>',label:'Top Agent',value:topAgent.ag.split(' ')[0],sub:topAgent.c+' deliveries'},
    {icon:'<svg viewBox="0 0 24 24"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>',label:'Avg Delivery Time',value:avgDelivery,sub:'Creation → Delivery'},
    {icon:'<svg viewBox="0 0 24 24"><rect x="2" y="3" width="20" height="14" rx="2"/><path d="M8 21h8"/><path d="M12 17v4"/></svg>',label:'Wincash Codes',value:wincashCount,sub:'Orders with code'},
    {icon:'<svg viewBox="0 0 24 24"><circle cx="12" cy="12" r="10"/><path d="M9 9l6 6"/><path d="M15 9l-6 6"/></svg>',label:'Unique Dealers',value:[...new Set(data.map(d=>d.dealerId).filter(v=>v&&v!=='—'))].length,sub:'Dealer IDs'},
  ];
  insights.forEach(ins=>{
    const card=document.createElement('div'); card.className='insight-card';
