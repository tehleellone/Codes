// Per-chart-type datalabel option builders. fmt() skips zero values.
function _dlText(){
  const t=document.body.getAttribute('data-theme')||'';
  return (t==='dark'||t==='teal-dark')?'#e2e8f0':'#0f1a3e';
}
function dlBar(){
  return {
    color:_dlText(),
    font:{weight:'700',size:10},
    anchor:'end',align:'end',offset:2,clamp:true,
    formatter:v=>(typeof v==='number'&&v>0)?(Number.isInteger(v)?v:v.toFixed(1)):''
  };
}
function dlBarStacked(){
  return {
    color:'#fff',
    font:{weight:'700',size:9},
    anchor:'center',align:'center',clamp:true,
    textShadowBlur:3,textShadowColor:'rgba(0,0,0,.55)',
    formatter:v=>(typeof v==='number'&&v>0)?v:''
  };
}
function dlHBar(){
  return {
    color:_dlText(),
    font:{weight:'700',size:10},
    anchor:'end',align:'end',offset:4,clamp:true,
    formatter:v=>(typeof v==='number'&&v>0)?v:''
  };
}
function dlDoughnut(){
  return {
    color:'#fff',
    font:{weight:'800',size:11},
    anchor:'center',align:'center',
    textShadowBlur:4,textShadowColor:'rgba(0,0,0,.65)',
    formatter:(v,ctx)=>{
      if(typeof v!=='number'||v<=0) return '';
      const total=ctx.dataset.data.reduce((a,b)=>a+(typeof b==='number'?b:0),0);
      const pct=total?(v/total*100):0;
      // Hide tiny slices to avoid clutter
      if(pct<3) return '';
      return v;
    }
  };
}
function dlLine(){
  const isDark=(document.body.getAttribute('data-theme')||'').includes('dark');
  return {
    color:_dlText(),
    font:{weight:'700',size:9},
    anchor:'end',align:'top',offset:6,clamp:true,
    backgroundColor:isDark?'rgba(14,22,48,.7)':'rgba(255,255,255,.85)',
    borderRadius:3,padding:{top:1,bottom:1,left:3,right:3},
    formatter:v=>(typeof v==='number'&&v>0)?(Number.isInteger(v)?v:v.toFixed(1)):''
  };
}
function dlLinePct(){
  return {
    color:'#f59e0b',
    font:{weight:'800',size:9},
    anchor:'end',align:'top',offset:6,
    formatter:v=>(typeof v==='number'&&v>0)?v+'%':''
  };
}
function destroyChart(k){ if(CHARTS[k]){ try{CHARTS[k].destroy();}catch(e){} CHARTS[k]=null; } }
function getChartColors(){
  const t=document.body.getAttribute('data-theme')||'';
  const isDark=t==='dark'||t==='teal-dark';
  const isTeal=t==='teal'||t==='teal-dark';
  return {
    text:isDark?'rgba(255,255,255,0.6)':'rgba(0,0,0,0.5)',
    grid:isDark?'rgba(255,255,255,0.07)':'rgba(0,0,0,0.06)',
    p1:isTeal?'#0d9488':'#2563eb', p2:isTeal?'#0891b2':'#7c3aed',
    p1a:isTeal?'rgba(13,148,136,':'rgba(37,99,235,',
  };
}
function getBuckets(period,count){
  const now=new Date(); const buckets=[];
  for(let i=count-1;i>=0;i--){
    let label,key;
    if(period==='D'){const d=new Date(now);d.setDate(d.getDate()-i);key=d.toISOString().split('T')[0];label=d.toLocaleDateString('en-GB',{day:'2-digit',month:'short'});}
    else if(period==='W'){const d=new Date(now);d.setDate(d.getDate()-i*7);key=d.getFullYear()+'-W'+String(getWeekOfYear(d)).padStart(2,'0');label='W'+getWeekOfYear(d);}
    else if(period==='M'){const d=new Date(now.getFullYear(),now.getMonth()-i,1);key=d.getFullYear()+'-'+String(d.getMonth()+1).padStart(2,'0');label=d.toLocaleDateString('en-US',{month:'short',year:'2-digit'});}
    else if(period==='Q'){const totalQ=now.getFullYear()*4+Math.floor(now.getMonth()/3)-i;const yr=Math.floor(totalQ/4);const q=(totalQ%4)+1;key=yr+'-Q'+q;label='Q'+q+' '+String(yr).slice(2);}
    else{const yr=now.getFullYear()-i;key=String(yr);label=String(yr);}
    buckets.push({key,label});
  }
  return buckets;
}
function getBucketKey(date,period){
  const d=new Date(date);
  if(period==='D') return d.toISOString().split('T')[0];
  if(period==='W') return d.getFullYear()+'-W'+String(getWeekOfYear(d)).padStart(2,'0');
  if(period==='M') return d.getFullYear()+'-'+String(d.getMonth()+1).padStart(2,'0');
  if(period==='Q') return d.getFullYear()+'-Q'+(Math.floor(d.getMonth()/3)+1);
  return String(d.getFullYear());
}
function buildPeriodToggle(wrapperId,currentVal,cbName,options){
  const wrap=el(wrapperId); if(!wrap) return;
  wrap.innerHTML=options.map(o=>`<button type="button" onclick="${cbName}('${o.k}')" class="${currentVal===o.k?'active':''}">${o.l}</button>`).join('');
}

