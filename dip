function setCompMode(mode,btn){
  CUR_COMP_MODE=mode;
  document.querySelectorAll('#sec-comparison .toggle-mini button').forEach(b=>b.classList.remove('active'));
  btn.classList.add('active');
  renderComparison();
}
function renderComparison(){
  const now=new Date();
  let curStart,curEnd,prevStart,prevEnd,curLabel,prevLabel;
  if(CUR_COMP_MODE==='qoq'){
    const q=Math.floor(now.getMonth()/3);
    curStart=new Date(now.getFullYear(),q*3,1);curEnd=new Date(now.getFullYear(),(q+1)*3,0);
    const pq=q===0?3:q-1;const pyr=q===0?now.getFullYear()-1:now.getFullYear();
    prevStart=new Date(pyr,pq*3,1);prevEnd=new Date(pyr,(pq+1)*3,0);
    curLabel='Q'+(q+1)+' '+now.getFullYear();prevLabel='Q'+(pq+1)+' '+pyr;
  }else if(CUR_COMP_MODE==='yoy'){
    curStart=new Date(now.getFullYear(),0,1);curEnd=new Date(now.getFullYear(),11,31);
    prevStart=new Date(now.getFullYear()-1,0,1);prevEnd=new Date(now.getFullYear()-1,11,31);
    curLabel=String(now.getFullYear());prevLabel=String(now.getFullYear()-1);
  }else{
    const m=now.getMonth();curStart=new Date(now.getFullYear(),m,1);curEnd=new Date(now.getFullYear(),m+1,0);
    const pm=m===0?11:m-1;const pyr=m===0?now.getFullYear()-1:now.getFullYear();
    prevStart=new Date(pyr,pm,1);prevEnd=new Date(pyr,pm+1,0);
    curLabel=now.toLocaleDateString('en-US',{month:'long',year:'numeric'});prevLabel=new Date(pyr,pm,1).toLocaleDateString('en-US',{month:'long',year:'numeric'});
  }
  const curData=ALL_DATA.filter(d=>{const rd=getRefDate(d);if(!rd)return false;const dt=new Date(rd);return dt>=curStart&&dt<=curEnd;});
  const prevData=ALL_DATA.filter(d=>{const rd=getRefDate(d);if(!rd)return false;const dt=new Date(rd);return dt>=prevStart&&dt<=prevEnd;});
  const compGrid=el('compGrid'); if(!compGrid) return;
  compGrid.innerHTML='';
  const metrics=[
    {label:'Total Orders',curVal:curData.length,prevVal:prevData.length},
    {label:'Delivered',curVal:curData.filter(d=>d.orderStatus==='Delivered').length,prevVal:prevData.filter(d=>d.orderStatus==='Delivered').length},
    {label:'Returned',curVal:curData.filter(d=>['Returned','Pending Return','Return Confirmed'].includes(d.orderStatus)).length,prevVal:prevData.filter(d=>['Returned','Pending Return','Return Confirmed'].includes(d.orderStatus)).length},
    {label:'Cancelled',curVal:curData.filter(d=>d.orderStatus==='Cancelled').length,prevVal:prevData.filter(d=>d.orderStatus==='Cancelled').length},
    {label:'Consumer',curVal:curData.filter(d=>d.salesChannel==='Consumer').length,prevVal:prevData.filter(d=>d.salesChannel==='Consumer').length},
    {label:'Enterprise',curVal:curData.filter(d=>d.salesChannel==='Enterprise').length,prevVal:prevData.filter(d=>d.salesChannel==='Enterprise').length},
  ];
  [
    {title:curLabel+' — Current Period',data:metrics,isCurrent:true},
    {title:prevLabel+' — Previous Period',data:metrics,isCurrent:false}
  ].forEach(({title,data:mets,isCurrent})=>{
    const card=document.createElement('div'); card.className='comp-card';
    card.innerHTML=`<div class="comp-title"><svg style="width:16px;height:16px;stroke:var(--acc);fill:none;stroke-width:2" viewBox="0 0 24 24"><line x1="18" y1="20" x2="18" y2="10"/><line x1="12" y1="20" x2="12" y2="4"/><line x1="6" y1="20" x2="6" y2="14"/></svg>${title}</div>`+
      mets.map(m=>{
        const val=isCurrent?m.curVal:m.prevVal;
        const delta=m.curVal-m.prevVal; const pct=m.prevVal?Math.abs(delta/m.prevVal*100).toFixed(1):null;
        const dc=delta>0?'delta-up':delta<0?'delta-down':'delta-flat';
        const ds=delta>0?'▲':delta<0?'▼':'—';
        return `<div class="comp-metric-row"><span class="comp-metric-label">${m.label}</span><div style="display:flex;align-items:center;gap:.4rem"><span class="comp-metric-val">${val}</span>${isCurrent&&pct?`<span class="comp-delta ${dc}">${ds} ${pct}%</span>`:''}</div></div>`;
      }).join('');
    compGrid.appendChild(card);
  });
  renderCompCharts(curData,prevData,curLabel,prevLabel);
}

