// ── LOAD DATA ────────────────────────────────────────────────────
function loadData(onComplete) {
  setLoadingStep('Fetching project records...');
  const select = [
    'Id',
    F.BID, F.CUST_NAME, F.PROJ_NAME, F.STATUS, F.START, F.CLOSURE_BL,
    F.EXP_DELIVERY, F.FORECAST, F.CANCELLED, F.BILLING_START,
    F.MULTI_SVC, F.FNE_INVOLVE, F.FNE_SCOPE, F.FES,
    F.FNE_GO_AHEAD, F.EXP_RFS, F.ACTUAL_RFS, F.RFS_DELAY,
    F.ACC_MGR, F.SALES_DIR, F.VERTICAL, F.UPDATES, F.WO,
    F.CONTRACT_DUR, F.OTC, F.MRC, F.CONTRACT_ID, F.ACC_NUM,
    F.PROD_TYPE, F.TCV, F.BILLED_REV, F.EXP_REV, F.DESCRIPTION,
    F.SPI, F.PROJ_HEALTH, F.PROJ_SIZE, F.PROJ_TYPE,
    F.PLANNED_DUR, F.ACTUAL_DUR, F.SOL_CONSULT, F.SVC_DELAY,
    F.PROJ_MGR+'/Title', F.PROJ_MGR+'/EMail',
  ].join(',');

  let all = [];
  function fetchPage(url) {
    spGet(url, function(err, data) {
      if(err) {
        console.error('[PM] Data load error:', err);
        ALL_ITEMS = [];
        buildFilterDropdowns();
        applyAll();
        if(onComplete) onComplete();
        return;
      }
      all = all.concat(data.d.results);
      setLoadingStep('Loaded '+all.length+' records...');
      if(data.d.__next) { fetchPage(data.d.__next); return; }
      console.log('[PM] Loaded:', all.length, 'records');
      ALL_ITEMS = all.map(mapItem);
      buildFilterDropdowns();
      applyAll();
      if(onComplete) onComplete();
    });
  }

  const url = SP_SITE+"/_api/web/lists/getbytitle('"+encodeURIComponent(SP_LIST)+"')/items" +
    "?$select="+encodeURIComponent(select)+
    "&$expand="+encodeURIComponent(F.PROJ_MGR)+
    "&$top=5000&$orderby=Id asc";
  fetchPage(url);
}

