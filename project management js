// ── KPI TILES ────────────────────────────────────────────────────
function renderKPIs() {
  const container = el('kpiGrid'); if(!container) return;
  container.innerHTML = '';
  const base = getViewItems();
  const total    = base.length;
  const comp     = base.filter(i=>STATUS_COMPLETED(i.status));
  const inprog   = base.filter(i=>STATUS_INPROGRESS(i.status));
  const onhold   = base.filter(i=>STATUS_ONHOLD(i.status));
  const cancel   = base.filter(i=>STATUS_CANCELLED(i.status));
  const totalTCV = base.reduce((s,i)=>s+i.tcv,0);
  const totalMRC = base.reduce((s,i)=>s+i.mrc,0);
  const totalOTC = base.reduce((s,i)=>s+i.otc,0);
  const billedRev= base.reduce((s,i)=>s+i.billedRev,0);
  const expRev   = base.reduce((s,i)=>s+i.expRev,0);
  const avgSPI   = total ? base.reduce((s,i)=>s+i.spi,0)/total : 0;
  const pct = x => total ? ((x/total)*100).toFixed(1)+'%' : '0%';

  const tiles = [
    { label:'Total Projects', value:total, sub:'All records', color:'var(--acc)', extras:[{l:'Completed',v:comp.length},{l:'In Progress',v:inprog.length}], click:null },
    { label:'Completed', value:pct(comp.length), sub:comp.length+' projects', color:'#16a34a', extras:[{l:'TCV',v:fmt(comp.reduce((s,i)=>s+i.tcv,0))},{l:'MRC',v:fmt(comp.reduce((s,i)=>s+i.mrc,0))}], click:'Completed' },
    { label:'In Progress', value:pct(inprog.length), sub:inprog.length+' active', color:'var(--acc)', extras:[{l:'TCV',v:fmt(inprog.reduce((s,i)=>s+i.tcv,0))}], click:'InProgress' },
    { label:'On Hold', value:pct(onhold.length), sub:onhold.length+' on hold', color:'#d97706', extras:[{l:'TCV',v:fmt(onhold.reduce((s,i)=>s+i.tcv,0))}], click:'OnHold' },
    { label:'Cancelled', value:pct(cancel.length), sub:cancel.length+' cancelled', color:'#dc2626', extras:[{l:'TCV',v:fmt(cancel.reduce((s,i)=>s+i.tcv,0))}], click:'Cancelled' },
    { label:'Total TCV', value:fmt(totalTCV), sub:'Contract value', color:'var(--acc)', extras:[{l:'MRC',v:fmt(totalMRC)},{l:'OTC',v:fmt(totalOTC)}], click:null },
    { label:'Billed Rev (YTD)', value:fmt(billedRev), sub:'Revenue collected', color:'#16a34a', extras:[{l:'Expected YTG',v:fmt(expRev)}], click:null },
    { label:'Avg SPI', value:avgSPI.toFixed(2), sub:'Schedule performance', color:avgSPI>=1?'#16a34a':avgSPI>=0.8?'#d97706':'#dc2626', extras:[{l:'Green health',v:base.filter(i=>i.health==='Green').length}], click:null },
  ];

  tiles.forEach(td => {
    const isActive = selStatusTile && selStatusTile===td.click;
    const isDimmed = selStatusTile && td.click && !isActive;
    const card = document.createElement('div');
    card.className = 'kpi-card'+(td.click?' clickable':'')+(isActive?' tile-active':'')+(isDimmed?' tile-dimmed':'');
    card.innerHTML = `<div class="kpi-label">${td.label}</div><div class="kpi-value" style="color:${td.color}">${td.value}</div><div class="kpi-sub">${td.sub}</div>${td.extras.length?'<div class="kpi-extras">'+td.extras.map(e=>`<div class="kpi-row"><span>${e.l}</span><span>${e.v}</span></div>`).join('')+'</div>':''}`;
