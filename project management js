function renderPipelineView() {
  const data = FILTERED.filter(i=>!STATUS_COMPLETED(i.status)&&!STATUS_CANCELLED(i.status));
  set('pipelineCount', data.length+' active projects');
  // Summary
  const strip = el('pipelineSummary'); if(strip) {
    const tcv=data.reduce((s,i)=>s+i.tcv,0), mrc=data.reduce((s,i)=>s+i.mrc,0);
    const avgSPI=data.length?data.reduce((s,i)=>s+i.spi,0)/data.length:0;
    const overdue=data.filter(i=>i.expDelivery&&new Date(i.expDelivery)<new Date()).length;
    strip.innerHTML=[
      {l:'Active Projects',v:data.length,c:'var(--acc)'},
      {l:'Total TCV',v:fmt(tcv),c:'var(--acc)'},
      {l:'Total MRC',v:fmt(mrc),c:'#16a34a'},
      {l:'Avg SPI',v:avgSPI.toFixed(2),c:avgSPI>=1?'#16a34a':avgSPI>=0.8?'#d97706':'#dc2626'},
      {l:'Overdue Delivery',v:overdue,c:overdue>0?'#dc2626':'#16a34a'},
