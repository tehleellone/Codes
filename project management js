function getWeekBucket(d) { return d.getFullYear()+'-W'+String(getWeekOfYear(d)).padStart(2,'0'); }
function getMonthBucket(d) { return d.getFullYear()+'-'+String(d.getMonth()+1).padStart(2,'0'); }
function getQBucket(d) { return d.getFullYear()+'-Q'+Math.ceil((d.getMonth()+1)/3); }
function getYearBucket(d) { return String(d.getFullYear()); }

function bucketByPeriod(d, period) {
  if(period==='W') return getWeekBucket(d);
  if(period==='M') return getMonthBucket(d);
  if(period==='Q') return getQBucket(d);
  return getYearBucket(d);
}

function buildTimeBuckets(period, count) {
  const now = new Date();
  const labels = [], buckets = [];
  for(let i=count-1;i>=0;i--) {
    let label, bucket;
    if(period==='W') {
      const d=new Date(now); d.setDate(d.getDate()-i*7);
      bucket=getWeekBucket(d); label='W'+getWeekOfYear(d);
    } else if(period==='M') {
      const d=new Date(now.getFullYear(),now.getMonth()-i,1);
      bucket=getMonthBucket(d); label=d.toLocaleDateString('en-US',{month:'short',year:'2-digit'});
    } else if(period==='Q') {
      const tq=now.getFullYear()*4+Math.ceil((now.getMonth()+1)/3)-1-i;
      const yr=Math.floor(tq/4); const q=(tq%4)+1;
      bucket=yr+'-Q'+q; label='Q'+q+' '+String(yr).slice(2);
    } else {
      bucket=String(now.getFullYear()-i); label=bucket;
    }
    labels.push(label); buckets.push(bucket);
  }
  return {labels,buckets};
}

