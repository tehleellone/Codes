// ── FILTER BAR ───────────────────────────────────────────────────
function buildFilterBar() {
  const grid = el('filterGrid'); if(!grid) return;
  grid.innerHTML = '';
  Object.entries(MS_CFG).forEach(([key, cfg]) => {
    const g = document.createElement('div'); g.className = 'fb-group';
    g.innerHTML = `
      <div class="fb-label">${cfg.label}</div>
      <div class="ms-wrap" id="ms-${key}">
        <div class="ms-trigger" id="mst-${key}" onclick="toggleMs('${key}')">
          <span id="mstxt-${key}">All</span>
          <svg viewBox="0 0 24 24"><polyline points="6 9 12 15 18 9"/></svg>
        </div>
        <div class="ms-dropdown" id="msd-${key}"></div>
      </div>`;
    grid.appendChild(g);
  });
}

function buildFilterDropdowns() {
  Object.entries(MS_CFG).forEach(([key, cfg]) => {
    const vals = [...new Set(ALL_ITEMS.map(i=>i[cfg.field]).filter(v=>v&&v!=='—'&&v!==null))].sort((a,b)=>{
      if(key==='year') return n(a)-n(b);
      return String(a).localeCompare(String(b));
    });
    const drop = el('msd-'+key); if(!drop) return;
    drop.innerHTML = '';
    vals.forEach(v => {
      const opt = document.createElement('div'); opt.className = 'ms-option';
      const cid = 'cb_'+key+'_'+String(v).replace(/\W/g,'_');
      opt.innerHTML = `<input type="checkbox" id="${cid}" value="${v}" onchange="onMsChange('${key}',this)"><label for="${cid}">${v}</label>`;
      drop.appendChild(opt);
    });
  });
}

function onMsChange(key, cb) {
  if(cb.checked) MS[key].add(cb.value);
  else MS[key].delete(cb.value);
  updateMsLabel(key);
  applyAll();
}

function updateMsLabel(key) {
  const sel = MS[key];
  const trig = el('mst-'+key);
  const txt = el('mstxt-'+key);
  if(!sel.size){ txt.textContent='All'; trig.classList.remove('has-sel'); }
  else if(sel.size===1){ txt.textContent=[...sel][0]; trig.classList.add('has-sel'); }
  else{ txt.textContent=sel.size+' selected'; trig.classList.add('has-sel'); }
}

function toggleMs(key) {
  const drop = el('msd-'+key), trig = el('mst-'+key);
  const isOpen = drop.classList.contains('open');
  document.querySelectorAll('.ms-dropdown.open').forEach(d=>d.classList.remove('open'));
  document.querySelectorAll('.ms-trigger.open').forEach(t=>t.classList.remove('open'));
  if(!isOpen) {
    const rect = trig.getBoundingClientRect();
    drop.style.top = (rect.bottom+4)+'px';
    drop.style.left = rect.left+'px';
    drop.style.width = Math.max(rect.width,190)+'px';
    drop.classList.add('open'); trig.classList.add('open');
  }
}

document.addEventListener('click', function(e) {
  if(!e.target.closest('.ms-wrap')) {
    document.querySelectorAll('.ms-dropdown.open').forEach(d=>d.classList.remove('open'));
    document.querySelectorAll('.ms-trigger.open').forEach(t=>t.classList.remove('open'));
  }
});

// ── APPLY ALL ────────────────────────────────────────────────────
function applyAll() {
  FILTERED = ALL_ITEMS.filter(item => {
    for(const [key, cfg] of Object.entries(MS_CFG)) {
      const sel = MS[key];
      if(!sel.size) continue;
      if(!sel.has(item[cfg.field]) && !sel.has(String(item[cfg.field]))) return false;
    }
    if(selStatusTile) {
      if(selStatusTile==='Completed' && !STATUS_COMPLETED(item.status)) return false;
      if(selStatusTile==='InProgress' && !STATUS_INPROGRESS(item.status)) return false;
      if(selStatusTile==='OnHold' && !STATUS_ONHOLD(item.status)) return false;
      if(selStatusTile==='Cancelled' && !STATUS_CANCELLED(item.status)) return false;
    }
    return true;
  });
  renderKPIs();
  renderHealthTiles();
  renderPMTiles();
  renderCharts();
  renderMainGrid();
  renderChips();
  updateSelBadge();
}

function getViewItems() {
