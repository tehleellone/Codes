function toggleSidebar(){
  const sb=el('sidebar'); sb.classList.toggle('collapsed');
  const col=sb.classList.contains('collapsed');
  el('sidebarIcon').innerHTML=col?'<polyline points="9 18 15 12 9 6"/><polyline points="15 18 21 12 15 6"/>':'<polyline points="15 18 9 12 15 6"/><polyline points="9 18 3 12 9 6"/>';
}
function applyTheme(base, dark) {
  const suffix = dark?'-dark':'';
  if(base==='blue'&&!dark) document.body.removeAttribute('data-theme');
  else document.body.setAttribute('data-theme', base+suffix);
  const icon=el('themeIcon');
  if(icon) icon.innerHTML=dark?'<path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/>':'<circle cx="12" cy="12" r="5"/><line x1="12" y1="1" x2="12" y2="3"/><line x1="12" y1="21" x2="12" y2="23"/><line x1="4.22" y1="4.22" x2="5.64" y2="5.64"/><line x1="18.36" y1="18.36" x2="19.78" y2="19.78"/><line x1="1" y1="12" x2="3" y2="12"/><line x1="21" y1="12" x2="23" y2="12"/><line x1="4.22" y1="19.78" x2="5.64" y2="18.36"/><line x1="18.36" y1="5.64" x2="19.78" y2="4.22"/>';
}
function changeTheme(base){
  const cur=document.body.getAttribute('data-theme')||'';
  const isDark=cur.includes('dark');
  applyTheme(base,isDark);
  try{localStorage.setItem('pm_base_theme',base);}catch(e){}
  setTimeout(()=>renderCharts(),120);
}
function toggleDark(){
  const cur=document.body.getAttribute('data-theme')||'';
  const isDark=cur.includes('dark');
  const base=(el('themeSel')||{value:'blue'}).value||'blue';
  applyTheme(base,!isDark);
  try{localStorage.setItem('pm_dark',String(!isDark));}catch(e){}
  setTimeout(()=>renderCharts(),120);
}
window.changeTheme=changeTheme; window.toggleDark=toggleDark;
window.toggleSidebar=toggleSidebar;
window.showView=showView;
window.toggleCharts=toggleCharts;
window.resetAll=resetAll;
window.toggleMs=toggleMs;

