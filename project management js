// Revenue Trend
function renderTrendChart(items,c) {
  dChart('trend');
  mkBtns('trendPeriodBtns',[{k:'W',l:'Week'},{k:'M',l:'Month'},{k:'Q',l:'Quarter'},{k:'Y',l:'Year'}],trendPeriod,'setTrendPeriod');
  mkBtns('trendMetricBtns',[{k:'tcv',l:'TCV'},{k:'mrc',l:'MRC'},{k:'otc',l:'OTC'},{k:'billedRev',l:'Billed Rev'}],trendMetric,'setTrendMetric');
  const cnt = trendPeriod==='W'?12:trendPeriod==='M'?12:trendPeriod==='Q'?8:6;
  const {labels,buckets} = buildTimeBuckets(trendPeriod, cnt);
  const getVal = (it) => trendMetric==='tcv'?it.tcv:trendMetric==='mrc'?it.mrc:trendMetric==='otc'?it.otc:it.billedRev;
  const getRef = it => it.startDate || it.billingStart || it.actualRFS;
  const datasets = [
    { label:'Completed', status:STATUS_COMPLETED, color:'#10b981' },
    { label:'In Progress', status:STATUS_INPROGRESS, color:c.p1 },
    { label:'On Hold', status:STATUS_ONHOLD, color:'#f59e0b' },
  ].map(ds => {
    const data = buckets.map(bkt => {
      const mb = items.filter(i=>{ const rd=getRef(i); if(!rd) return false; return bucketByPeriod(new Date(rd),trendPeriod)===bkt && ds.status(i.status); });
      return +(mb.reduce((s,i)=>s+getVal(i),0)/1e6).toFixed(2);
    });
    return { label:ds.label, data, borderColor:ds.color, backgroundColor:ds.color.replace(')',',0.15)').replace('rgb','rgba'), fill:true, tension:.38, pointRadius:4, pointHoverRadius:7, pointBackgroundColor:ds.color, pointBorderColor:'#fff', pointBorderWidth:2, borderWidth:2.5 };
  });
  const canvas = el('chartTrend'); if(!canvas) return;
  CHARTS.trend = new Chart(canvas,{type:'line',data:{labels,datasets},options:{responsive:true,maintainAspectRatio:false,interaction:{mode:'index',intersect:false},plugins:{legend:{position:'top',labels:{color:c.text,font:{size:12,weight:'600'},usePointStyle:true,pointStyleWidth:10,padding:20}},tooltip:{backgroundColor:'rgba(10,10,28,.88)',padding:14,cornerRadius:12,titleFont:{size:13,weight:'700'},bodyFont:{size:12},callbacks:{label:ctx=>'  '+ctx.dataset.label+': '+ctx.parsed.y.toFixed(2)+'M'}}},scales:{x:{ticks:{color:c.text,font:{size:11,weight:'600'}},grid:{color:c.grid},border:{dash:[4,4]}},y:{ticks:{color:c.text,callback:v=>v+'M'},grid:{color:c.grid},beginAtZero:true}}}});
}
