// ── EXPORT ───────────────────────────────────────────────────────
function buildExcelHtml(data) {
  const cols=['bid','custName','projName','status','health','pmName','vertical','accMgr','salesDir','mrc','otc','tcv','billedRev','expRev','contractDur','spi','projType','projSize','startDate','closureBL','expDelivery','expRFS','actualRFS','billingStart','fneInvolve','fneScope','wo','contractId','accNum','rfsDelay','year','quarter'];
  const hdrs=['Bid #','Customer','Project','Status','Health','PM','Vertical','AM','Sales Dir','MRC','OTC','TCV','Billed Rev','Exp Rev','Duration','SPI','Proj Type','Proj Size','Handover','Closure BL','Exp Delivery','Exp RFS','Actual RFS','Billing Start','FNE','FNE Scope','WO','Contract ID','Acc #','RFS Delay','Year','Quarter'];
  const numF=new Set(['mrc','otc','tcv','billedRev','expRev']);
  const dateF=new Set(['startDate','closureBL','expDelivery','expRFS','actualRFS','billingStart']);
  let html='<html><head><meta charset="utf-8"></head><body><table border="1" cellpadding="4" cellspacing="0">';
  html+='<tr>'+hdrs.map(h=>`<th style="background:#2563eb;color:#fff;font-weight:bold;padding:10px;">${h}</th>`).join('')+'</tr>';
  data.forEach((row,i)=>{ const bg=i%2===0?'#f0f4ff':'#fff'; html+='<tr>'+cols.map(c=>{ let v=row[c]; if(v===undefined||v===null||v==='—') v='—'; if(numF.has(c)) v=fmt(n(v)); if(dateF.has(c)) v=fmtD(v); return `<td style="background:${bg};padding:8px;">${v}</td>`; }).join('')+'</tr>'; });
  html+='</table></body></html>';
  return html;
}
function downloadExcel(html, fname) {
  const blob=new Blob([html],{type:'application/vnd.ms-excel'});
  const a=document.createElement('a'); a.href=URL.createObjectURL(blob); a.download=fname; a.click();
}
function doExport(){ downloadExcel(buildExcelHtml(getViewItems()),'PM_Projects_'+new Date().toISOString().split('T')[0]+'.xls'); }
function exportPipeline(){ downloadExcel(buildExcelHtml(FILTERED.filter(i=>!STATUS_COMPLETED(i.status)&&!STATUS_CANCELLED(i.status))),'PM_Pipeline_'+new Date().toISOString().split('T')[0]+'.xls'); }
function exportDelivered(){ downloadExcel(buildExcelHtml(FILTERED.filter(i=>STATUS_COMPLETED(i.status))),'PM_Delivered_'+new Date().toISOString().split('T')[0]+'.xls'); }
function exportAll(){ downloadExcel(buildExcelHtml(ALL_ITEMS),'PM_AllRecords_'+new Date().toISOString().split('T')[0]+'.xls'); }
window.doExport=doExport; window.exportPipeline=exportPipeline; window.exportDelivered=exportDelivered; window.exportAll=exportAll;

