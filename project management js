// ── Utilities ────────────────────────────────────────────────────
const n = v => { const x = parseFloat(v); return isNaN(x) ? 0 : x; };
function fmt(v) { const x = n(v); if(x>=1e9) return (x/1e9).toFixed(2)+'B'; if(x>=1e6) return (x/1e6).toFixed(2)+'M'; if(x>=1e3) return (x/1e3).toFixed(1)+'K'; return x.toFixed(0); }
const fmtD = iso => { if(!iso) return '—'; const d = new Date(iso); return isNaN(d) ? '—' : d.toLocaleDateString('en-GB',{day:'2-digit',month:'short',year:'numeric'}); };
const el = id => document.getElementById(id);
function set(id,val) { const e=el(id); if(e) e.textContent=val; }
function getInitials(name) { if(!name) return '?'; const p=name.trim().split(' '); return p.length>=2?(p[0][0]+p[p.length-1][0]).toUpperCase():name[0].toUpperCase(); }
function getVisitCount() { try { return parseInt(localStorage.getItem('pm_vc_'+USER.email)||'0'); } catch(e){ return 0; } }
function incVisit() { try { const c=getVisitCount()+1; localStorage.setItem('pm_vc_'+USER.email,c); return c; } catch(e){ return 1; } }
function getLastVisit() { try { const lv=localStorage.getItem('pm_lv_'+USER.email); if(!lv) return 'First visit'; const diff=Date.now()-new Date(lv).getTime(); const m=Math.floor(diff/6e4),h=Math.floor(diff/36e5),d=Math.floor(diff/864e5); if(m<60) return m+'m ago'; if(h<24) return h+'h ago'; if(d<7) return d+'d ago'; return new Date(lv).toLocaleDateString('en-GB'); } catch(e){ return '—'; } }
function saveLastVisit() { try { localStorage.setItem('pm_lv_'+USER.email,new Date().toISOString()); } catch(e){} }
function setLoadingStep(msg) { const e=el('loadingStep'); if(e) e.textContent=msg; }
function getWeekOfYear(date) { const d=new Date(date); d.setHours(0,0,0,0); d.setDate(d.getDate()+3-(d.getDay()+6)%7); const w1=new Date(d.getFullYear(),0,4); return 1+Math.round(((d-w1)/864e5-3+(w1.getDay()+6)%7)/7); }

// STATUS helpers
const STATUS_COMPLETED  = v => v && (v.toLowerCase().includes('complet') || v.toLowerCase().includes('close') || v.toLowerCase().includes('rfs'));
const STATUS_INPROGRESS = v => v && (v.toLowerCase().includes('progress') || v.toLowerCase().includes('active') || v.toLowerCase().includes('in-progress'));
const STATUS_ONHOLD     = v => v && (v.toLowerCase().includes('hold') || v.toLowerCase().includes('pause'));
const STATUS_CANCELLED  = v => v && v.toLowerCase().includes('cancel');

function getStatusClass(s) {
  if(!s || s==='—') return 'badge-grey';
  if(STATUS_COMPLETED(s)) return 'badge-green';
  if(STATUS_INPROGRESS(s)) return 'badge-blue';
  if(STATUS_ONHOLD(s)) return 'badge-amber';
  if(STATUS_CANCELLED(s)) return 'badge-red';
  return 'badge-grey';
}
function getHealthClass(h) {
  if(!h||h==='—') return 'badge-grey';
  if(h==='Green') return 'badge-green';
  if(h==='Amber') return 'badge-amber';
  if(h==='Red') return 'badge-red';
  return 'badge-grey';
}

// ── SP Fetch helpers ─────────────────────────────────────────────
function spGet(url, cb) {
  const xhr = new XMLHttpRequest();
  xhr.open('GET', url, true);
  xhr.setRequestHeader('Accept','application/json;odata=verbose');
  xhr.onreadystatechange = function() {
    if(xhr.readyState !== 4) return;
    if(xhr.status >= 200 && xhr.status < 300) {
      try { cb(null, JSON.parse(xhr.responseText)); } catch(e){ cb(e,null); }
    } else { cb(new Error('HTTP '+xhr.status), null); }
  };
  xhr.onerror = () => cb(new Error('Network error'), null);
  xhr.send();
}

// ── ACCESS CONTROL ───────────────────────────────────────────────
function initAccess() {
  spGet(SP_SITE+'/_api/web/currentuser?$select=Title,Email', function(err, data) {
    if(err) { showDenied('Cannot reach SharePoint at '+SP_SITE); return; }
    USER.email = data.d.Email;
    USER.name  = data.d.Title;
    // Try access list; if list doesn't exist yet, fall back to granting access for development
    spGet(SP_SITE+"/_api/web/lists/getbytitle('"+SP_ACCESS+"')/items?$select=UserEmailID,Role&$filter=UserEmailID eq '"+USER.email+"'", function(err2, data2) {
      if(err2 || !data2 || !data2.d || !data2.d.results.length) {
        // Fallback: grant viewer access to any authenticated user
        USER.role = 'Viewer';
        USER.IsAdmin = false;
        populateLanding();
        return;
      }
      USER.role = data2.d.results[0].Role || 'Viewer';
      USER.IsAdmin = ['Admin','Director','Head'].includes(USER.role);
      populateLanding();
    });
  });
}

