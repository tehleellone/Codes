function dChart(k) { if(CHARTS[k]){ CHARTS[k].destroy(); CHARTS[k]=null; } }

function mkBtns(containerId, opts, current, onClick) {
  const wrap = el(containerId); if(!wrap) return;
  wrap.innerHTML = opts.map(o =>
    `<button type="button" class="chart-btn${current===o.k?' active':''}" onclick="${onClick}('${o.k}')">${o.l}</button>`
  ).join('');
