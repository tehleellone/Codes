        // Utility Functions
        function getSiteUrl() {
            if (typeof _spPageContextInfo !== 'undefined' &amp;&amp; _spPageContextInfo.webAbsoluteUrl) {
                return _spPageContextInfo.webAbsoluteUrl;
            }
            return window.location.origin + window.location.pathname.split('/')[0];
        }

        function parseNumber(v) {
            if (v === null || v === undefined || v === "") return 0;
            const n = parseFloat(v);
            return isNaN(n) ? 0 : n;
        }

        function formatCurrency(v) {
            const n = parseNumber(v);
            if (n &gt;= 1000000) return (n / 1000000).toFixed(2) + 'M';
            if (n &gt;= 1000) return (n / 1000).toFixed(1) + 'K';
            return n.toFixed(0);
        }

        function formatDate(iso) {
            if (!iso) return "-";
            const d = new Date(iso);
            if (isNaN(d)) return "-";
            return d.toLocaleDateString();
        }

        function getMonthYear(iso) {
            if (!iso) return null;
            const d = new Date(iso);
            if (isNaN(d)) return null;
            return d.getFullYear() + '-' + String(d.getMonth() + 1).padStart(2, '0');
        }
        // NEW FUNCTION: Get the relevant date based on status
        function getRelevantDateForBid(bid) {
            const status = bid.status;

            // WON: Use Actual Signed Date
            if (status === 'Won') {
                return bid.contractSigned; // Actual_x0020_Contract_x0020_Sign
            }

            // BILLED: Use Billed Date
            if (status === 'Billed') {
                return bid.billedDate; // BilledDate
            }

            // IN PROGRESS: Use Expected Activation
            if (['Lead', 'Opportunity', 'On Hold', 'Proposed'].includes(status)) {
                return bid.expectedActivation; // Expected_x0020_Contract_x0020_Si
            }

            // LOST: Use Lost/Cancelled/No Bid Date
            if (['Lost', 'Cancelled', 'No Bid'].includes(status)) {
                return bid.lostCancelledDate; // No_x0020_Bid_x002f_Lost_x002f_Ca
            }

            // Fallback to Proposed Date or Contract Signed
            return bid.proposedDate || bid.contractSigned;
        }

        // Load Data from SharePoint
        function loadSharePointData() {
            const siteUrl = getSiteUrl();
            const url = siteUrl +
                "/_api/web/lists/getbytitle('" + SHAREPOINT_CONFIG.listName + "')/items" +
                "?$select=Id,Title,Type_x0020_of_x0020_Request,Type_x0020_of_x0020_Contract," +
                "Solution_x0020_Manager,SolutionManagerRequired,Services,Complexity,Product_x0020_Family," +
                "Product_x0020_Category,Monthly_x0020_Recurring_x0020_Ch," +
                "One_x0020_Time_x0020_Charges_x00,Total_x0020_Contact_x0020_Value_," +
                "field8,Proposed_x0020_Date,Expected_x0020_Contract_x0020_Si," +
                "Actual_x0020_Contract_x0020_Sign,BilledDate,No_x0020_Bid_x002f_Lost_x002f_Ca,Contract_x0020_Duration," +
                "Unique_x0020_Reference_x0020_ID,CustomerCode,Segment,Opportunity_x0020_Status,SolutionAssignedDate" +
                "&amp;$filter=(SolutionManagerRequired eq 'Yes') and (Product_x0020_Family eq 'Fixed') and (" +
                "(Solution_x0020_Manager eq 'Sajjad Ahmad') or " +
                "(Solution_x0020_Manager eq 'Kholloud Almeraikhi') or " +
                "(Solution_x0020_Manager eq 'Hadi Unas') or " +
                "(Solution_x0020_Manager eq 'Yazan Shalab') or " +
                "(Solution_x0020_Manager eq 'Mohammed Alkhateeb') or " +
                "(Solution_x0020_Manager eq 'Jonathan Warner') or " +
                "(Solution_x0020_Manager eq 'Ahmed AlBenali') or " +
                "(Solution_x0020_Manager eq 'Salem AlShehhi'))" +
                "&amp;$top=5000";

            const xhr = new XMLHttpRequest();
            xhr.open("GET", url, true);
            xhr.setRequestHeader("Accept", "application/json;odata=verbose");

            xhr.onreadystatechange = function() {
                if (xhr.readyState !== 4) return;

                if (xhr.status &gt;= 200 &amp;&amp; xhr.status &lt; 300) {
                    try {
                        const json = JSON.parse(xhr.responseText);
                        const items = json.d.results;
                        console.log('=== SharePoint Raw Data ===');
                        console.log('Total items received:', items.length);
                        console.log('First 3 items:', items.slice(0, 3));
                        // Transform SharePoint data and FILTER by allowed architects
                        ALL_BIDS = items.map(item =&gt; ({
                            id: item.Id,
                            customerName: item.Title || "-",
                            typeOfRequest: item.Type_x0020_of_x0020_Request || "-",
                            typeOfContract: item.Type_x0020_of_x0020_Contract || "-",
                            solutionManager: item.Solution_x0020_Manager || "-",
                            services: item.Services || "-",
                            complexity: item.Complexity || "-",
                            productFamily: item.Product_x0020_Family || "-",
                            productCategory: item.Product_x0020_Category || "-",
                            mrc: parseNumber(item.Monthly_x0020_Recurring_x0020_Ch),
                            otc: parseNumber(item.One_x0020_Time_x0020_Charges_x00),
                            tcv: parseNumber(item.Total_x0020_Contact_x0020_Value_),
                            prepaidPostpaid: item.field8 || item.PrepaidPostpaid || item.Prepaid_x002f_Postpaid || "-",
                            proposedDate: item.Proposed_x0020_Date || null,
                            expectedActivation: item.Expected_x0020_Contract_x0020_Si || null,
                            contractSigned: item.Actual_x0020_Contract_x0020_Sign || null,
                            billedDate: item.BilledDate || null,
                            lostCancelledDate: item.No_x0020_Bid_x002f_Lost_x002f_Ca || null,
                            solutionAssignedDate: item.SolutionAssignedDate || null,
                            duration: item.Contract_x0020_Duration || "-",
                            bidReference: item.Unique_x0020_Reference_x0020_ID || "-",
                            customerCode: item.CustomerCode || "-",
                            vertical: item.Segment || "-",
                            status: item.Opportunity_x0020_Status || "Open"
                        }));
                        console.log('Loaded bids:', ALL_BIDS.length);
                        console.log('Sample bid:', ALL_BIDS[0]);
                        console.log('Prepaid/Postpaid value:', ALL_BIDS[0]?.prepaidPostpaid);
                        console.log('Raw SharePoint item:', items[0]);
                        init();
                    } catch (error) {
                        console.error('Error parsing SharePoint data:', error);
                        ALL_BIDS = [];
                        init();
                    }
                } else {
                    console.error("Error loading SharePoint data. Status:", xhr.status);
                    ALL_BIDS = [];
                    init();
                }
            };

            xhr.onerror = function() {
                console.error('Network error loading SharePoint data');
                ALL_BIDS = [];
                init();
            };

            xhr.send();
        }

