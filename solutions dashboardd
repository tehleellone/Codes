            color: var(--text-primary);
            font-size: 14px;
            font-weight: 500;
            cursor: pointer;
            transition: all 0.3s;
            font-family: inherit;
        }

        [data-theme="glass"] .filter-select,
        [data-theme="dark"] .filter-select {
            background: rgba(255, 255, 255, 0.1);
            color: #ffffff;
        }

        [data-theme="glass"] .filter-select option,
        [data-theme="dark"] .filter-select option {
            background: #2a1f3f;
            color: #ffffff;
        }

        .filter-select:focus {
            outline: none;
