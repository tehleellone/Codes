        function applyFilters() {
            const teams = getCheckedValues('teamDropdown');
            const managers = getCheckedValues('solutionMgrDropdown');
            const verticals = getCheckedValues('verticalDropdown');
            const complexities = getCheckedValues('complexityDropdown');
            const statuses = getCheckedValues('statusDropdown');
            const years = getCheckedValues('yearDropdown');
            const quarters = getCheckedValues('quarterDropdown');
            const months = getCheckedValues('monthDropdown');
            const weeks = getCheckedValues('weekDropdown');

            filteredBids = ALL_BIDS.filter(bid =&gt; {
                if (viewMode === 'assignment' &amp;&amp; !bid.solutionAssignedDate) return false;

                const relevantDate = viewMode === 'assignment' ?
                    bid.solutionAssignedDate : getRelevantDateForBid(bid);
                const bidDate = new Date(relevantDate);
                const bidYear = String(bidDate.getFullYear());
                const bidMonth = String(bidDate.getMonth());
                const bidQuarter = getQuarter(relevantDate);
                const bidWeek = String(getWeekOfYear(relevantDate));

                const managerIndex = ALLOWED_ARCHITECTS.indexOf(bid.solutionManager);
                const bidTeam = managerIndex &lt; 4 ? 'Team Blue' : 'Team Purple';

                if (selectedArchitect &amp;&amp; bid.solutionManager !== selectedArchitect) return false;
                if (teams.length &gt; 0 &amp;&amp; !teams.includes(bidTeam)) return false;
                if (managers.length &gt; 0 &amp;&amp; !managers.includes(bid.solutionManager)) return false;
                if (verticals.length &gt; 0 &amp;&amp; !verticals.includes(bid.vertical)) return false;
                if (statuses.length &gt; 0 &amp;&amp; !statuses.includes(bid.status)) return false;
                if (complexities.length &gt; 0 &amp;&amp; !complexities.includes(bid.complexity)) return false;
                if (years.length &gt; 0 &amp;&amp; !years.includes(bidYear)) return false;
                if (quarters.length &gt; 0 &amp;&amp; !quarters.includes(bidQuarter)) return false;
                if (months.length &gt; 0 &amp;&amp; !months.includes(bidMonth)) return false;
                if (weeks.length &gt; 0 &amp;&amp; !weeks.includes(bidWeek)) return false;
                return true;
            });

            if (viewMode === 'status') {
                updateTopStats();
            } else {
                updateAssignmentStats();
            }
            renderArchitectTiles();
            renderCharts();
            renderTable();
        }

