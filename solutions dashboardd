        function updateTopStats() {
            const totalBids = filteredBids.length;
            const totalTCV = filteredBids.reduce((sum, b) =&gt; sum + b.tcv, 0);

            // WON = Billed, Won
            const wonBids = filteredBids.filter(b =&gt; ['Won', 'Billed'].includes(b.status)).length;
            const wonTCV = filteredBids.filter(b =&gt; ['Won', 'Billed'].includes(b.status)).reduce((sum, b) =&gt; sum + b.tcv, 0);

            // IN PROGRESS = Lead, Opportunity, On Hold, Proposed
            const inProgressBids = filteredBids.filter(b =&gt; ['Lead', 'Opportunity', 'On Hold', 'Proposed'].includes(b.status)).length;
            const inProgressTCV = filteredBids.filter(b =&gt; ['Lead', 'Opportunity', 'On Hold', 'Proposed'].includes(b.status)).reduce((sum, b) =&gt; sum + b.tcv, 0);

            // LOST = Lost, Cancelled, No Bid
            const lostBids = filteredBids.filter(b =&gt; ['Lost', 'Cancelled', 'No Bid'].includes(b.status)).length;
            const lostTCV = filteredBids.filter(b =&gt; ['Lost', 'Cancelled', 'No Bid'].includes(b.status)).reduce((sum, b) =&gt; sum + b.tcv, 0);

            // Tile 1: Overall Bids
            document.getElementById('overallBids').textContent = totalBids;
            document.getElementById('overallTCV').textContent = formatCurrency(totalTCV);

            // Tile 2: Total TCV
            document.getElementById('totalTCV').textContent = formatCurrency(totalTCV);
            document.getElementById('wonTCVValue').textContent = formatCurrency(wonTCV);
            document.getElementById('otherTCVValue').textContent = formatCurrency(inProgressTCV + lostTCV);

            // Tile 3: Won
            const wonPercentage = totalBids &gt; 0 ? ((wonBids / totalBids) * 100).toFixed(1) : 0;
            document.getElementById('wonBids').textContent = wonPercentage + '%';
            document.getElementById('wonCount').textContent = wonBids;
            document.getElementById('wonTCV').textContent = formatCurrency(wonTCV);

            // Tile 4: In Progress
            const inProgressPercentage = totalBids &gt; 0 ? ((inProgressBids / totalBids) * 100).toFixed(1) : 0;
            document.getElementById('inProgressBids').textContent = inProgressPercentage + '%';
            document.getElementById('inProgressCount').textContent = inProgressBids;
            document.getElementById('inProgressTCV').textContent = formatCurrency(inProgressTCV);

            // Tile 5: Lost
            const lostPercentage = totalBids &gt; 0 ? ((lostBids / totalBids) * 100).toFixed(1) : 0;
            document.getElementById('lostBids').textContent = lostPercentage + '%';
            document.getElementById('lostCount').textContent = lostBids;
            document.getElementById('lostTCV').textContent = formatCurrency(lostTCV);
        }

        function updateAssignmentStats() {
            const now = new Date();
            const currentMonth = now.getMonth();
            const currentYear = now.getFullYear();
            const currentQuarter = Math.ceil((currentMonth + 1) / 3);

            // Filter by assignment date
            const assignedBids = filteredBids.filter(b =&gt; b.solutionAssignedDate);

            // Total assignments
            const totalAssignments = assignedBids.length;
            document.getElementById('totalAssignments').textContent = totalAssignments;

            // This month assignments
            const thisMonthAssignments = assignedBids.filter(b =&gt; {
                const d = new Date(b.solutionAssignedDate);
                return d.getMonth() === currentMonth &amp;&amp; d.getFullYear() === currentYear;
            }).length;
            document.getElementById('assignmentsThisMonth').textContent = thisMonthAssignments;

            // This quarter assignments
            const thisQuarterAssignments = assignedBids.filter(b =&gt; {
                const d = new Date(b.solutionAssignedDate);
                const q = Math.ceil((d.getMonth() + 1) / 3);
                return q === currentQuarter &amp;&amp; d.getFullYear() === currentYear;
            }).length;
            document.getElementById('assignmentsThisQuarter').textContent = thisQuarterAssignments;

            // Per manager stats
            const managerLoads = {};
            assignedBids.forEach(b =&gt; {
                if (!managerLoads[b.solutionManager]) {
                    managerLoads[b.solutionManager] = {
                        count: 0,
                        tcv: 0
                    };
                }
                managerLoads[b.solutionManager].count++;
                managerLoads[b.solutionManager].tcv += b.tcv;
            });

            const loads = Object.values(managerLoads).map(l =&gt; l.count);
            const avgLoad = loads.length &gt; 0 ? (loads.reduce((a, b) =&gt; a + b, 0) / loads.length).toFixed(1) : 0;
            const highestLoad = loads.length &gt; 0 ? Math.max(...loads) : 0;
            const lowestLoad = loads.length &gt; 0 ? Math.min(...loads) : 0;

            document.getElementById('avgPerManager').textContent = avgLoad;
            document.getElementById('highestLoad').textContent = highestLoad;
            document.getElementById('lowestLoad').textContent = lowestLoad;

            // Most loaded manager
            const sortedManagers = Object.entries(managerLoads).sort((a, b) =&gt; b[1].count - a[1].count);

            if (sortedManagers.length &gt; 0) {
                const mostLoaded = sortedManagers[0];
                document.getElementById('mostLoadedManager').textContent = mostLoaded[0].split(' ')[0];
                document.getElementById('mostLoadedCount').textContent = mostLoaded[1].count + ' assignments';
                document.getElementById('mostLoadedTCV').textContent = formatCurrency(mostLoaded[1].tcv);
                document.getElementById('mostLoadedPercent').textContent = ((mostLoaded[1].count / totalAssignments) * 100).toFixed(1) + '%';

                const leastLoaded = sortedManagers[sortedManagers.length - 1];
                document.getElementById('leastLoadedManager').textContent = leastLoaded[0].split(' ')[0];
                document.getElementById('leastLoadedCount').textContent = leastLoaded[1].count + ' assignments';
                document.getElementById('leastLoadedTCV').textContent = formatCurrency(leastLoaded[1].tcv);
                document.getElementById('leastLoadedPercent').textContent = ((leastLoaded[1].count / totalAssignments) * 100).toFixed(1) + '%';
            } else {
                // CLEAR TILES WHEN NO DATA
                document.getElementById('mostLoadedManager').textContent = '-';
                document.getElementById('mostLoadedCount').textContent = '0 assignments';
                document.getElementById('mostLoadedTCV').textContent = '0M';
                document.getElementById('mostLoadedPercent').textContent = '0%';

                document.getElementById('leastLoadedManager').textContent = '-';
                document.getElementById('leastLoadedCount').textContent = '0 assignments';
                document.getElementById('leastLoadedTCV').textContent = '0M';
                document.getElementById('leastLoadedPercent').textContent = '0%';
            }
        }

        function renderArchitectTiles() {
            // Only show allowed architects
            const managers = ALLOWED_ARCHITECTS.filter(mgr =&gt;
                filteredBids.some(b =&gt; b.solutionManager === mgr)
            );

            const architectStats = managers.map((manager, i) =&gt; {
                const bids = filteredBids.filter(b =&gt; b.solutionManager === manager);

                // WON = Billed, Won
                const wonBids = bids.filter(b =&gt; ['Won', 'Billed'].includes(b.status)).length;
                const wonTCV = bids.filter(b =&gt; ['Won', 'Billed'].includes(b.status)).reduce((sum, b) =&gt; sum + b.tcv, 0);

                // IN PROGRESS = Lead, Opportunity, On Hold, Proposed
                const inProgressBids = bids.filter(b =&gt; ['Lead', 'Opportunity', 'On Hold', 'Proposed'].includes(b.status)).length;
                const inProgressTCV = bids.filter(b =&gt; ['Lead', 'Opportunity', 'On Hold', 'Proposed'].includes(b.status)).reduce((sum, b) =&gt; sum + b.tcv, 0);

                // LOST = Lost, Cancelled, No Bid
                const lostBids = bids.filter(b =&gt; ['Lost', 'Cancelled', 'No Bid'].includes(b.status)).length;
                const lostTCV = bids.filter(b =&gt; ['Lost', 'Cancelled', 'No Bid'].includes(b.status)).reduce((sum, b) =&gt; sum + b.tcv, 0);

                // WIN RATIO (Won / Total)
                const winRatio = bids.length &gt; 0 ? ((wonBids / bids.length) * 100).toFixed(1) : 0;

                // TCV CALCULATIONS
                const totalTCV = bids.reduce((sum, b) =&gt; sum + b.tcv, 0);

                // COMPLEXITY SPLIT
                const simplexCount = bids.filter(b =&gt; b.complexity === 'Simplex').length;
                const complexCount = bids.filter(b =&gt; b.complexity === 'Complex').length;
                const simplexPercent = bids.length &gt; 0 ? ((simplexCount / bids.length) * 100).toFixed(1) : 0;
                const complexPercent = bids.length &gt; 0 ? ((complexCount / bids.length) * 100).toFixed(1) : 0;

                const totalFilteredBids = filteredBids.length;
                const overallContribution = totalFilteredBids &gt; 0 ? (bids.length / totalFilteredBids * 100).toFixed(1) : 0;
                const tcvContribution = filteredBids.reduce((sum, b) =&gt; sum + b.tcv, 0);
                const tcvPercent = tcvContribution &gt; 0 ? (totalTCV / tcvContribution * 100).toFixed(1) : 0;

                // CORRECT TEAM ASSIGNMENT - Based on ALLOWED_ARCHITECTS array position
                const managerIndex = ALLOWED_ARCHITECTS.indexOf(manager);
                const team = managerIndex &lt; 4 ? 'Team Blue' : 'Team Purple'
                return {
                    name: manager,
                    team: team,
                    totalBids: bids.length,
                    wonBids,
                    inProgressBids,
                    lostBids,
                    wonTCV,
                    inProgressTCV,
                    lostTCV,
                    winRatio,
                    totalTCV,
                    simplexCount,
                    complexCount,
                    simplexPercent,
                    complexPercent,
                    overallContribution,
