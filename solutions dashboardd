        function _pdfEnsurePage(pdf, y, needed, pageH, footerRoom) {
            footerRoom = footerRoom || 15;
            if (y + needed > pageH - footerRoom) {
                pdf.addPage();
                return 15;
            }
            return y;
        }

        function _pdfSectionTitle(pdf, text, y, margin, contentW, accent) {
            pdf.setFontSize(11);
            pdf.setFont(undefined, 'bold');
            pdf.setTextColor(accent[0], accent[1], accent[2]);
            pdf.text(text, margin, y);
            y += 2;
            pdf.setDrawColor(200, 210, 235);
            pdf.setLineWidth(0.3);
            pdf.line(margin, y, margin + contentW, y);
            return y + 5;
        }

        function _pdfWriteFooter(pdf, pageW, pageH, margin) {
            const pages = pdf.internal.getNumberOfPages();
            for (let i = 1; i <= pages; i++) {
                pdf.setPage(i);
                pdf.setFontSize(8);
                pdf.setTextColor(120, 120, 120);
                pdf.setFont(undefined, 'normal');
                pdf.text('GLK Solution Dashboard · SharePoint', margin, pageH - 6);
                const pgText = 'Page ' + i + ' of ' + pages;
                pdf.text(pgText, pageW - margin - pdf.getTextWidth(pgText), pageH - 6);
            }
        }

        async function _pdfAddOverviewBlock(pdf, y, margin, contentW, pageH, statsEl) {
            const wrapper = document.createElement('div');
            wrapper.style.cssText = 'position:fixed;left:-10000px;top:0;width:' +
                Math.min(document.getElementById('mainDashboard').offsetWidth, 1400) +
                'px;background:transparent;padding:0;margin:0;z-index:-1;';

            function appendBlock(el, label) {
                if (!el || el.offsetHeight < 5 || getComputedStyle(el).display === 'none') return;
                if (label) {
                    const heading = document.createElement('div');
                    heading.textContent = label;
                    heading.style.cssText = 'font-size:12px;font-weight:800;color:#7c3aed;margin:12px 0 8px;text-transform:uppercase;letter-spacing:0.04em;';
                    wrapper.appendChild(heading);
                }
                const clone = el.cloneNode(true);
                clone.style.marginBottom = '12px';
                wrapper.appendChild(clone);
            }

            appendBlock(statsEl, 'Key Metrics');
            appendBlock(document.querySelector('.team-blue-section'), null);
            appendBlock(document.querySelector('.team-purple-section'), null);

            if (!wrapper.childNodes.length) return y;

            document.body.appendChild(wrapper);
            const bodyBg = getComputedStyle(document.body).backgroundColor;
            const captureBg = (bodyBg && bodyBg !== 'rgba(0, 0, 0, 0)') ? bodyBg : '#ffffff';
            const snap = await html2canvas(wrapper, {
                scale: 2,
                useCORS: true,
                backgroundColor: captureBg,
                logging: false,
                allowTaint: true
            });
            document.body.removeChild(wrapper);

            let imgW = contentW;
            let imgH = (snap.height / snap.width) * imgW;
            const availH = pageH - y - 15;
            if (imgH > availH) {
                const scale = availH / imgH;
                imgH = availH;
                imgW = imgW * scale;
            }

            pdf.addImage(snap.toDataURL('image/jpeg', 0.95), 'JPEG', margin, y, imgW, imgH);
            return y + imgH + 4;
        }

        async function _pdfAddSnapshot(pdf, el, y, margin, contentW, pageH, label, accent, forceNewPage) {
            if (!el || el.offsetHeight < 5 || getComputedStyle(el).display === 'none') return y;
            if (forceNewPage && y > 20) {
                pdf.addPage();
                y = 15;
            }

            const bodyBg = getComputedStyle(document.body).backgroundColor;
            const captureBg = (bodyBg && bodyBg !== 'rgba(0, 0, 0, 0)') ? bodyBg : '#ffffff';
            const snap = await html2canvas(el, {
                scale: 2,
                useCORS: true,
                backgroundColor: captureBg,
                logging: false,
                allowTaint: true
            });

            const labelH = label ? 10 : 0;
            let imgW = contentW;
            let imgH = (snap.height / snap.width) * imgW;
            const maxBlockH = pageH - margin - 15;

            y = _pdfEnsurePage(pdf, y, Math.min(labelH + imgH, maxBlockH), pageH);
            if (label) y = _pdfSectionTitle(pdf, label, y, margin, contentW, accent);

            const availH = pageH - y - 15;
            if (imgH > availH) {
                const scale = availH / imgH;
                imgH = availH;
                imgW = imgW * scale;
            }

            pdf.addImage(snap.toDataURL('image/jpeg', 0.95), 'JPEG', margin, y, imgW, imgH);
            return y + imgH + 8;
        }

        function _pdfChartBlockHeight(chart, slotW, maxHmm, title) {
            if (!chart || !chart.canvas) return 0;
            let imgH = (chart.canvas.height / chart.canvas.width) * slotW;
            if (imgH > maxHmm) imgH = maxHmm;
            return 9 + imgH + (title ? 0 : 0);
        }

        function _pdfDrawChartInSlot(pdf, chart, title, x, y, slotW, maxHmm, accent) {
            if (!chart || !chart.canvas) return y;
            try { chart.update('none'); } catch (e) {}

            pdf.setFontSize(8.5);
            pdf.setFont(undefined, 'bold');
            pdf.setTextColor(accent[0], accent[1], accent[2]);
            const titleLines = pdf.splitTextToSize(title, slotW);
            titleLines.forEach(function(line, i) {
                pdf.text(line, x, y + 4 + (i * 3.6));
            });
            const titleH = 4 + (titleLines.length * 3.6);

            let imgW = slotW;
            let imgH = (chart.canvas.height / chart.canvas.width) * imgW;
            if (imgH > maxHmm) {
                imgH = maxHmm;
                imgW = imgH * (chart.canvas.width / chart.canvas.height);
            }

            pdf.addImage(chart.toBase64Image('image/png', 1), 'PNG', x, y + titleH, imgW, imgH);
            return y + titleH + imgH;
        }

        function _pdfAddChartPairRow(pdf, left, right, y, margin, contentW, pageH, accent) {
            const gap = 6;
            const halfW = (contentW - gap) / 2;
            const xRight = margin + halfW + gap;
            const maxHmm = 78;
            const rowH = Math.max(
                left ? _pdfChartBlockHeight(left.chart, halfW, maxHmm, left.title) : 0,
                right ? _pdfChartBlockHeight(right.chart, halfW, maxHmm, right.title) : 0,
                20
            );

            y = _pdfEnsurePage(pdf, y, rowH + 8, pageH);
            let bottom = y;
            if (left && left.chart) {
                bottom = Math.max(bottom, _pdfDrawChartInSlot(pdf, left.chart, left.title, margin, y, halfW, maxHmm, accent));
            }
            if (right && right.chart) {
                bottom = Math.max(bottom, _pdfDrawChartInSlot(pdf, right.chart, right.title, xRight, y, halfW, maxHmm, accent));
            }
            return bottom + 8;
        }

        function _pdfAddChartFullWidth(pdf, chart, title, y, margin, contentW, pageH, accent) {
            if (!chart) return y;
            const maxHmm = 105;
            y = _pdfEnsurePage(pdf, y, maxHmm + 14, pageH);
            return _pdfDrawChartInSlot(pdf, chart, title, margin, y, contentW, maxHmm, accent) + 8;
        }

        async function exportDashboardPDF() {
            if (!window.jspdf || !window.html2canvas) {
                alert('PDF libraries are still loading. Please try again in a moment.');
                return;
            }

            const dashboard = document.getElementById('mainDashboard');
            if (!dashboard || dashboard.style.display === 'none') {
                alert('Please open the dashboard before exporting to PDF.');
                return;
            }

            const btn = document.getElementById('pdfExportBtn');
            const oldHtml = btn ? btn.innerHTML : null;
            const overlay = document.getElementById('pdfLoadingOverlay');
            if (btn) {
                btn.disabled = true;
                btn.textContent = 'Generating PDF...';
            }
            if (overlay) overlay.classList.add('active');

            try {
                const { jsPDF } = window.jspdf;
                const pdf = new jsPDF({ orientation: 'p', unit: 'mm', format: 'a4' });
                const pageW = pdf.internal.pageSize.getWidth();
                const pageH = pdf.internal.pageSize.getHeight();
                const margin = 12;
                const contentW = pageW - margin * 2;
                const accent = [124, 58, 237];
                const viewLabel = viewMode === 'assignment' ? 'Assignment Load' : 'Status Dashboard';

                pdf.setFillColor(147, 51, 234);
                pdf.rect(0, 0, pageW, 28, 'F');
                pdf.setTextColor(255, 255, 255);
                pdf.setFontSize(17);
                pdf.setFont(undefined, 'bold');
                pdf.text('GLK Solution Dashboard — ' + viewLabel, margin, 13);
                pdf.setFontSize(10);
                pdf.setFont(undefined, 'normal');
                pdf.text('Generated: ' + new Date().toLocaleString('en-GB'), margin, 21);
                if (USER_CONTEXT && USER_CONTEXT.userName) {
                    const userText = 'User: ' + USER_CONTEXT.userName;
                    pdf.text(userText, pageW - margin - pdf.getTextWidth(userText), 21);
                }

                let y = 36;
                y = _pdfSectionTitle(pdf, 'Filters Applied', y, margin, contentW, accent);
                pdf.setFontSize(9.5);
                pdf.setFont(undefined, 'normal');
                pdf.setTextColor(40, 40, 40);

                _getFiltersDescription().forEach(function(f) {
                    pdf.splitTextToSize('• ' + f, contentW - 4).forEach(function(line) {
                        pdf.text(line, margin + 2, y);
                        y += 4.8;
                    });
                });
                y += 4;

                const statsEl = viewMode === 'assignment'
                    ? document.getElementById('assignmentStatsSection')
                    : document.querySelector('.top-stats');
                y = await _pdfAddOverviewBlock(pdf, y, margin, contentW, pageH, statsEl);

                Object.values(chartInstances).forEach(function(c) {
                    if (c && typeof c.update === 'function') {
                        try { c.update('none'); } catch (e) {}
                    }
                });
                await new Promise(function(r) { setTimeout(r, 120); });

                const chartsSection = document.querySelector('.charts-section');
                if (chartsSection && chartsSection.offsetHeight > 5 && getComputedStyle(chartsSection).display !== 'none') {
                    pdf.addPage();
                    y = 15;
                    y = _pdfSectionTitle(pdf, 'Charts & Analytics', y, margin, contentW, accent);
                    y = _pdfAddChartPairRow(pdf,
                        { chart: chartInstances.openClosed, title: 'Won vs In Progress vs Lost by Manager' },
                        { chart: chartInstances.trend, title: 'Bid Activity Trend (Last 6 Months)' },
                        y, margin, contentW, pageH, accent);
                    y = _pdfAddChartPairRow(pdf,
                        { chart: chartInstances.load, title: 'Assignment Load per Manager' },
                        { chart: chartInstances.complexity, title: 'Complexity Distribution by Manager' },
                        y, margin, contentW, pageH, accent);
                }

                const servicesCard = document.getElementById('servicesChartCard');
                if (servicesCard && servicesCard.offsetHeight > 5 && getComputedStyle(servicesCard).display !== 'none' && chartInstances.services) {
                    const servicesTitle = document.getElementById('servicesChartTitle');
                    const title = servicesTitle ? servicesTitle.textContent.trim() : 'Services Breakdown';
                    y = _pdfAddChartFullWidth(pdf, chartInstances.services, title, y, margin, contentW, pageH, accent);
                }

                _pdfWriteFooter(pdf, pageW, pageH, margin);
                pdf.save('GLK_Solutions_Dashboard_' + new Date().toISOString().split('T')[0] + '.pdf');
            } catch (e) {
                console.error('PDF export failed:', e);
                alert('PDF export failed: ' + e.message);
            } finally {
                if (overlay) overlay.classList.remove('active');
                if (btn) {
                    btn.disabled = false;
                    btn.innerHTML = oldHtml;
                }
            }
        }

