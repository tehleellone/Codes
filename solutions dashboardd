            // TREND CHART - Real data based on Contract Signed Date
            if (chartInstances.trend) chartInstances.trend.destroy();
            const trendCtx = document.getElementById('trendChart');

            // Get last 6 months trend data
            const dataForTrend = selectedArchitect ?
                filteredBids.filter(b =&gt; b.solutionManager === selectedArchitect) :
                filteredBids;
            // Update chart title
            document.getElementById('trendChartTitle').innerHTML = selectedArchitect ?
                `&lt;i data-lucide="trending-up" style="width:18px;height:18px;display:inline-block;margin-right:6px;"&gt;&lt;/i&gt;${selectedArchitect}'s Activity Trend (Last 6 Months)` :
                '&lt;i data-lucide="trending-up" style="width:18px;height:18px;display:inline-block;margin-right:6px;"&gt;&lt;/i&gt;Bid Activity Trend (Last 6 Months)';
            if (typeof lucide !== "undefined") lucide.createIcons();

            const monthCounts = {};
            const monthTCV = {};
            dataForTrend.forEach(bid =&gt; {
                const relevantDate = getRelevantDateForBid(bid);
                const monthYear = getMonthYear(relevantDate);
                if (monthYear) {
                    monthCounts[monthYear] = (monthCounts[monthYear] || 0) + 1;
                    monthTCV[monthYear] = (monthTCV[monthYear] || 0) + bid.tcv;
                }
