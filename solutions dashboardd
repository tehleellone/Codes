            // Get last 6 months
            const now = new Date();
            const months = [];
            const monthData = [];
            const monthTCVData = [];
            for (let i = 5; i &gt;= 0; i--) {
                const d = new Date(now.getFullYear(), now.getMonth() - i, 1);
                const key = d.getFullYear() + '-' + String(d.getMonth() + 1).padStart(2, '0');
                months.push(d.toLocaleDateString('en-US', {
