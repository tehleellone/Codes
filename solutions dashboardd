            color: var(--danger);
            font-weight: 600;
            font-size: 14px;
            cursor: pointer;
            transition: all 0.3s;
        }

        .reset-btn:hover {
            background: rgba(239, 68, 68, 0.25);
        }

        /* Solution Architect Tiles - 4 per row */
        .architects-grid {
            display: grid;
            grid-template-columns: repeat(4, 1fr);
            gap: 20px;
            margin-bottom: 24px;
        }

        .architect-tile {
            background: var(--bg-card);
            backdrop-filter: blur(20px);
            border: 2px solid var(--border-color);
            border-radius: 20px;
            padding: 24px;
            box-shadow: var(--card-shadow);
