            // COMPLEXITY DISTRIBUTION CHART
            if (chartInstances.complexity) chartInstances.complexity.destroy();
            const complexityCtx = document.getElementById('complexityChart');

            // Get data for complexity chart - either selected architect or all managers
            const complexityManagers = selectedArchitect ? [selectedArchitect] : managers;

            const simplexData = complexityManagers.map(mgr => {
                const bids = filteredBids.filter(b => b.solutionManager === mgr);
                return bids.filter(b => b.complexity === 'Simplex').length;
