            if (teams.length) parts.push('Team: ' + teams.join(', '));
            else parts.push('Team: All Teams');
            if (managers.length) parts.push('Solution Manager: ' + managers.join(', '));
            else parts.push('Solution Manager: All Managers');
            if (verticals.length) parts.push('Vertical: ' + verticals.join(', '));
            if (complexities.length) parts.push('Complexity: ' + complexities.join(', '));
            if (statuses.length) parts.push('Opportunity Status: ' + statuses.join(', '));
