            const complexData = complexityManagers.map(mgr => {
                const bids = filteredBids.filter(b => b.solutionManager === mgr);
                return bids.filter(b => b.complexity === 'Complex').length;
            });

            // Calculate totals for percentages
            const totalPerManager = complexityManagers.map(mgr => {
