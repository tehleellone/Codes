        function getChartColors() {
            const isDark = document.body.classList.contains('dark-theme');
            const isCyan = document.body.classList.contains('cyan-theme');

            if (isDark) {
                // Dark mode - white text
                return {
                    text: '#ffffff',
                    secondary: '#e2e8f0',
                    grid: 'rgba(255, 255, 255, 0.1)',
                    primary: isCyan ? '#3b82f6' : '#a855f7',
                    accent: isCyan ? '#3b82f6' : '#a855f7',
                    teamBlue: isCyan ? '#3b82f6' : '#3b82f6',
                    teamPurple: isCyan ? '#60a5fa' : '#a855f7',
                    success: '#10b981',
                    warning: '#f59e0b',
                    danger: '#ef4444'
                };
            } else {
                // Light mode - dark text
                return {
                    text: '#1e293b',
                    secondary: '#475569',
                    grid: 'rgba(100, 116, 139, 0.15)',
                    primary: isCyan ? '#3b82f6' : '#a855f7',
                    accent: isCyan ? '#3b82f6' : '#a855f7',
                    teamBlue: isCyan ? '#3b82f6' : '#3b82f6',
                    teamPurple: isCyan ? '#0ea5e9' : '#a855f7',
                    success: '#10b981',
                    warning: '#f59e0b',
                    danger: '#ef4444'
                };
            }
        }

