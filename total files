<script type="text/javascript">
    (function() {
        // ===== CONFIG =====
        var LIST_TITLE = "Partners Dashboard"; // SharePoint list display name
        var ACCESS_CONTROL_LIST = "Dashboard_Access_Control"; // For checking Access of USer
        // Internal field names
        var FIELD_PARTNER = "Title";
