        function getSiteUrl() {
            if (window._spPageContextInfo && _spPageContextInfo.webAbsoluteUrl) {
                return _spPageContextInfo.webAbsoluteUrl.replace(/\/$/, "");
            }
            return location.origin;
        }

        function parseNumber(v) {
            if (v === null || v === undefined || v === "") return 0;
            var n = parseFloat(v);
            return isNaN(n) ? 0 : n;
        }

        function formatCurrency(v) {
            var n = parseNumber(v);
            if (n >= 1000000) return "AED " + (n / 1000000).toFixed(2) + "M";
            if (n >= 1000) return "AED " + (n / 1000).toFixed(1) + "K";
            return "AED " + n.toString().replace(/\B(?=(\d{3})+(?!\d))/g, ",");
        }

        function formatDate(iso) {
            if (!iso) return "-";
            var d = new Date(iso);
            if (isNaN(d)) return "-";
            return d.toLocaleDateString();
        }

        function daysTo(dateIso) {
            if (!dateIso) return null;
            var d = new Date(dateIso);
            if (isNaN(d)) return null;
            var diff = d.getTime() - (new Date()).getTime();
            return Math.floor(diff / (1000 * 60 * 60 * 24));
        }

        function clearChildren(el) {
            if (!el) return;
            while (el.firstChild) el.removeChild(el.firstChild);
        }

        function createCard(options) {
            var card = document.createElement("div");
            card.className = "iptv-card" + (options.extraClass ? " " + options.extraClass : "");
            var header = document.createElement("div");
            header.className = "iptv-card-header";
            header.textContent = options.title || "";
            card.appendChild(header);
            var main = document.createElement("div");
            main.className = "iptv-card-main";
            var left = document.createElement("div");
            var valueEl = document.createElement("div");
            valueEl.className = "iptv-card-value";
            valueEl.textContent = options.value || "";
            var sub = document.createElement("div");
            sub.className = "iptv-card-sub";
            sub.textContent = options.subtitle || "";
            left.appendChild(valueEl);
            left.appendChild(sub);
            main.appendChild(left);
            if (options.badgeText) {
                var chip = document.createElement("div");
                chip.className = "iptv-chip" + (options.badgeClass ? " " + options.badgeClass : "");
                chip.textContent = options.badgeText;
                main.appendChild(chip);
            }
            card.appendChild(main);
            return card;
        }

        // DUMMY DATA GENERATOR (for testing)
        function generateDummyData() {
            var customers = ["Jumeirah Hotels", "Emirates Palace", "Rotana Hotels", "Address Hotels", "Armani Hotel", "Fairmont", "Kempinski", "Sheraton", "Marriott", "Hilton", "Hyatt", "Ritz Carlton", "Four Seasons", "Waldorf Astoria", "St Regis"];
            var products = ["Set-Up Box", "TV Hospitality"];
            var verticals = ["Enterprise", "Hospitality"];
            var managers = ["Ahmed Ali", "Sara Mohammed", "Khalid Hassan", "Fatima Abdullah", "Omar Rashid"];
            var directors = ["Mohamad Amer Sibai", "Humaid Al Ali"];
            var statuses = ["Billed", "Won", "Opportunity"];
            var dummyData = [];

            for (var i = 1; i <= 15; i++) {
                var startDate = new Date(2024, Math.floor(Math.random() * 12), 1);
                var duration = [12, 24, 36][Math.floor(Math.random() * 3)];
                var endDate = new Date(startDate);
                endDate.setMonth(endDate.getMonth() + duration);

                dummyData.push({
                    id: i,
                    accountCode: "ACC" + (1000 + i),
                    product: products[Math.floor(Math.random() * products.length)],
                    customer: customers[Math.floor(Math.random() * customers.length)],
                    vertical: verticals[Math.floor(Math.random() * verticals.length)],
                    am: managers[Math.floor(Math.random() * managers.length)],
                    dir: directors[Math.floor(Math.random() * directors.length)],
                    startDate: startDate.toISOString(),
                    endDate: endDate.toISOString(),
                    duration: duration,
                    otc: Math.floor(Math.random() * 500000) + 100000,
                    status: statuses[Math.floor(Math.random() * statuses.length)]
                });
            }
            return dummyData;
        }

        function buildDashboardCards() {
            var root = document.getElementById("iptv-dashboard-cards");
            clearChildren(root);
            if (!root) return;

            var visibleItems = filterItemsByUserAccess(allItems);
            var activeItems = visibleItems.filter(function(item) {
                return item.status === "Billed" || item.status === "Won" || item.status === "Pending";
            });
            var totalContracts = activeItems.length;
            var totalValue = 0;
            var uniqueCustomers = {};
            for (var i = 0; i < activeItems.length; i++) {
                totalValue += activeItems[i].otc;
                if (activeItems[i].customer) uniqueCustomers[activeItems[i].customer] = true;
            }
            var countOverdue = 0,
                countNext30 = 0;
            for (i = 0; i < activeItems.length; i++) {
                if (!activeItems[i].endDate) continue;
                var d = daysTo(activeItems[i].endDate);
                if (d < 0) {
                    countOverdue++;
                } else if (d >= 0 && d <= 30) {
                    countNext30++;
                }
            }

            root.appendChild(createCard({
                title: "Total Active Contracts",
                value: String(totalContracts),
                subtitle: "Customers: " + Object.keys(uniqueCustomers).length,
                badgeText: "Active",
                badgeClass: "iptv-chip-planned",
                extraClass: "iptv-card-vertical"
            }));

            root.appendChild(createCard({
                title: "Total Contract Value",
                value: formatCurrency(totalValue),
                subtitle: "(approx.)",
                badgeText: "Revenue",
                badgeClass: "iptv-chip-planned",
                extraClass: "iptv-card-vertical"
            }));

            root.appendChild(createCard({
                title: "Overdue Contracts",
                value: String(countOverdue),
                subtitle: "Expired & Need Renewal",
                badgeClass: "iptv-chip-expired",
                badgeText: "Critical",
                extraClass: "iptv-card-vertical"
            }));

            root.appendChild(createCard({
                title: "Expiring in 30 Days",
                value: String(countNext30),
                subtitle: "Urgent Action Required",
                badgeClass: "iptv-chip-urgent",
                badgeText: "High Priority",
                extraClass: "iptv-card-vertical"
            }));

            // Product Summary
            var sectionHeader = document.createElement("div");
            sectionHeader.className = "iptv-section-header";
            sectionHeader.style.gridColumn = "1 / -1";
            sectionHeader.style.marginTop = "24px";
            sectionHeader.innerHTML = "<h2>Contract Type</h2><p>Count and value by Managed TV (STB) and TV Hospitality (Bulk IPTV)</p>";
            root.appendChild(sectionHeader);

            var products = ["Managed TV (STB)", "TV Hospitality (Bulk IPTV)"];
            var stats = {};
            for (i = 0; i < products.length; i++) {
                stats[products[i]] = {
                    count: 0,
                    value: 0
                };
            }

            for (i = 0; i < activeItems.length; i++) {
                var p = activeItems[i].product || "Unassigned";
                // Create stat entry if it doesn't exist
                if (!stats[p]) {
                    stats[p] = {
                        count: 0,
                        value: 0
                    };
                }
                stats[p].count++;
                stats[p].value += activeItems[i].otc;
            }

            var productGrid = document.createElement("div");
            productGrid.style.cssText = "display:grid;grid-template-columns:repeat(2,1fr);gap:10px;grid-column:1 / -1;";
            for (i = 0; i < products.length; i++) {
                var name = products[i];
                var s = stats[name] || {
                    count: 0,
                    value: 0
                };
                productGrid.appendChild(createCard({
                    title: name,
                    value: String(s.count),
                    subtitle: "Active Contracts",
                    badgeText: "Value: " + formatCurrency(s.value),
                    extraClass: "iptv-card-vertical"
                }));
            }
            root.appendChild(productGrid);

            // Status Summary
            var statusHeader = document.createElement("div");
            statusHeader.className = "iptv-section-header";
            statusHeader.style.gridColumn = "1 / -1";
            statusHeader.style.marginTop = "24px";
            statusHeader.innerHTML = "<h2>Status Summary</h2><p>Overview of contract status distribution</p>";
            root.appendChild(statusHeader);

            var statusCounts = {
                Billed: 0,
                Won: 0,
                Pending: 0,
                Proposed: 0,
                Ceased: 0,
                Lost: 0
            };
            for (i = 0; i < visibleItems.length; i++) {
                var st = visibleItems[i].status;
                if (statusCounts.hasOwnProperty(st)) statusCounts[st]++;
            }

            var statusGrid = document.createElement("div");
            statusGrid.style.cssText = "display:grid;grid-template-columns:repeat(5,1fr);gap:10px;grid-column:1 / -1;";

            statusGrid.appendChild(createCard({
                title: "Billed",
                value: String(statusCounts.Billed),
                subtitle: "Active Billing",
                badgeText: "Revenue",
                badgeClass: "iptv-chip-planned",
                extraClass: "iptv-card-vertical"
            }));

            // Count renewed contracts
            var renewedCount = 0;
            for (i = 0; i < visibleItems.length; i++) {
                if (visibleItems[i].status === "Renewed") renewedCount++;
            }

            statusGrid.appendChild(createCard({
                title: "Won",
                value: String(statusCounts.Won),
                subtitle: "Contracts Won",
                badgeText: "Success",
                badgeClass: "iptv-chip-planned",
                extraClass: "iptv-card-vertical"
            }));

            statusGrid.appendChild(createCard({
                title: "Pending",
                value: String(statusCounts.Pending),
                subtitle: "Awaiting Decision",
                badgeText: "In Progress",
                badgeClass: "iptv-chip-urgent",
                extraClass: "iptv-card-vertical"
            }));

            statusGrid.appendChild(createCard({
                title: "Proposed",
                value: String(statusCounts.Proposed),
                subtitle: "Proposals Sent",
                badgeText: "Pipeline",
                badgeClass: "iptv-chip-urgent",
                extraClass: "iptv-card-vertical"
            }));

            statusGrid.appendChild(createCard({
                title: "Lost",
                value: String(statusCounts.Lost),
                subtitle: "Lost Contracts",
                badgeText: "Closed",
                badgeClass: "iptv-chip-expired",
                extraClass: "iptv-card-vertical"
            }));

            statusGrid.appendChild(createCard({
                title: "Ceased",
                value: String(statusCounts.Ceased),
                subtitle: "Terminated",
                badgeText: "Closed",
                badgeClass: "iptv-chip-expired",
                extraClass: "iptv-card-vertical"
            }));

            root.appendChild(statusGrid);
        }

