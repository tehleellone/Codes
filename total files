        // ===== DROPDOWNS =====
        function populateRenewalDropdowns() {
            var accessibleItems = filterItemsByUserAccess(allItems);
            var yearSelect = document.getElementById("pd-ren-year");
            var dirSelect = document.getElementById("pd-ren-dir");
            var managerSelect = document.getElementById("pd-ren-am");
            if (!yearSelect || !dirSelect || !managerSelect) {
                return;
            }
            var selectedYear = yearSelect.value || "";
            var selectedDir = dirSelect.value || "";
            var selectedMgr = managerSelect.value || "";
            // Build director-manager mapping from ALL items
            var directorManagerMap = {}; // director -> [managers]
            var managerDirectorMap = {}; // manager -> director
            for (var i = 0; i < allItems.length; i++) {
                var item = allItems[i];
                var dir = item.dir || "Unassigned";
                var mgr = item.am || "Unassigned";
                if (!directorManagerMap[dir]) {
                    directorManagerMap[dir] = {};
                }
                directorManagerMap[dir][mgr] = true;
                if (!managerDirectorMap[mgr]) {
                    managerDirectorMap[mgr] = dir;
                }
            }
            // Years dropdown (unchanged)
            var yearsMap = {};
            var item, d, y;
            for (i = 0; i < accessibleItems.length; i++) {
                item = accessibleItems[i];
                if (!item.expiry) {
                    continue;
                }
                d = new Date(item.expiry);
                if (isNaN(d)) {
                    continue;
                }
                y = d.getFullYear();
                if (y >= 2000) {
                    yearsMap[y] = true;
                }
            }
            var years = [];
            for (y in yearsMap) {
                if (yearsMap.hasOwnProperty(y)) {
                    years.push(parseInt(y, 10));
                }
            }
            years.sort(function(a, b) {
                return a - b;
            });
            yearSelect.innerHTML = '<option value="">All Years</option>';
            for (i = 0; i < years.length; i++) {
                yearSelect.innerHTML += '<option value="' + years[i] + '">' + years[i] + '</option>';
            }
            yearSelect.value = selectedYear;
            // Directors and Managers based on role and selection
            var dirMap = {};
            var mgrMap = {};
            if (userContext.role === "Admin") {
                // ADMIN MODE
                if (selectedDir) {
                    // Director is selected -> show that director and their managers
                    dirMap[selectedDir] = true;
                    if (directorManagerMap[selectedDir]) {
                        for (var m in directorManagerMap[selectedDir]) {
                            if (directorManagerMap[selectedDir].hasOwnProperty(m)) {
                                mgrMap[m] = true;
                            }
                        }
                    }
                } else if (selectedMgr) {
                    // Manager is selected -> show ONLY their director and that manager
                    mgrMap[selectedMgr] = true;
                    var relatedDir = managerDirectorMap[selectedMgr];
                    if (relatedDir) {
                        dirMap[relatedDir] = true;
                    }
                } else {
                    // Nothing selected -> show ALL directors and managers
                    for (i = 0; i < accessibleItems.length; i++) {
                        item = accessibleItems[i];
                        dirMap[item.dir || "Unassigned"] = true;
                        mgrMap[item.am || "Unassigned"] = true;
                    }
                }
            } else if (userContext.role === "Director") {
                // DIRECTOR MODE - only their name, ALWAYS show all their managers
                dirMap[userContext.directorName] = true;
                // ALWAYS show all managers under this director (don't filter by selectedMgr)
                if (directorManagerMap[userContext.directorName]) {
                    for (var m in directorManagerMap[userContext.directorName]) {
                        if (directorManagerMap[userContext.directorName].hasOwnProperty(m)) {
                            mgrMap[m] = true;
                        }
                    }
                }
            } else if (userContext.role === "Manager") {
                // MANAGER MODE - only their name, only their director
                mgrMap[userContext.userName] = true;
                var theirDir = managerDirectorMap[userContext.userName];
                if (theirDir) {
                    dirMap[theirDir] = true;
                }
            }

            function mapToSortedArray(map) {
                var arr = [];
                for (var k in map) {
                    if (map.hasOwnProperty(k)) {
                        arr.push(k);
                    }
                }
                arr.sort();
                var idx = arr.indexOf("Unassigned");
                if (idx > -1) {
                    arr.splice(idx, 1);
                    arr.unshift("Unassigned");
                }
                return arr;
            }
            var dirs = mapToSortedArray(dirMap);
            var mgrs = mapToSortedArray(mgrMap);
            // Populate Directors dropdown
            dirSelect.innerHTML = '<option value="">All Directors</option>';
            for (i = 0; i < dirs.length; i++) {
                dirSelect.innerHTML += '<option value="' + dirs[i] + '">' + dirs[i] + '</option>';
            }
            // Set selected director
            if (userContext.role === "Director") {
                dirSelect.value = userContext.directorName;
                dirSelect.disabled = true; // Lock it for directors
            } else if (userContext.role === "Manager") {
                // Lock director dropdown for managers too
                var theirDir = managerDirectorMap[userContext.userName];
                if (theirDir) {
                    dirSelect.value = theirDir;
                }
                dirSelect.disabled = true;
            } else {
                // Admin mode: always set the current selection
                dirSelect.value = selectedDir;
                dirSelect.disabled = false;
            }
            // Populate Managers dropdown
            managerSelect.innerHTML = '<option value="">All Managers</option>';
            for (i = 0; i < mgrs.length; i++) {
                managerSelect.innerHTML += '<option value="' + mgrs[i] + '">' + mgrs[i] + '</option>';
            }
            // Set selected manager
            if (userContext.role === "Manager") {
                managerSelect.value = userContext.userName;
                managerSelect.disabled = true; // Lock it for managers
            } else if (mgrs.indexOf(selectedMgr) > -1 || selectedMgr === "") {
                managerSelect.value = selectedMgr;
                managerSelect.disabled = false;
            } else {
                managerSelect.value = "";
                managerSelect.disabled = false;
            }
        }
        // ===== RENEWAL RENDER ======
        function renderRenewalDashboard() {
            var fYear = document.getElementById("pd-ren-year").value;
            var fAM = document.getElementById("pd-ren-am").value;
            var fDir = document.getElementById("pd-ren-dir").value;
            if (!selectedRenewalFilter && !selectedRenewalMonth) {
                selectedRenewalFilter = "all";
            }
            var rawList = [];
            var accessibleItems = filterItemsByUserAccess(allItems);
            var i, it;
            for (i = 0; i < accessibleItems.length; i++) {
                it = accessibleItems[i];
                // Only include Ongoing contracts for renewal tracking
                if (it.expiry && it.status === "Ongoing") {
                    rawList.push(it);
                }
            }
            populateRenewalDropdowns();
            var filtered = [];
            for (i = 0; i < rawList.length; i++) {
                it = rawList[i];
                var d = new Date(it.expiry);
                var y = d.getFullYear().toString();
                if (fYear && y !== fYear) {
                    continue;
                }
                if (fAM) {
                    var itemAM = it.am || "Unassigned";
                    if (itemAM !== fAM) {
                        continue;
                    }
                }
                if (fDir) {
                    var itemDir = it.dir || "Unassigned";
                    if (itemDir !== fDir) {
                        continue;
                    }
                }
                filtered.push(it);
            }
            // Summary cards
            var rootSum = document.getElementById("pd-renewal-summary");
            clearChildren(rootSum);
            var totalVal = 0,
                countOverdue = 0,
                countNext30 = 0;
            for (i = 0; i < filtered.length; i++) {
                it = filtered[i];
                totalVal += it.value;
                var dd = daysTo(it.expiry);
                if (dd < 0) {
                    countOverdue++;
                } else if (dd <= 30) {
                    countNext30++;
                }
            }
            // Count unique partners in filtered data
            var uniquePartnersFiltered = {};
            for (var up = 0; up < filtered.length; up++) {
                if (filtered[up].partner) {
                    uniquePartnersFiltered[filtered[up].partner] = true;
                }
            }
            var card1 = createCard({
                title: "Total Contracts",
                value: String(filtered.length),
                subtitle: "Partners: " + String(Object.keys(uniquePartnersFiltered).length),
                badgeText: "Value: " + formatCurrency(totalVal),
                extraClass: "pd-card-interactive"
            });
            if (selectedRenewalFilter === "all") {
                card1.className += " pd-card-active";
            }
            card1.onclick = function() {
                selectedRenewalFilter = (selectedRenewalFilter === "all") ? null : "all";
                selectedRenewalMonth = null;
                renderRenewalDashboard();
            };
            rootSum.appendChild(card1);
            var card2 = createCard({
                title: "OVERDUE CONTRACTS",
                value: String(countOverdue),
                subtitle: "Expired contracts",
                badgeClass: "pd-chip-expired",
                badgeText: "Action Required",
                extraClass: "pd-card-interactive"
            });
            if (selectedRenewalFilter === "overdue") {
                card2.className += " pd-card-active";
            }
            card2.onclick = function() {
                selectedRenewalFilter = (selectedRenewalFilter === "overdue") ? null : "overdue";
                selectedRenewalMonth = null;
                renderRenewalDashboard();
            };
            rootSum.appendChild(card2);
            var card3 = createCard({
                title: "Expiring In 30 Days",
                value: String(countNext30),
                subtitle: "Urgent Renewals",
                badgeClass: "pd-chip-urgent",
                badgeText: "High Priority",
                extraClass: "pd-card-interactive"
            });
            if (selectedRenewalFilter === "next30") {
                card3.className += " pd-card-active";
            }
            card3.onclick = function() {
                selectedRenewalFilter = (selectedRenewalFilter === "next30") ? null : "next30";
                selectedRenewalMonth = null;
                renderRenewalDashboard();
            };
            rootSum.appendChild(card3);
            // ===== ADD RENEWED & CEASED CARDS (DYNAMIC - respects filters!) =====
            var renewedCount = 0;
            var ceasedCount = 0;
            var renewedValue = 0;
            var ceasedValue = 0;
            // Apply the SAME filters as ongoing contracts
            for (var rc = 0; rc < allItems.length; rc++) {
                var rcItem = allItems[rc];
                // Filter by user access first
                var accessibleCheck = filterItemsByUserAccess([rcItem]);
                if (accessibleCheck.length === 0) continue;
                // Apply year filter (if set)
                if (fYear && rcItem.expiry) {
                    var rcDate = new Date(rcItem.expiry);
                    var rcYear = rcDate.getFullYear().toString();
                    if (rcYear !== fYear) continue;
                }
                // Apply Account Manager filter (if set)
                if (fAM) {
                    var rcAM = rcItem.am || "Unassigned";
                    if (rcAM !== fAM) continue;
                }
                // Apply Director filter (if set)
                if (fDir) {
                    var rcDir = rcItem.dir || "Unassigned";
                    if (rcDir !== fDir) continue;
                }
                // Now count Renewed and Ceased
                if (rcItem.status === "Renewed") {
                    renewedCount++;
                    renewedValue += rcItem.value;
                }
                if (rcItem.status === "Ceased") {
                    ceasedCount++;
                    ceasedValue += rcItem.value;
                }
            }
            var renewedCard = createCard({
                title: "Renewed Contracts",
                value: String(renewedCount),
                subtitle: "Successfully renewed",
                badgeText: "Completed",
                badgeClass: "pd-chip-planned",
                extraClass: "pd-card-interactive"
            });
            if (selectedRenewalFilter === "renewed") {
                renewedCard.className += " pd-card-active";
            }
            renewedCard.onclick = function() {
                selectedRenewalFilter = (selectedRenewalFilter === "renewed") ? null : "renewed";
                selectedRenewalMonth = null;
                renderRenewalDashboard();
            };
            rootSum.appendChild(renewedCard);
            var ceasedCard = createCard({
                title: "Ceased Contracts",
                value: String(ceasedCount),
                subtitle: "No longer active",
                badgeText: "Closed",
                badgeClass: "pd-chip-expired",
                extraClass: "pd-card-interactive"
            });
            if (selectedRenewalFilter === "ceased") {
                ceasedCard.className += " pd-card-active";
            }
            ceasedCard.onclick = function() {
                selectedRenewalFilter = (selectedRenewalFilter === "ceased") ? null : "ceased";
                selectedRenewalMonth = null;
                renderRenewalDashboard();
            };
            rootSum.appendChild(ceasedCard);
            // Month cards
            var monthMap = {};
            for (i = 0; i < filtered.length; i++) {
                it = filtered[i];
                var d2 = new Date(it.expiry);
                var key = d2.getFullYear() + "-" + ("0" + (d2.getMonth() + 1)).slice(-2);
                if (!monthMap[key]) {
                    monthMap[key] = {
                        count: 0,
                        value: 0,
                        date: d2,
                        key: key
                    };
                }
                monthMap[key].count++;
                monthMap[key].value += it.value;
            }
            var keys = [];
            for (var k in monthMap) {
                if (monthMap.hasOwnProperty(k)) {
                    keys.push(k);
                }
            }
            keys.sort();
            var rootMonth = document.getElementById("pd-renewal-month-cards");
            clearChildren(rootMonth);
            for (i = 0; i < keys.length; i++) {
                k = keys[i];
                var m = monthMap[k];
                var monthName = m.date.toLocaleString("default", {
                    month: "long",
                    year: "numeric"
                });
                var now = new Date();
                var monthStart = new Date(m.date.getFullYear(), m.date.getMonth(), 1);
                var currentMonthStart = new Date(now.getFullYear(), now.getMonth(), 1);
                var daysDiff = Math.floor((monthStart - currentMonthStart) / (1000 * 60 * 60 * 24));
                var colorClass = "";
                var badgeClass = "";
                var badgeLabel = "Value: " + formatCurrency(m.value);
                if (daysDiff < 0) {
                    colorClass = "pd-card-danger";
                    badgeClass = "pd-chip-expired";
                    badgeLabel = "Expired";
                } else if (daysDiff <= 90) {
                    colorClass = "pd-card-warning";
                    badgeClass = "pd-chip-urgent";
                    badgeLabel = "Urgent";
                } else {
                    colorClass = "pd-card-safe";
                    badgeClass = "pd-chip-planned";
                    badgeLabel = "Planned";
                }
                var subtitleText = "Contracts expiring";
                if (daysDiff < 0) {
                    subtitleText = "Contracts expired";
                } else if (daysDiff <= 90) {
                    subtitleText = "Urgent renewals";
                }
                (function(keyCopy) {
                    var card = createCard({
                        title: monthName,
                        value: String(m.count),
                        subtitle: subtitleText,
                        badgeText: "Value: " + formatCurrency(m.value),
                        badgeClass: badgeClass,
                        extraClass: "pd-card-interactive " + colorClass
                    });
                    if (selectedRenewalMonth === keyCopy) {
                        card.className += " pd-card-active";
                    }
                    card.onclick = function() {
                        if (selectedRenewalMonth === keyCopy) {
                            selectedRenewalMonth = null;
                        } else {
                            selectedRenewalMonth = keyCopy;
                        }
                        selectedRenewalFilter = null;
                        renderRenewalDashboard();
                    };
                    rootMonth.appendChild(card);
                })(k);
            }
            var searchText = "";
            var searchBox = document.getElementById("pd-renewal-search");
            if (searchBox) {
                searchText = searchBox.value;
            }
            renderRenewalTable(filtered, searchText);
        }

        function renderRenewalTable(dataset, searchText) {
            // RESET ALL HEADERS FIRST - THIS IS CRITICAL!
            // RESET ALL HEADERS FIRST - THIS IS CRITICAL!
            document.getElementById("pdDateHeader1").textContent = "Expiry Date";
            document.getElementById("pdDateHeader2").textContent = "Days Left";
            document.getElementById("pdRenewedDaysHeader").style.display = "none";
            document.getElementById("pdReasonHeader").style.display = "none";
            document.getElementById("pdActionHeader").style.display = ""; // Show by default
            // Show/hide resource column based on role
            var resourceHeader = document.getElementById("pd-resource-header");
            if (resourceHeader) {
                resourceHeader.style.display = (userContext.role === "Admin") ? "" : "none";
            }
            var tbody = document.getElementById("pd-renewal-tbody");
            var titleEl = document.getElementById("pd-ren-table-title");
            clearChildren(tbody);
            if (!tbody) {
                return;
            }
            var finalData = [];
            var i, it;
            // search first
            if (searchText) {
                var term = (searchText || "").toLowerCase();
                for (i = 0; i < dataset.length; i++) {
                    it = dataset[i];
                    var s = (it.partner + " " + it.customer + " " + it.vertical + " " + it.am + " " + it.dir).toLowerCase();
                    if (s.indexOf(term) >= 0) {
                        finalData.push(it);
                    }
                }
            } else {
                finalData = dataset.slice(0);
            }
            // ========== SORT BY URGENCY ==========
            finalData.sort(function(a, b) {
                var daysA = daysTo(a.expiry);
                var daysB = daysTo(b.expiry);
                if (daysA === null) return 1;
                if (daysB === null) return -1;
                var getPriority = function(days) {
                    if (days < 0) return 1;
                    if (days <= 30) return 2;
                    if (days <= 90) return 3;
                    return 4;
                };
                var priorityA = getPriority(daysA);
                var priorityB = getPriority(daysB);
                if (priorityA !== priorityB) {
                    return priorityA - priorityB;
                }
                return daysA - daysB;
            });
            // ========== END SORTING ==========
            if (selectedRenewalFilter === "renewed") {
                // Show ONLY renewed contracts from FILTERED dataset
                var fYear = document.getElementById("pd-ren-year").value;
                var fAM = document.getElementById("pd-ren-am").value;
                var fDir = document.getElementById("pd-ren-dir").value;
                var renewedList = filterItemsByUserAccess(allItems).filter(function(item) {
                    if (item.status !== "Renewed") return false;
                    // Apply year filter
                    if (fYear && item.expiry) {
                        var d = new Date(item.expiry);
                        var y = d.getFullYear().toString();
                        if (y !== fYear) return false;
                    }
                    // Apply AM filter
                    if (fAM) {
                        var itemAM = item.am || "Unassigned";
                        if (itemAM !== fAM) return false;
                    }
                    // Apply Director filter
                    if (fDir) {
                        var itemDir = item.dir || "Unassigned";
                        if (itemDir !== fDir) return false;
                    }
                    return true;
                });
                finalData = renewedList;
                titleEl.innerHTML = "Renewed Contracts";
                document.getElementById("pdDateHeader1").textContent = "Original Expiry";
                document.getElementById("pdDateHeader2").textContent = "Renewed Date";
                document.getElementById("pdRenewedDaysHeader").style.display = "";
                document.getElementById("pdReasonHeader").style.display = "none";
                document.getElementById("pdActionHeader").style.display = "none";
            } else if (selectedRenewalFilter === "ceased") {
                // Show ONLY ceased contracts from FILTERED dataset
                var fYear = document.getElementById("pd-ren-year").value;
                var fAM = document.getElementById("pd-ren-am").value;
                var fDir = document.getElementById("pd-ren-dir").value;
                var ceasedList = filterItemsByUserAccess(allItems).filter(function(item) {
                    if (item.status !== "Ceased") return false;
                    // Apply year filter
                    if (fYear && item.expiry) {
                        var d = new Date(item.expiry);
                        var y = d.getFullYear().toString();
                        if (y !== fYear) return false;
                    }
                    // Apply AM filter
                    if (fAM) {
                        var itemAM = item.am || "Unassigned";
                        if (itemAM !== fAM) return false;
                    }
                    // Apply Director filter
                    if (fDir) {
                        var itemDir = item.dir || "Unassigned";
                        if (itemDir !== fDir) return false;
                    }
                    return true;
                });
                finalData = ceasedList;
                titleEl.innerHTML = "Ceased Contracts";
                document.getElementById("pdDateHeader1").textContent = "Original Expiry";
                document.getElementById("pdDateHeader2").textContent = "Ceased Date";
                document.getElementById("pdReasonHeader").style.display = "";
                document.getElementById("pdActionHeader").style.display = "none";
            } else if (selectedRenewalFilter === "overdue") {
                var tmp = [];
                for (i = 0; i < finalData.length; i++) {
                    it = finalData[i];
                    if (daysTo(it.expiry) < 0) {
                        tmp.push(it);
                    }
                }
                finalData = tmp;
                titleEl.innerHTML = "Critical / Overdue Contracts";
            } else if (selectedRenewalFilter === "next30") {
                tmp = [];
                for (i = 0; i < finalData.length; i++) {
                    it = finalData[i];
                    var d = daysTo(it.expiry);
                    if (d >= 0 && d <= 30) {
                        tmp.push(it);
                    }
                }
                finalData = tmp;
                titleEl.innerHTML = "Expiring in Next 30 Days";
            } else if (selectedRenewalFilter === "all") {
                titleEl.innerHTML = "All Filtered Contracts";
            } else {
