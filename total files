    [{k:'tcv',l:'TCV'},{k:'mrc',l:'MRC'},{k:'otc',l:'OTC'},{k:'pcv',l:'Catelog MRC'}];
  const now=new Date();
  let labels=[];
  const getVal=(b,k)=>k==='tcv'?b.tcv:k==='mrc'?b.mrc:k==='otc'?b.otc:k==='pcv'?b.pcv:b.gaPoints;
  const periods=trendPeriod==='W'?12:trendPeriod==='M'?12:trendPeriod==='Q'?8:5;
  const getBucket=(rd)=>{
    const d=new Date(rd);
    if(trendPeriod==='W') return d.getFullYear()+'-W'+String(getWeekOfYear(d)).padStart(2,'0');
    if(trendPeriod==='M') return d.getFullYear()+'-'+String(d.getMonth()+1).padStart(2,'0');
    if(trendPeriod==='Q') return d.getFullYear()+'-Q'+Math.ceil((d.getMonth()+1)/3);
    return String(d.getFullYear());
  };
  const buckets=[];
  for(let i=periods-1;i>=0;i--){
    let label,bucket;
    if(trendPeriod==='W'){
      const d=new Date(now);d.setDate(d.getDate()-i*7);
      bucket=d.getFullYear()+'-W'+String(getWeekOfYear(d)).padStart(2,'0');
      label='W'+getWeekOfYear(d);
    } else if(trendPeriod==='M'){
      const d=new Date(now.getFullYear(),now.getMonth()-i,1);
      bucket=d.getFullYear()+'-'+String(d.getMonth()+1).padStart(2,'0');
      label=d.toLocaleDateString('en-US',{month:'short',year:'2-digit'});
    } else if(trendPeriod==='Q'){
      const totalQ=now.getFullYear()*4+Math.ceil((now.getMonth()+1)/3)-1-i;
      const yr=Math.floor(totalQ/4);
      const q=(totalQ%4)+1;
      bucket=yr+'-Q'+q;
      label='Q'+q+' '+String(yr).slice(2);
    } else {
      const yr=now.getFullYear()-i;
      bucket=String(yr);label=String(yr);
