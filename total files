function loadData(){
  const select=[
    'Id','Title','Type_x0020_of_x0020_Request','Type_x0020_of_x0020_Contract',
    'Segment','Account_x0020_Director','Solution_x0020_Manager','Head_x0020_Director',
    'Product_x0020_Family','Product_x0020_Category','Services','Gross_x0020_Adds',
    'Monthly_x0020_Recurring_x0020_Ch','One_x0020_Time_x0020_Charges_x00',
    'Contract_x0020_Duration','Total_x0020_Contact_x0020_Value_','Opportunity_x0020_Status',
    'Closure_x0020_Probability','Expected_x0020_Contract_x0020_Si','Actual_x0020_Contract_x0020_Sign',
    'Proposed_x0020_Date','No_x0020_Bid_x002f_Lost_x002f_Ca','BilledDate','Lost_x0020_Reason',
    'CustomerCode','Complexity','BidManager','ProjectManager0','field5','field8',
    'group/Title','group/EMail'
  ].join(',');

  const cutoff=new Date('2025-01-01T00:00:00Z');
  let allResults=[];

  function fetchPage(url){
    spGet(url,function(err,data){
      if(err){
        console.error('Data load error:',err);
        ALL_BIDS=[];
        remapBlankHD();
        buildFilters();
        applyAll();
        return;
      }
      allResults=allResults.concat(data.d.results);
      console.log('[GLK] Fetched so far:',allResults.length);
      if(data.d.__next){
        fetchPage(data.d.__next);
      } else {
        console.log('[GLK] All records loaded:',allResults.length);
        ALL_BIDS=allResults.map(mapItem).filter(function(bid){
          const rd=getRelevantDate(bid); if(!rd) return false;
          const d=new Date(rd); return !isNaN(d)&&d>=cutoff;
        });
        remapBlankHD();
        buildFilters();
        applyAll();
      }
    });
  }

  const firstUrl=SP_SITE+
    "/_api/web/lists/getbytitle('"+SP_LIST+"')/items"+
    "?$select="+encodeURIComponent(select)+
    "&$expand=group"+
    "&$filter=Expected_x0020_Contract_x0020_Si ge '2025-01-01T00:00:00Z' or "+
    "Actual_x0020_Contract_x0020_Sign ge '2025-01-01T00:00:00Z' or "+
    "Proposed_x0020_Date ge '2025-01-01T00:00:00Z' or "+
    "No_x0020_Bid_x002f_Lost_x002f_Ca ge '2025-01-01T00:00:00Z' or "+
    "BilledDate ge '2025-01-01T00:00:00Z'"+
    "&$top=5000&$orderby=Id asc";

  fetchPage(firstUrl);
}function mapItem(it){
  return {
    id:it.Id,customerName:it.Title||'—',typeOfRequest:it.Type_x0020_of_x0020_Request||'—',
    typeOfContract:it.Type_x0020_of_x0020_Contract||'—',vertical:it.Segment||'—',
    accountDirector:it.Account_x0020_Director||'—',solutionManager:it.Solution_x0020_Manager||'—',
   headDirector:it.Head_x0020_Director||'(Blank)',productFamily:it.Product_x0020_Family||'—',
    productCategory:it.Product_x0020_Category||'—',services:it.Services||'—',
    gaPoints:num(it.Gross_x0020_Adds),mrc:num(it.Monthly_x0020_Recurring_x0020_Ch),
    otc:num(it.One_x0020_Time_x0020_Charges_x00),duration:it.Contract_x0020_Duration||'—',
    tcv:num(it.Total_x0020_Contact_x0020_Value_),status:it.Opportunity_x0020_Status||'—',
    closureProb:it.Closure_x0020_Probability||'—',
    expectedActivation:it.Expected_x0020_Contract_x0020_Si||null,
    contractSigned:it.Actual_x0020_Contract_x0020_Sign||null,
    proposedDate:it.Proposed_x0020_Date||null,lostDate:it.No_x0020_Bid_x002f_Lost_x002f_Ca||null,
    billedDate:it.BilledDate||null,lostReason:it.Lost_x0020_Reason||'—',
    customerCode:it.CustomerCode||'—',complexity:it.Complexity||'—',
    bidManager:it.BidManager||'—',projectManager:it.ProjectManager0||'—',
    pcv:num(it.field5),prepaidPostpaid:it.field8||'—',
    amName:it.group?(it.group.Title||'—'):'—',amEmail:it.group?(it.group.EMail||''):'',
  };
}

