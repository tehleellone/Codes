        function createCard(options) {
            var card = document.createElement("div");
            card.className = "pd-card" + (options.extraClass ? " " + options.extraClass : "");
            var header = document.createElement("div");
            header.className = "pd-card-header";
            header.appendChild(document.createTextNode(options.title || ""));
            card.appendChild(header);
            var main = document.createElement("div");
            main.className = "pd-card-main";
            var left = document.createElement("div");
            var valueEl = document.createElement("div");
            valueEl.className = "pd-card-value";
            valueEl.appendChild(document.createTextNode(options.value || ""));
            var sub = document.createElement("div");
            sub.className = "pd-card-sub";
            sub.appendChild(document.createTextNode(options.subtitle || ""));
            left.appendChild(valueEl);
            left.appendChild(sub);
            main.appendChild(left);
            if (options.badgeText) {
                var chip = document.createElement("div");
                chip.className = "pd-chip" + (options.badgeClass ? " " + options.badgeClass : "");
                chip.appendChild(document.createTextNode(options.badgeText));
                main.appendChild(chip);
            }
            card.appendChild(main);
            return card;
