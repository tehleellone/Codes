        function populateRenewalDropdowns() {
            // Similar logic to Partners Dashboard - implementing based on role
            var accessibleItems = filterItemsByUserAccess(allItems);
            var yearSelect = document.getElementById("iptv-ren-year");
            var dirSelect = document.getElementById("iptv-ren-dir");
            var managerSelect = document.getElementById("iptv-ren-am");

            if (!yearSelect || !dirSelect || !managerSelect) return;

            var selectedYear = yearSelect.value || "";
            var selectedDir = dirSelect.value || "";
            var selectedMgr = managerSelect.value || "";

            // Build director-manager mapping
            var directorManagerMap = {};
            var managerDirectorMap = {};
            for (var i = 0; i < allItems.length; i++) {
                var item = allItems[i];
                var dir = item.dir || "Unassigned";
                var mgr = item.am || "Unassigned";
                if (!directorManagerMap[dir]) directorManagerMap[dir] = {};
                directorManagerMap[dir][mgr] = true;
                if (!managerDirectorMap[mgr]) managerDirectorMap[mgr] = dir;
            }

            // Years dropdown
            var yearsMap = {};
            for (i = 0; i < accessibleItems.length; i++) {
                item = accessibleItems[i];
                if (!item.startDate) continue;
                var d = new Date(item.startDate);
                if (isNaN(d)) continue;
                var y = d.getFullYear();
                if (y >= 2000) yearsMap[y] = true;
            }
            var years = [];
            for (var year in yearsMap) {
                if (yearsMap.hasOwnProperty(year)) years.push(parseInt(year, 10));
            }
            years.sort(function(a, b) {
                return a - b;
            });

            yearSelect.innerHTML = '<option value="">All Years</option>';
            for (i = 0; i < years.length; i++) {
                yearSelect.innerHTML += '<option value="' + years[i] + '">' + years[i] + '</option>';
            }
            yearSelect.value = selectedYear;

            // Directors and Managers based on role
            var dirMap = {};
            var mgrMap = {};

            if (userContext.role === "Admin") {
                if (selectedDir) {
                    dirMap[selectedDir] = true;
                    if (directorManagerMap[selectedDir]) {
                        for (var m in directorManagerMap[selectedDir]) {
                            if (directorManagerMap[selectedDir].hasOwnProperty(m)) mgrMap[m] = true;
                        }
                    }
                } else if (selectedMgr) {
                    mgrMap[selectedMgr] = true;
                    var relatedDir = managerDirectorMap[selectedMgr];
                    if (relatedDir) dirMap[relatedDir] = true;
                } else {
                    for (i = 0; i < accessibleItems.length; i++) {
                        item = accessibleItems[i];
                        dirMap[item.dir || "Unassigned"] = true;
                        mgrMap[item.am || "Unassigned"] = true;
                    }
                }
            } else if (userContext.role === "Director") {
                dirMap[userContext.directorName] = true;
                if (directorManagerMap[userContext.directorName]) {
                    for (var m in directorManagerMap[userContext.directorName]) {
                        if (directorManagerMap[userContext.directorName].hasOwnProperty(m)) mgrMap[m] = true;
                    }
                }
            } else if (userContext.role === "Manager") {
                mgrMap[userContext.userName] = true;
                var theirDir = managerDirectorMap[userContext.userName];
                if (theirDir) dirMap[theirDir] = true;
            }

            function mapToSortedArray(map) {
                var arr = [];
                for (var k in map) {
                    if (map.hasOwnProperty(k)) arr.push(k);
                }
                arr.sort();
                var idx = arr.indexOf("Unassigned");
                if (idx > -1) {
                    arr.splice(idx, 1);
                    arr.unshift("Unassigned");
                }
                return arr;
            }

            var dirs = mapToSortedArray(dirMap);
            var mgrs = mapToSortedArray(mgrMap);

            dirSelect.innerHTML = '<option value="">All Directors</option>';
            for (i = 0; i < dirs.length; i++) {
                dirSelect.innerHTML += '<option value="' + dirs[i] + '">' + dirs[i] + '</option>';
            }

            if (userContext.role === "Director") {
                dirSelect.value = userContext.directorName;
                dirSelect.disabled = true;
            } else if (userContext.role === "Manager") {
                var theirDir = managerDirectorMap[userContext.userName];
                if (theirDir) dirSelect.value = theirDir;
                dirSelect.disabled = true;
            } else {
                dirSelect.value = selectedDir;
                dirSelect.disabled = false;
            }

            managerSelect.innerHTML = '<option value="">All Managers</option>';
            for (i = 0; i < mgrs.length; i++) {
                managerSelect.innerHTML += '<option value="' + mgrs[i] + '">' + mgrs[i] + '</option>';
            }

            if (userContext.role === "Manager") {
                managerSelect.value = userContext.userName;
                managerSelect.disabled = true;
            } else if (mgrs.indexOf(selectedMgr) > -1 || selectedMgr === "") {
                managerSelect.value = selectedMgr;
                managerSelect.disabled = false;
            } else {
                managerSelect.value = "";
                managerSelect.disabled = false;
            }
        }

