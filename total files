.overdue-banner span { font-size: 12px; color: #991B1B; font-weight: 600; flex: 1; }
.ob-btn { font-size: 11px; font-weight: 700; color: #EF4444; background: none; border: 1px solid #FECACA; border-radius: 5px; padding: 3px 8px; cursor: pointer; }
.ob-btn:hover { background: #FEE2E2; }

/* ── TOAST ────────────────────────────────────────── */
#toast {
  position: fixed; bottom: 20px; right: 20px;
  background: var(--text-primary); color: #fff;
  padding: 9px 15px; border-radius: 8px; font-size: 12px; font-weight: 600;
