/* MS HELPERS */
function unique(arr) {
  var seen = {}, out = [];
  arr.forEach(function(v){ if (v && !seen[v]) { seen[v] = 1; out.push(v); } });
  return out;
}
function escapeHtml(s) { return String(s||'').replace(/[&<>"']/g, function(c){ return ({'&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;',"'":'&#39;'})[c]; }); }
function escapeAttr(s) { return escapeHtml(s).replace(/'/g,'&#39;'); }

