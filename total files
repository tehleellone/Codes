            }
            return name[0].toUpperCase();
        }

        // ===== ACCESS CONTROL =====
        function loadUserAccess(callback) {
            const siteUrl = SP_URL;

            const xhrUser = new XMLHttpRequest();
            xhrUser.open('GET', siteUrl + '/_api/web/currentuser?$select=Title,Email', true);
            xhrUser.setRequestHeader('Accept', 'application/json;odata=verbose');
            xhrUser.onreadystatechange = function() {
                if (xhrUser.readyState !== 4) return;
                if (xhrUser.status >= 200 && xhrUser.status < 300) {
                    const currentUser = JSON.parse(xhrUser.responseText).d;
                    const userEmail = currentUser.Email;
                    const userName = currentUser.Title;

                    USER_CONTEXT.userEmail = userEmail;
                    USER_CONTEXT.userName = userName;

                    fetchAccessControl(userEmail, userName, callback);
                } else {
                    console.error('Error loading current user');
                    callback(false);
                }
            };
            xhrUser.send();
        }

        function fetchAccessControl(userEmail, userName, callback) {
            const siteUrl = SP_URL;
            const listName = SP_ACCESS_LIST;

            const url = siteUrl + "/_api/web/lists/getbytitle('" + listName + "')/items" +
                "?$select=UserEmailID,Role" +
                "&$filter=UserEmailID eq '" + userEmail + "'";

            const xhr = new XMLHttpRequest();
            xhr.open('GET', url, true);
            xhr.setRequestHeader('Accept', 'application/json;odata=verbose');

            xhr.onreadystatechange = function() {
                if (xhr.readyState !== 4) return;

                if (xhr.status >= 200 && xhr.status < 300) {
                    try {
                        const json = JSON.parse(xhr.responseText);
                        const items = json.d.results;

                        if (items.length > 0) {
                            const accessRecord = items[0];
                            const role = accessRecord.Role || 'Viewer';

                            USER_CONTEXT.role = role;
                            USER_CONTEXT.isActive = true;
                            USER_CONTEXT.isAdmin = (role === 'Admin');

                            localStorage.setItem('glk_user_email', userEmail);
                            localStorage.setItem('glk_user_name', userName);
                            localStorage.setItem('glk_user_role', role);

                            console.log('[OK] Access granted:', userEmail, '| Role:', role);
                            callback(true);
                        } else {
                            // User not found in access list - DENY ACCESS
                            console.warn('[DENIED] User not in access list:', userEmail);
                            USER_CONTEXT.role = 'none';
                            USER_CONTEXT.isActive = false;
                            USER_CONTEXT.isAdmin = false;
                            callback(false);
                        }
                    } catch (error) {
                        console.error('Error parsing access control data:', error);
                        callback(false);
                    }
                } else {
                    console.error('Error loading access control. Status:', xhr.status);
                    callback(false);
                }
            };

            xhr.onerror = function() {
                console.error('Network error loading access control');
                callback(false);
            };

            xhr.send();
        }
