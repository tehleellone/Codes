        // ===== LOAD DATA FROM SHAREPOINT =====
        function loadData() {
            var siteUrl = getSiteUrl();
            var safeTitle = LIST_TITLE.replace(/'/g, "''"); // escape single quotes
            var url = siteUrl +
                "/_api/web/lists/getbytitle('" + safeTitle + "')/items" +
                "?$select=Id," +
                FIELD_PARTNER + "," +
                FIELD_CUSTOMER + "," +
                FIELD_VERTICAL + "," +
                FIELD_VALUE + "," +
                FIELD_EXPIRY + "," +
                FIELD_STATUS + "," +
                FIELD_RENEWED_DATE + "," +
                FIELD_CEASED_DATE + "," +
                FIELD_CEASED_REASON + "," +
                FIELD_AM + "/Title," +
                FIELD_DIR + "/Title" +
                "&$expand=" + FIELD_AM + "," + FIELD_DIR +
                "&$top=5000";
            var xhr = new XMLHttpRequest();
            xhr.open("GET", url, true);
            xhr.setRequestHeader("Accept", "application/json;odata=verbose");
            xhr.onreadystatechange = function() {
                if (xhr.readyState !== 4) {
                    return;
                }
                if (xhr.status >= 200 && xhr.status < 300) {
                    try {
                        var json = JSON.parse(xhr.responseText);
                        var rows = (json.d && json.d.results) ? json.d.results : [];
                        var i, r;
                        allItems = [];
                        for (i = 0; i < rows.length; i++) {
                            r = rows[i];
                            allItems.push({
                                id: r.Id,
                                partner: r[FIELD_PARTNER],
                                customer: r[FIELD_CUSTOMER],
                                vertical: r[FIELD_VERTICAL],
                                am: (r[FIELD_AM] && r[FIELD_AM].Title) ? r[FIELD_AM].Title : "",
                                dir: (r[FIELD_DIR] && r[FIELD_DIR].Title) ? r[FIELD_DIR].Title : "",
                                expiry: r[FIELD_EXPIRY],
                                value: parseNumber(r[FIELD_VALUE]),
                                status: r[FIELD_STATUS] || "",
                                renewedDate: r[FIELD_RENEWED_DATE] || null,
                                ceasedDate: r[FIELD_CEASED_DATE] || null,
                                ceasedReason: r[FIELD_CEASED_REASON] || "",
                                resources: 0
                            });
                        }
                        // Only render if user has access
                        if (userContext.isActive) {
                            buildDashboardCards();
                            renderRenewalDashboard();
                        } else {
                            showAccessDenied();
                        }
                    } catch (e) {
                        if (window.console) {
                            console.error("Error parsing Partners Dashboard data", e);
                        }
                    }
                } else {
                    if (window.console) {
                        console.error("Error loading Partners Dashboard:", xhr.status, xhr.responseText);
                    }
                }
            };
            xhr.send();
        }
