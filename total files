        // ===== SUMMARY CARDS =====
        function buildDashboardCards() {
            var root = document.getElementById("pd-dashboard-cards");
            clearChildren(root);
            if (!root) {
                return;
            }
            var visibleItems = filterItemsByUserAccess(allItems);
            // Filter to show only Ongoing contracts
            var ongoingItems = visibleItems.filter(function(item) {
                return item.status === "Ongoing";
            });
            var totalContracts = ongoingItems.length;
            var totalValue = 0;
            var uniquePartners = {};
            var i, it;
            for (i = 0; i < ongoingItems.length; i++) {
                it = ongoingItems[i];
                totalValue += it.value;
                if (it.partner) {
                    uniquePartners[it.partner] = true;
                }
            }
            var countOverdue = 0;
            var countNext30 = 0;
            for (i = 0; i < ongoingItems.length; i++) {
                it = ongoingItems[i];
                if (!it.expiry) {
                    continue;
                }
                var d = daysTo(it.expiry);
                if (d < 0) {
                    countOverdue++;
                } else if (d >= 0 && d <= 30) {
                    countNext30++;
                }
            }
            // Tiles
            root.appendChild(createCard({
                title: "Total Contracts",
                value: String(totalContracts),
                subtitle: "Partners: " + String(Object.keys(uniquePartners).length),
                badgeText: "Active",
                badgeClass: "pd-chip-planned",
                extraClass: "pd-card-vertical"
            }));
            root.appendChild(createCard({
                title: "Total PO Value",
                value: formatCurrency(totalValue),
                subtitle: "(approx.)",
                badgeText: "Active",
                badgeClass: "pd-chip-planned",
                extraClass: "pd-card-vertical"
