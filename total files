  const email=(document.getElementById('vaEmailInput').value||'').trim();
  const roleOv=document.getElementById('vaRoleOverride').value;
  if(!email){document.getElementById('vaLog').innerHTML='⚠ Enter an email';return;}

  document.getElementById('vaLog').innerHTML='⏳ Looking up '+email+'...';
  if(!_realUser) _realUser={email:USER.email,name:USER.name,role:USER.role};

  // Step 1: Get real display name from SharePoint
  spGet(SP_SITE+"/_api/web/siteusers?$filter=Email eq '"+email+"'&$select=Title,Email",
    function(err,userData){
      const resolvedName=(!err&&userData.d.results.length)
        ?userData.d.results[0].Title
        :email.split('@')[0].replace(/\./g,' ').replace(/\b\w/g,c=>c.toUpperCase());

      // Step 2: Get role from access list
      spGet(SP_SITE+"/_api/web/lists/getbytitle('"+SP_ACCESS+"')/items?$select=UserEmailID,Role&$filter=UserEmailID eq '"+email+"'",
        function(err2,data){
          let role=roleOv;
          if(!err2&&data.d.results.length){
            role=(data.d.results[0].Role||'').trim();
            document.getElementById('vaLog').innerHTML='✓ Found: '+resolvedName+' · '+role;
          } else if(!role){
            document.getElementById('vaLog').innerHTML='⚠ Not in access list. Select role manually.';
            return;
          }

          USER.email=email;
          USER.name=resolvedName;
          USER.role=role;

          el('dashboardContent').style.cssText='display:none!important';
          el('landingPage').style.cssText='display:flex!important';
          el('lAvatar').textContent=getInitials(resolvedName);
          set('lName',resolvedName);
          set('lEmail',email);
          set('lRole',role+' (Spoofed)');
          set('lVisits',getVisitCount());
          set('lLastVisit',getLastVisit());

          const btn=el('launchBtn');
          btn.disabled=false;
          btn.innerHTML='<span class="btn-icon"><svg viewBox="0 0 24 24"><rect x="3" y="3" width="7" height="7"/><rect x="14" y="3" width="7" height="7"/><rect x="14" y="14" width="7" height="7"/><rect x="3" y="14" width="7" height="7"/></svg></span><span class="btn-text">Launch as '+resolvedName+'</span><span class="btn-shine"></span>';
          btn.onclick=function(){glkLaunchSpoofed();};
          el('accessNote').innerHTML='<svg viewBox="0 0 24 24" style="width:14px;height:14px;stroke:#f97316;fill:none;stroke-width:2"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg><span style="color:#f97316;font-weight:600;">👁 Spoofed as '+resolvedName+'</span>';
          document.getElementById('vaLog').innerHTML='✓ Ready. Click Launch to enter as '+resolvedName+' ('+role+')';
        }
      );
    }
  );
