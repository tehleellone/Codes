                for (i = 0; i < dataset.length; i++) {
                    it = dataset[i];
                    var s = (it.accountCode + " " + it.customer + " " + it.product + " " + it.am + " " + it.dir).toLowerCase();
                    if (s.indexOf(term) >= 0) finalData.push(it);
                }
            } else {
                finalData = dataset.slice(0);
            }

            // Sort by urgency
            finalData.sort(function(a, b) {
                var daysA = daysTo(a.endDate);
                var daysB = daysTo(b.endDate);
                if (daysA === null) return 1;
                if (daysB === null) return -1;
                var getPriority = function(days) {
                    if (days < 0) return 1;
                    if (days <= 30) return 2;
                    if (days <= 90) return 3;
                    return 4;
                };
                var priorityA = getPriority(daysA);
                var priorityB = getPriority(daysB);
                if (priorityA !== priorityB) return priorityA - priorityB;
                return daysA - daysB;
            });
