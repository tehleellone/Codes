        function sendContractReminder(contract) {
            var daysLeft = daysTo(contract.endDate);
            var urgencyLevel = "";
            var actionText = "";

            if (daysLeft < 0) {
                urgencyLevel = "⚠️ CRITICAL - EXPIRED";
                actionText = "IMMEDIATE RENEWAL REQUIRED";
            } else if (daysLeft <= 7) {
                urgencyLevel = "🔴 URGENT - Expiring in " + daysLeft + " days";
                actionText = "URGENT ACTION NEEDED";
            } else if (daysLeft <= 30) {
                urgencyLevel = "🟡 HIGH PRIORITY - Expiring in " + daysLeft + " days";
                actionText = "Renewal process should begin";
            } else {
                urgencyLevel = "🟢 REMINDER - Expiring in " + daysLeft + " days";
                actionText = "Plan renewal activities";
            }

            var fromEmail = userContext.userEmail;
            var toEmail = "";
            var ccEmail = "";

            if (userContext.role === "Admin") {
                var dirEmail = contract.dir || "";
                var amEmail = contract.am || "";

                if (!dirEmail && !amEmail) {
                    alert("⚠️ Cannot send email: This contract has no Director or Account Manager assigned.");
                    return;
                }

                toEmail = dirEmail || amEmail;
                if (dirEmail && amEmail) {
                    ccEmail = amEmail;
                } else {
                    ccEmail = fromEmail;
                }
            } else if (userContext.role === "Director") {
                var amEmail = contract.am || "";

                if (!amEmail) {
                    alert("⚠️ Cannot send email: This contract has no Account Manager assigned.");
                    return;
                }

                toEmail = amEmail;
                ccEmail = fromEmail;
            }

            var subject = urgencyLevel + " | Contract Renewal: " + contract.accountCode + " - " + contract.customer;

            // Build FORMATTED email body (matching Partners Dashboard)
            var body = "";
            body += "═══════════════════════════════════\n";
            body += "   CONTRACT RENEWAL ALERT\n";
            body += "═══════════════════════════════════\n\n";

            if (userContext.role === "Admin") {
                body += "Dear " + contract.dir + ",\n\n";
            } else if (userContext.role === "Director") {
                body += "Dear " + contract.am + ",\n\n";
            }

            body += "⚠️ " + urgencyLevel + "\n";
            body += "➤ " + actionText + "\n\n";

            if (daysLeft < 0) {
                body += "❌ EXPIRED " + Math.abs(daysLeft) + " days ago\n\n";
            } else {
                body += "⏰ " + daysLeft + " days until expiry\n\n";
            }

            body += "CONTRACT DETAILS:\n";
            body += "Account: " + contract.accountCode + "\n";
            body += "Customer: " + contract.customer + "\n";
            body += "Product: " + contract.product + "\n";
            body += "Value: " + formatCurrency(contract.otc) + "\n";
            body += "Expiry: " + formatDate(contract.endDate) + "\n";
            body += "AM: " + contract.am + "\n";
            body += "Director: " + contract.dir + "\n\n";

            body += "Best Regards,";

            body = encodeURIComponent(body);

            var mailtoLink = "mailto:" + toEmail;
            if (ccEmail) {
                mailtoLink += "?cc=" + ccEmail;
                mailtoLink += "&subject=" + encodeURIComponent(subject);
                mailtoLink += "&body=" + body;
            } else {
                mailtoLink += "?subject=" + encodeURIComponent(subject);
                mailtoLink += "&body=" + body;
            }

            window.location.href = mailtoLink;
        }

        function loadUserAccess(callback) {
            var siteUrl = getSiteUrl();
            var xhrUser = new XMLHttpRequest();
            xhrUser.open("GET", siteUrl + "/_api/web/currentuser?$select=Title,Email", true);
            xhrUser.setRequestHeader("Accept", "application/json;odata=verbose");
            xhrUser.onreadystatechange = function() {
                if (xhrUser.readyState !== 4) return;
                if (xhrUser.status >= 200 && xhrUser.status < 300) {
                    var currentUser = JSON.parse(xhrUser.responseText).d;
                    var userEmail = currentUser.Email;
                    var userName = currentUser.Title;
                    fetchAccessControl(userEmail, userName, callback);
                }
            };
            xhrUser.send();
        }

        function fetchAccessControl(userEmail, userName, callback) {
            var siteUrl = getSiteUrl();
            var safeListTitle = ACCESS_CONTROL_LIST.replace(/'/g, "''");
            var url = siteUrl +
                "/_api/web/lists/getbytitle('" + safeListTitle + "')/items" +
                "?$select=Title,UserEmail,Role,DirectorName,IsActive" +
                "&$filter=UserEmail eq '" + userEmail + "' and IsActive eq 1" +
                "&$top=1";
            var xhr = new XMLHttpRequest();
            xhr.open("GET", url, true);
            xhr.setRequestHeader("Accept", "application/json;odata=verbose");
            xhr.onreadystatechange = function() {
                if (xhr.readyState !== 4) return;
                if (xhr.status >= 200 && xhr.status < 300) {
                    var json = JSON.parse(xhr.responseText);
                    var results = (json.d && json.d.results) ? json.d.results : [];
                    if (results.length > 0) {
                        var accessRecord = results[0];
                        userContext.userName = userName;
                        userContext.userEmail = userEmail;
                        userContext.role = accessRecord.Role;
                        userContext.directorName = accessRecord.DirectorName || "";
                        userContext.isActive = true;
                        callback(true);
                    } else {
                        userContext.userName = userName;
                        userContext.userEmail = userEmail;
                        userContext.role = "none";
                        userContext.isActive = false;
                        callback(false);
                    }
                } else {
                    console.error("Error loading access control");
                    callback(false);
                }
            };
            xhr.send();
        }

        function filterItemsByUserAccess(items) {
            if (!userContext.isActive || userContext.role === "none") return [];
            if (userContext.role === "Admin") return items;
            if (userContext.role === "Director") {
                return items.filter(function(item) {
                    var itemDirector = item.dir || "Unassigned";
                    return itemDirector === userContext.directorName;
                });
            }
            if (userContext.role === "Manager") {
                return items.filter(function(item) {
                    var itemManager = item.am || "Unassigned";
                    return itemManager === userContext.userName;
                });
            }
            return [];
        }

