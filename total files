        function applyFilters() {
            const teams = getCheckedValues('teamDropdown');
            const managers = getCheckedValues('solutionMgrDropdown');
            const verticals = getCheckedValues('verticalDropdown');
            const complexities = getCheckedValues('complexityDropdown');
            const statuses = getCheckedValues('statusDropdown');
            const years = getCheckedValues('yearDropdown');
            const quarters = getCheckedValues('quarterDropdown');
            const months = getCheckedValues('monthDropdown');
            const weeks = getCheckedValues('weekDropdown');

            filteredBids = ALL_BIDS.filter(bid => {
                if (viewMode === 'assignment' && !bid.solutionAssignedDate) return false;

                const relevantDate = viewMode === 'assignment' ?
                    bid.solutionAssignedDate : getRelevantDateForBid(bid);
                const bidDate = new Date(relevantDate);
                const bidYear = String(bidDate.getFullYear());
                const bidMonth = String(bidDate.getMonth());
                const bidQuarter = getQuarter(relevantDate);
                const bidWeek = String(getWeekOfYear(relevantDate));

                const managerIndex = ALLOWED_ARCHITECTS.indexOf(bid.solutionManager);
                const bidTeam = managerIndex < 4 ? 'Team Blue' : 'Team Purple';

                if (selectedArchitect && bid.solutionManager !== selectedArchitect) return false;
                if (teams.length > 0 && !teams.includes(bidTeam)) return false;
                if (managers.length > 0 && !managers.includes(bid.solutionManager)) return false;
                if (verticals.length > 0 && !verticals.includes(bid.vertical)) return false;
                if (statuses.length > 0 && !statuses.includes(bid.status)) return false;
                if (complexities.length > 0 && !complexities.includes(bid.complexity)) return false;
                if (years.length > 0 && !years.includes(bidYear)) return false;
                if (quarters.length > 0 && !quarters.includes(bidQuarter)) return false;
                if (months.length > 0 && !months.includes(bidMonth)) return false;
                if (weeks.length > 0 && !weeks.includes(bidWeek)) return false;
                return true;
            });

            if (viewMode === 'status') {
                updateTopStats();
            } else {
                updateAssignmentStats();
            }
