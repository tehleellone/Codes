        function setCurrentDate() {
            const now = new Date();
            const options = {
                weekday: 'long',
                year: 'numeric',
                month: 'long',
                day: 'numeric'
            };
            document.getElementById('currentDate').textContent = now.toLocaleDateString('en-US', options);
        }

        function buildCheckboxDropdown(dropdownId, values, filterKey, labelText) {
            const dropdown = document.getElementById(dropdownId);
            if (!dropdown) return;
            dropdown.innerHTML = '';
            values.forEach(function(v) {
                const div = document.createElement('div');
                div.className = 'multiselect-option';
                const safeId = filterKey + '_' + v.toString().replace(/\s+/g, '_').replace(/[^a-zA-Z0-9_]/g, '');
                div.innerHTML = '<input type="checkbox" id="' + safeId + '" value="' + v + '" onchange="updateFilterDisplay(\'' + filterKey + '\',\'' + labelText + '\')">' +
                    '<label for="' + safeId + '">' + v + '</label>';
                dropdown.appendChild(div);
            });
        }

        function populateFilters() {
            // Solution Managers
            buildCheckboxDropdown('solutionMgrDropdown', ALLOWED_ARCHITECTS.sort(), 'solutionMgr', 'Managers');

            // Verticals
            const verticals = [...new Set(ALL_BIDS.map(b => b.vertical))].filter(v => v !== '-').sort();
            buildCheckboxDropdown('verticalDropdown', verticals, 'vertical', 'Verticals');

