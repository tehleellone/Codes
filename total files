const FILTER_DEFS=[
  {key:'typeOfRequest',label:'Type of Request'},
  {key:'typeOfContract',label:'Type of Contract'},
  {key:'vertical',label:'Vertical'},
  {key:'status',label:'Opp. Status'},
  {key:'_year',label:'Year'},
  {key:'_quarter',label:'Quarter'},
  {key:'_month',label:'Month'},
];
const MONTH_NAMES=['Jan','Feb','Mar','Apr','May','Jun','Jul','Aug','Sep','Oct','Nov','Dec'];

function getBidMeta(bid){
  const rd=getRelevantDate(bid); const d=rd?new Date(rd):null;
  return {
    _year:d&&!isNaN(d)?String(d.getFullYear()):null,
    _quarter:d&&!isNaN(d)?getQuarter(rd):null,
    _month:d&&!isNaN(d)?String(d.getMonth()):null,
  };
}
function getFilterVals(key){
  if(key==='_year') return [...new Set(ALL_BIDS.map(b=>{const rd=getRelevantDate(b);const d=rd?new Date(rd):null;return d&&!isNaN(d)?String(d.getFullYear()):null;}).filter(Boolean))].sort();
  if(key==='_quarter') return ['Q1','Q2','Q3','Q4'];
  if(key==='_month') return MONTH_NAMES.map((_,i)=>String(i));
  if(key==='closureProb') return PROB_ORDER;
return [...new Set(ALL_BIDS.map(b=>b[key]).filter(Boolean))].sort();
}
function remapBlankHD(){
  const STATUS_ONGOING=['Lead','Opportunity','On Hold','Proposed'];

  // Step 1: Build AD -> HD map from bids that have a real (non-blank) HD
  const adToHD={};
  ALL_BIDS.forEach(function(b){
    if(b.headDirector&&b.headDirector!=='(Blank)'&&b.headDirector!=='—'&&b.accountDirector&&b.accountDirector!=='—'){
      adToHD[b.accountDirector]=b.headDirector;
    }
  });

  // Step 2: Process blank HD bids
  const remapped=[];
  ALL_BIDS.forEach(function(b){
    if(b.headDirector!=='(Blank)'){
      remapped.push(b); // normal bid, keep as is
      return;
    }
    // Blank HD bid
    if(!STATUS_ONGOING.includes(b.status)){
      // Closed bid with blank HD -> discard completely
      return;
    }
    // Ongoing bid with blank HD -> try to remap
    const realHD=adToHD[b.accountDirector];
    if(!realHD){
      // AD has no known HD mapping -> discard
      return;
    }
    // Reassign HD and keep
    remapped.push(Object.assign({},b,{headDirector:realHD}));
  });

  ALL_BIDS=remapped;
}
function buildFilters(){
  const grid=el('filtersGrid'); grid.innerHTML='';
  const lockedKeys=new Set();
  if(USER.role==='Head Director') lockedKeys.add('headDirector');
  if(USER.role==='Account Director'){lockedKeys.add('headDirector');lockedKeys.add('accountDirector');}
  if(USER.role==='Account Manager'){lockedKeys.add('headDirector');lockedKeys.add('accountDirector');lockedKeys.add('amName');}

  FILTER_DEFS.forEach(function(fd){
    const isLocked=lockedKeys.has(fd.key);
    const div=document.createElement('div'); div.className='filter-group';
    div.innerHTML='<div class="filter-label">'+fd.label+'</div>';
    const wrap=document.createElement('div'); wrap.className='ms-wrap'; wrap.id='ms_'+fd.key;
    const trig=document.createElement('div'); trig.className='ms-trigger'; trig.id='mst_'+fd.key;
    if(isLocked) trig.style.opacity='.5';
    trig.innerHTML='<span id="mstext_'+fd.key+'">All</span><svg viewBox="0 0 24 24"><polyline points="6 9 12 15 18 9"/></svg>';
    if(!isLocked) trig.onclick=function(e){e.stopPropagation();toggleMs(fd.key);};
    const drop=document.createElement('div'); drop.className='ms-dropdown'; drop.id='msd_'+fd.key;
    getFilterVals(fd.key).forEach(function(v){
      if(!v||v==='—'||v==='All') return;
      const label=fd.key==='_month'?MONTH_NAMES[+v]:v;
      const opt=document.createElement('div'); opt.className='ms-option';
      const cid='cb_'+fd.key+'_'+v.toString().replace(/[^a-zA-Z0-9]/g,'_');
      opt.innerHTML='<input type="checkbox" id="'+cid+'" value="'+v+'" onchange="onFilterChange(\''+fd.key+'\')"><label for="'+cid+'">'+label+'</label>';
      drop.appendChild(opt);
    });
    wrap.appendChild(trig); wrap.appendChild(drop); div.appendChild(wrap); grid.appendChild(div);
  });
  applyRoleLocks();
}
function applyRoleLocks(){
  if(USER.role==='Viewer'||USER.role==='Admin'||USER.role==='CEO') return;
  
  if(USER.role==='Head Director'){
    const v=findMyHD();
    if(!v){preSelectAndLock('headDirector',['__NOACCESS__']);return;}
    preSelectAndLock('headDirector',[v]);
  }
  
  if(USER.role==='Account Director'){
    const v=findMyAD();
    if(!v){preSelectAndLock('accountDirector',['__NOACCESS__']);return;}
    const hd=[...new Set(ALL_BIDS.filter(b=>b.accountDirector===v).map(b=>b.headDirector))];
    preSelectAndLock('headDirector',hd);
    preSelectAndLock('accountDirector',[v]);
  }
  
if(USER.role==='Account Manager'){
    let amBids=ALL_BIDS.filter(b=>b.amEmail&&b.amEmail.toLowerCase()===USER.email.toLowerCase());
    if(!amBids.length&&USER.name) amBids=ALL_BIDS.filter(b=>b.amName&&b.amName.toLowerCase()===USER.name.toLowerCase());
    if(!amBids.length){preSelectAndLock('amName',['__NOACCESS__']);return;}
    const amName=amBids[0].amName;
    preSelectAndLock('headDirector',[...new Set(amBids.map(b=>b.headDirector))]);
    preSelectAndLock('accountDirector',[...new Set(amBids.map(b=>b.accountDirector))]);
    preSelectAndLock('amName',[amName]);
  }
}
function findMyHD(){ 
  const name=USER.name.toLowerCase().trim();
  const d=ALL_BIDS.find(b=>b.headDirector&&(
    b.headDirector.toLowerCase().trim()===name||
    b.headDirector.toLowerCase().includes(name)||
    name.includes(b.headDirector.toLowerCase().trim())
  ));
  return d?d.headDirector:null; 
}
function findMyAD(){ 
  const name=USER.name.toLowerCase().trim();
  const d=ALL_BIDS.find(b=>b.accountDirector&&(
    b.accountDirector.toLowerCase().trim()===name||
    b.accountDirector.toLowerCase().includes(name)||
    name.includes(b.accountDirector.toLowerCase().trim())
  ));
  return d?d.accountDirector:null; 
}
function preSelectAndLock(key,values){
  const drop=el('msd_'+key); if(!drop) return;
  drop.querySelectorAll('input[type=checkbox]').forEach(function(cb){cb.checked=values.includes(cb.value);cb.disabled=true;});
  updateMsText(key);
}
function toggleMs(key){
  const drop=el('msd_'+key),trig=el('mst_'+key);
  const isOpen=drop.classList.contains('open');
  document.querySelectorAll('.ms-dropdown.open').forEach(d=>{
    d.classList.remove('open');
    const t=el('mst_'+d.id.replace('msd_',''));
    if(t) t.classList.remove('open');
  });
  if(!isOpen){
    const rect=trig.getBoundingClientRect();
    drop.style.top=(rect.bottom+4)+'px';
    drop.style.left=rect.left+'px';
    drop.style.width=Math.max(rect.width,180)+'px';
    drop.classList.add('open');
    trig.classList.add('open');
  }
}
document.addEventListener('click',function(){ document.querySelectorAll('.ms-dropdown.open').forEach(function(d){ d.classList.remove('open'); const t=el('mst_'+d.id.replace('msd_','')); if(t) t.classList.remove('open'); }); });
window.addEventListener('scroll', function(){
  document.querySelectorAll('.ms-dropdown.open').forEach(function(d){
    const key=d.id.replace('msd_','');
    const trig=el('mst_'+key);
    if(trig){const rect=trig.getBoundingClientRect();d.style.top=(rect.bottom+4)+'px';d.style.left=rect.left+'px';}
  });
}, true);
window.addEventListener('resize', function(){
  document.querySelectorAll('.ms-dropdown.open').forEach(function(d){
    const key=d.id.replace('msd_','');
    const trig=el('mst_'+key);
    if(trig){const rect=trig.getBoundingClientRect();d.style.top=(rect.bottom+4)+'px';d.style.left=rect.left+'px';}
  });
});
function getChecked(key){ const drop=el('msd_'+key); if(!drop) return []; return Array.from(drop.querySelectorAll('input:checked')).map(c=>c.value); }
function updateMsText(key){
  const checked=getChecked(key); const e=el('mstext_'+key); if(!e) return;
  if(!checked.length) e.textContent='All';
  else if(checked.length===1) e.textContent=key==='_month'?MONTH_NAMES[+checked[0]]:checked[0];
  else e.textContent=checked.length+' selected';
}
function onFilterChange(key){
  updateMsText(key);
  // Cascade: year change resets quarter+month; quarter change resets month
  if(key==='_year'){
    clearFilter('_quarter');
    clearFilter('_month');
    rebuildQuarterMonth();
  } else if(key==='_quarter'){
    clearFilter('_month');
    rebuildQuarterMonth();
  }
  applyAll();
}
function rebuildQuarterMonth(){
  const selYears=getChecked('_year');
  const selQuarters=getChecked('_quarter');
  // Filter available months based on selected years+quarters
  const available=ALL_BIDS.filter(b=>{
    const rd=getRelevantDate(b); const d=rd?new Date(rd):null; if(!d||isNaN(d)) return false;
    const yr=String(d.getFullYear());
    const qr='Q'+Math.ceil((d.getMonth()+1)/3);
    if(selYears.length&&!selYears.includes(yr)) return false;
    if(selQuarters.length&&!selQuarters.includes(qr)) return false;
    return true;
  });
  const availMonths=new Set(available.map(b=>{const rd=getRelevantDate(b);const d=rd?new Date(rd):null;return d&&!isNaN(d)?String(d.getMonth()):null;}).filter(Boolean));
  const drop=el('msd__month'); if(!drop) return;
  drop.querySelectorAll('input[type=checkbox]').forEach(cb=>{
    const inScope=availMonths.has(cb.value);
    cb.parentElement.style.opacity=inScope?'1':'0.35';
    cb.parentElement.style.pointerEvents=inScope?'auto':'none';
    if(!inScope) cb.checked=false;
  });
  updateMsText('_month');
}
function clearFilter(key){ const drop=el('msd_'+key); if(!drop) return; drop.querySelectorAll('input:not([disabled])').forEach(c=>c.checked=false); updateMsText(key); }

// ══════════════════════════════════════════════════════════════════
//  APPLY ALL
// ══════════════════════════════════════════════════════════════════
function applyAll(){
  const filters={};
  FILTER_DEFS.forEach(function(fd){ filters[fd.key]=getChecked(fd.key); });
FILTERED=ALL_BIDS.filter(function(bid){
    const meta=getBidMeta(bid);
    for(const fd of FILTER_DEFS){
      const vals=filters[fd.key]; if(!vals.length) continue;
      const bidVal=fd.key.startsWith('_')?meta[fd.key]:bid[fd.key];
      if(!vals.includes(bidVal)) return false;
    }
    return true;
  });

  // Hard-scope FILTERED by role regardless of filter dropdowns
  if(USER.role==='Head Director'){
    const myHD=findMyHD();
    if(myHD) FILTERED=FILTERED.filter(b=>b.headDirector===myHD);
  }
  if(USER.role==='Account Director'){
    const myAD=findMyAD();
    if(myAD) FILTERED=FILTERED.filter(b=>b.accountDirector===myAD);
  }
  if(USER.role==='Account Manager'){
    const byEmail=FILTERED.filter(b=>b.amEmail&&b.amEmail.toLowerCase()===USER.email.toLowerCase());
    FILTERED=byEmail.length?byEmail:FILTERED.filter(b=>b.amName&&b.amName.toLowerCase()===USER.name.toLowerCase());
  }
updateTopStats();

// For Account Manager role
  if(USER.role==='Account Manager'){
    el('hd-section-nav').style.display='none';
    el('adSection').style.display='none';
    renderAMTile();
