            document.getElementById('btnStatus').style.background = 'transparent';
            document.getElementById('btnStatus').style.color = 'var(--text-secondary)';

            // Toggle sections
            document.querySelector('.top-stats').style.display = 'none';
            document.getElementById('assignmentStatsSection').style.display = 'grid';

            applyFilters();
        }
        // ===== MAIN INITIALIZATION =====
        function initAll() {
            // Initialize Lucide icons first
            if (typeof lucide !== 'undefined') {
                lucide.createIcons();
            }

            // Show landing page first
            document.getElementById('landingPage').style.display = 'grid';
            document.getElementById('mainDashboard').style.display = 'none';

            loadUserAccess(function(hasAccess) {
                populateLandingPage();
                // Re-initialize Lucide icons after populating
                if (typeof lucide !== 'undefined') {
                    lucide.createIcons();
                }
            });
        }
        // Initialize on page load
        window.addEventListener('DOMContentLoaded', function() {
            if (typeof lucide !== "undefined") lucide.createIcons();
            initAll();
        });
    </script>
