//  TILE STATS HELPER
// ══════════════════════════════════════════════════════════════════
function buildTileStats(bids, parentBids){  const total=bids.length;
  const won=bids.filter(b=>STATUS_WON.includes(b.status));
  const ip=bids.filter(b=>STATUS_IP.includes(b.status));
  const lost=bids.filter(b=>STATUS_LOST.includes(b.status));
  const wonTCV=won.reduce((s,b)=>s+b.tcv,0);
  const ipTCV=ip.reduce((s,b)=>s+b.tcv,0);
  const lostTCV=lost.reduce((s,b)=>s+b.tcv,0);
  const allTCV=bids.reduce((s,b)=>s+b.tcv,0);
  const winRatio=total?(won.length/total*100).toFixed(1):0;
  const ga=bids.reduce((s,b)=>s+b.gaPoints,0);
const pool=parentBids||FILTERED;
const contribPct=pool.length?(bids.length/pool.length*100).toFixed(1):0;
const allTCV2=pool.reduce((s,b)=>s+b.tcv,0);
  const tcvPct=allTCV2?(allTCV/allTCV2*100).toFixed(1):0;
  return {total,won:won.length,ip:ip.length,lost:lost.length,wonTCV,ipTCV,lostTCV,allTCV,winRatio,ga,contribPct,tcvPct,highProb:bids.filter(b=>['75%','100%'].includes(b.closureProb)).length};
}

