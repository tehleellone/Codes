        function updateTopStats() {
            const totalBids = filteredBids.length;
            const totalTCV = filteredBids.reduce((sum, b) => sum + b.tcv, 0);

            // WON = Billed, Won
            const wonBids = filteredBids.filter(b => ['Won', 'Billed'].includes(b.status)).length;
            const wonTCV = filteredBids.filter(b => ['Won', 'Billed'].includes(b.status)).reduce((sum, b) => sum + b.tcv, 0);

            // IN PROGRESS = Lead, Opportunity, On Hold, Proposed
            const inProgressBids = filteredBids.filter(b => ['Lead', 'Opportunity', 'On Hold', 'Proposed'].includes(b.status)).length;
            const inProgressTCV = filteredBids.filter(b => ['Lead', 'Opportunity', 'On Hold', 'Proposed'].includes(b.status)).reduce((sum, b) => sum + b.tcv, 0);

            // LOST = Lost, Cancelled, No Bid
            const lostBids = filteredBids.filter(b => ['Lost', 'Cancelled', 'No Bid'].includes(b.status)).length;
            const lostTCV = filteredBids.filter(b => ['Lost', 'Cancelled', 'No Bid'].includes(b.status)).reduce((sum, b) => sum + b.tcv, 0);

            // Tile 1: Overall Bids
            document.getElementById('overallBids').textContent = totalBids;
            document.getElementById('overallTCV').textContent = formatCurrency(totalTCV);

            // Tile 2: Total TCV
            document.getElementById('totalTCV').textContent = formatCurrency(totalTCV);
            document.getElementById('wonTCVValue').textContent = formatCurrency(wonTCV);
            document.getElementById('otherTCVValue').textContent = formatCurrency(inProgressTCV + lostTCV);

            // Tile 3: Won
