                    lastCell.style.color = "#f87171";
                    lastCell.style.fontWeight = "bold";
                    lastCell.textContent = "Expired (" + Math.abs(daysLeft) + " days ago)";
                } else {
                    if (daysLeft <= 30) {
                        lastCell.style.color = "#fbbf24";
                        lastCell.style.fontWeight = "bold";
                    }
                    lastCell.textContent = daysLeft + " days";
                }
                tr.appendChild(lastCell);

