                populateMonths();
                populateWeeks();
                document.getElementById('monthSelectedText').textContent = 'All Months';
                document.getElementById('weekSelectedText').textContent = 'All Weeks';
            }
            if (filterKey === 'month') {
                populateWeeks();
                document.getElementById('weekSelectedText').textContent = 'All Weeks';
            }

            applyFilters();
        }

        function getCheckedValues(dropdownId) {
            return Array.from(document.querySelectorAll('#' + dropdownId + ' input[type="checkbox"]:checked'))
                .map(cb => cb.value);
        }

        function getWeekOfYear(date) {
            const d = new Date(date);
            d.setHours(0, 0, 0, 0);
            d.setDate(d.getDate() + 3 - (d.getDay() + 6) % 7);
            const week1 = new Date(d.getFullYear(), 0, 4);
            return 1 + Math.round(((d - week1) / 86400000 - 3 + (week1.getDay() + 6) % 7) / 7);
        }

        function getQuarter(date) {
            const d = new Date(date);
            return 'Q' + Math.ceil((d.getMonth() + 1) / 3);
        }





        function populateQuarters() {
            const selectedYears = getCheckedValues('yearDropdown');
            const quarters = [...new Set(ALL_BIDS
                .filter(b => {
                    const d = new Date(getRelevantDateForBid(b));
                    if (isNaN(d)) return false;
                    if (selectedYears.length === 0) return true;
                    return selectedYears.includes(String(d.getFullYear()));
                })
                .map(b => getQuarter(getRelevantDateForBid(b)))
            )].sort();
            buildCheckboxDropdown('quarterDropdown', quarters, 'quarter', 'Quarters');
        }

        function populateMonths() {
            const selectedYears = getCheckedValues('yearDropdown');
            const selectedQuarters = getCheckedValues('quarterDropdown');
            const monthNames = ['January', 'February', 'March', 'April', 'May', 'June', 'July', 'August', 'September', 'October', 'November', 'December'];

            // Quarter to months mapping
            const quarterMonths = {
                'Q1': [0, 1, 2],
                'Q2': [3, 4, 5],
                'Q3': [6, 7, 8],
                'Q4': [9, 10, 11]
            };

            const availableMonths = [...new Set(ALL_BIDS
                .filter(b => {
                    const d = new Date(getRelevantDateForBid(b));
                    if (isNaN(d)) return false;
                    const yearOk = selectedYears.length === 0 || selectedYears.includes(String(d.getFullYear()));
                    const quarterOk = selectedQuarters.length === 0 || selectedQuarters.some(q => quarterMonths[q] && quarterMonths[q].includes(d.getMonth()));
                    return yearOk && quarterOk;
                })
                .map(b => new Date(getRelevantDateForBid(b)).getMonth())
            )].sort((a, b) => a - b);

            const dropdown = document.getElementById('monthDropdown');
            if (!dropdown) return;
            dropdown.innerHTML = '';
            availableMonths.forEach(function(m) {
                const div = document.createElement('div');
                div.className = 'multiselect-option';
                div.innerHTML = '<input type="checkbox" id="month_' + m + '" value="' + m + '" onchange="updateFilterDisplay(\'month\',\'Months\')">' +
                    '<label for="month_' + m + '">' + monthNames[m] + '</label>';
                dropdown.appendChild(div);
            });
        }

function populateWeeks() {
    const selectedYears = getCheckedValues('yearDropdown');
    const selectedQuarters = getCheckedValues('quarterDropdown');
    const selectedMonths = getCheckedValues('monthDropdown');
    
    const quarterMonths = { 'Q1': [0,1,2], 'Q2': [3,4,5], 'Q3': [6,7,8], 'Q4': [9,10,11] };

    const weeks = [...new Set(ALL_BIDS
        .filter(b => {
            const relevantDate = getRelevantDateForBid(b);
            const d = new Date(relevantDate);
            if (isNaN(d)) return false;
            const yearOk = selectedYears.length === 0 || selectedYears.includes(String(d.getFullYear()));
            const quarterOk = selectedQuarters.length === 0 || selectedQuarters.some(q => quarterMonths[q] && quarterMonths[q].includes(d.getMonth()));
            const monthOk = selectedMonths.length === 0 || selectedMonths.includes(String(d.getMonth()));
            return yearOk && quarterOk && monthOk;
        })
        .map(b => getWeekOfYear(getRelevantDateForBid(b)))
    )].filter(w => !isNaN(w) && w > 0).sort((a, b) => a - b);

    const dropdown = document.getElementById('weekDropdown');
    if (!dropdown) return;
    dropdown.innerHTML = '';
    weeks.forEach(function(w) {
        const div = document.createElement('div');
        div.className = 'multiselect-option';
        div.innerHTML = '<input type="checkbox" id="week_' + w + '" value="' + w + '" onchange="updateFilterDisplay(\'week\',\'Weeks\')">' +
            '<label for="week_' + w + '">Week ' + w + '</label>';
        dropdown.appendChild(div);
    });
